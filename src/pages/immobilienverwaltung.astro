---
import Layout from '../layouts/Layout.astro';
import { immobilienverwaltungOffers } from '../lib/offers';
import { breadcrumbSchema, professionalServiceSchema } from '../lib/seo';

const description =
  'Contentfluss baut AI-Operations für Immobilienverwaltungen: Schadenmeldung, Inbox-Triage, Koordination, Serienkommunikation und Rückstandsprozesse.';

const painpoints = [
  'Schadenmeldungen kommen unvollständig an und brauchen viele Rückfragen.',
  'Inbox-Triage kostet Zeit, Prioritäten bleiben unklar.',
  'Koordination mit Mietern, Eigentümern und Dienstleistern ist stark manuell.',
  'Dokumentenanforderungen laufen ohne klare Frist- und Rücklaufsteuerung.',
  'Rückstands- und Mahnkommunikation ist uneinheitlich und sensibel.',
];

const processSteps = [
  {
    title: 'Workflow-Audit',
    text: 'Vorgangsarten, Mail-Volumen und Engpässe analysieren. Danach den größten operativen Hebel priorisieren.',
  },
  {
    title: 'Build / Umsetzung',
    text: 'Workflow mit klaren Kategorien, Priorisierung und Teamrouting aufsetzen und mit realen Fällen testen.',
  },
  {
    title: 'Betrieb / Optimierung',
    text: 'Regeln, Vorlagen und Routing im Live-Betrieb nachschleifen. Fokus auf Durchlaufzeit und Bearbeitungsqualität.',
  },
];

const structuredData = [
  professionalServiceSchema('/immobilienverwaltung', description),
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Immobilienverwaltung', path: '/immobilienverwaltung' },
  ]),
];
---

<Layout
  title="AI-Operations für Immobilienverwaltung | Contentfluss"
  description={description}
  canonicalPath="/immobilienverwaltung"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">AI-Operations für Immobilienverwaltungen</p>
        <h1>Weniger Kommunikationschaos in der Immobilienverwaltung – strukturierte Abläufe statt Inbox-Feuerwehr</h1>
        <p class="lead">
          Contentfluss automatisiert operative Abläufe in Verwaltungen: Schadenmeldung, Inbox-Triage,
          Koordination mit Mietern und Dienstleistern. Kein CRM-Ersatz – sondern ein AI-Layer,
          der bestehende Prozesse strukturiert.
        </p>
        <p class="trustline">Struktur: Workflow-Audit → Pilot → Ausbau.</p>
        <div class="button-row">
          <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="immo_hero_cta">
            Erstgespräch buchen
          </a>
          <a href="#offers" class="btn btn-secondary" data-track="cta_clicked" data-track-label="immo_hero_offers">
            5 Immo-Offers ansehen
          </a>
        </div>
      </div>

      <aside class="workflow-visual" data-reveal>
        <header>
          <strong>Typische Hebel in der Verwaltung</strong>
          <span>Schaden, Inbox, Koordination</span>
        </header>
        <ul class="metric-list">
          <li>Vollständigere Schadenmeldungen ab Erstkontakt</li>
          <li>Schnellere Inbox-Sortierung und Priorisierung</li>
          <li>Weniger manuelle Abstimmung mit Dienstleistern</li>
          <li>Klare Fristen und Rücklaufsteuerung für Dokumente</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Typische Painpoints in der Immobilienverwaltung</h2>
      </div>
      <div class="card surface" data-reveal style="padding: 1.3rem;">
        <ul class="list">
          {painpoints.map((painpoint) => (
            <li>{painpoint}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section id="offers" class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Die 5 Offers für Immobilienverwaltung</h2>
        <p>Alle Angebote sind auf wiederholbare Ops-Workflows statt Einzelfallprojekte ausgerichtet.</p>
      </div>

      <div class="card-grid two">
        {immobilienverwaltungOffers.map((offer) => (
          <article class="card" data-reveal>
            <span class="chip">{offer.code}</span>
            <h3 style="margin-top: 0.65rem;">{offer.name}</h3>
            <p>{offer.shortDescription}</p>
            <p style="margin-top: 0.75rem;"><strong>Pilot:</strong> {offer.pilotFromPrice}</p>
            <p style="margin-top: 0.35rem;"><strong>Care optional:</strong> {offer.careFromPrice}</p>
            <p style="margin-top: 0.35rem;"><strong>Hinweis:</strong> Finale Kalkulation nach Workflow-Audit.</p>
            <ul class="list list-check" style="margin-top: 0.85rem;">
              {offer.deliverables.slice(0, 3).map((deliverable) => (
                <li>{deliverable}</li>
              ))}
            </ul>
            <div class="button-row">
              <a
                href={`/immobilienverwaltung/${offer.slug}`}
                class="btn btn-secondary"
                data-track="cta_clicked"
                data-track-label={`immo_offer_detail_${offer.slug}`}
              >
                Details ansehen
              </a>
              <a
                href={`/kontakt?workflow=${offer.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`immo_offer_contact_${offer.slug}`}
              >
                Offer besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Prozessmodell für jedes Projekt</h2>
      </div>

      <div class="card-grid three">
        {processSteps.map((step, index) => (
          <article class="card" data-reveal>
            <span class="kicker-number">{index + 1}</span>
            <h3 style="margin-top: 0.8rem;">{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container surface" style="padding: clamp(1.4rem, 4vw, 2.1rem);" data-reveal>
      <h2>Welcher Engpass in eurer Verwaltung hat den größten Hebel?</h2>
      <p class="lead">
        Im Erstgespräch schauen wir auf euren Ablauf und priorisieren den ersten Schritt –
        kostenlos und unverbindlich.
      </p>
      <div class="button-row">
        <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="immo_final_cta">
          Erstgespräch buchen
        </a>
      </div>
    </div>
  </section>
</Layout>
