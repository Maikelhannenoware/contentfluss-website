---
import Layout from '../layouts/Layout.astro';
import { immobilienverwaltungWorkflows } from '../lib/workflows';
import { breadcrumbSchema, faqSchema, professionalServiceSchema } from '../lib/seo';

const description =
  'KI Immobilienverwaltung und KI Hausverwaltung: Contentfluss automatisiert Schadenmeldungen, E-Mail-Triage und Koordination für verwaltende Teams.';

const faqItems = [
  {
    question: 'Ersetzt das unser Portal oder ERP?',
    answer:
      'Nein. Der Workflow ergänzt euer bestehendes System und übernimmt wiederkehrende Kommunikation sowie Vorqualifikation.',
  },
  {
    question: 'Was passiert mit bestehenden E-Mails und Formularen?',
    answer:
      'Bestehende Kanäle bleiben erhalten. Wir strukturieren Eingänge und führen sie in einen klaren Bearbeitungsprozess.',
  },
  {
    question: 'Können wir mit mehreren Bearbeitern arbeiten?',
    answer:
      'Ja. Zuständigkeiten, Prioritäten und Übergaben werden so aufgebaut, dass mehrere Sachbearbeiter sauber zusammenarbeiten können.',
  },
  {
    question: 'Wie sieht Datenschutz aus?',
    answer:
      'Datenschutzanforderungen werden von Anfang an berücksichtigt. Wir arbeiten DSGVO-orientiert und dokumentieren den Prozess transparent.',
  },
  {
    question: 'Lohnt sich das auch für kleinere Verwaltungen?',
    answer:
      'Gerade bei kleinen bis mittleren Teams lohnt sich die Entlastung, wenn viele Vorgänge parallel bearbeitet werden müssen.',
  },
];

const simulatedSnapshots = [
  {
    title: 'Schadenmeldung',
    situation: 'Viele Meldungen starten ohne vollständige Pflichtinformationen.',
    impact: 'Simulierter Zielkorridor: 30-50 % weniger Nachforderungen je Vorgang.',
  },
  {
    title: 'Inbox-Triage',
    situation: 'Hohe Maillast führt zu Verzögerung und unklaren Prioritäten.',
    impact: 'Simulierter Zielkorridor: 20-35 % kürzere Erstreaktionszeit.',
  },
  {
    title: 'Dienstleister-Koordination',
    situation: 'Statusstände werden über mehrere Kanäle manuell nachgehalten.',
    impact: 'Simulierter Zielkorridor: 20-30 % weniger manuelle Abstimmungszeit.',
  },
];

const structuredData = [
  professionalServiceSchema('/immobilienverwaltung', description),
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Immobilienverwaltung', path: '/immobilienverwaltung' },
  ]),
  faqSchema(faqItems),
];
---

<Layout
  title="KI Immobilienverwaltung | Automatisierung für Hausverwaltungen"
  description={description}
  canonicalPath="/immobilienverwaltung"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">AI-Workflows für Immobilienverwaltungen</p>
        <h1>Weniger Kommunikationschaos. Sauberere Vorgänge. Mehr Entlastung im Tagesgeschäft.</h1>
        <p class="lead">
          Contentfluss unterstützt Immobilienverwaltungen mit AI-gestützten Workflows für
          Schadenmeldungen, E-Mail-Triage, Dokumentenanforderungen und Koordination.
        </p>
        <div class="button-row">
          <a
            href="/kontakt"
            class="btn btn-primary"
            data-track="cta_clicked"
            data-track-label="immo_hero_erstgespraech"
          >
            Erstgespräch buchen
          </a>
          <a
            href="/workflows"
            class="btn btn-secondary"
            data-track="cta_clicked"
            data-track-label="immo_hero_workflows"
          >
            Lösungen ansehen
          </a>
        </div>
      </div>

      <aside class="workflow-visual" data-reveal>
        <header>
          <strong>Operative Entlastung</strong>
          <span>Verwaltungsteams</span>
        </header>
        <ul class="metric-list">
          <li>Schadenmeldungen mit Pflichtinfos statt Nachfassen</li>
          <li>E-Mail-Triage nach Priorität und Zuständigkeit</li>
          <li>Statusupdates für Eigentümer, Mieter, Dienstleister</li>
          <li>Weniger Liegenbleiber in wiederkehrenden Vorgängen</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Typische Engpässe</h2>
      </div>
      <div class="card surface" data-reveal style="padding: 1.3rem;">
        <ul class="list">
          <li>Unvollständige Schadenmeldungen</li>
          <li>Zu viele E-Mails in zu wenig Zeit</li>
          <li>Ständiges Nachfassen bei Beteiligten</li>
          <li>Fehlende Informationen in Vorgängen</li>
          <li>Hoher Kommunikationsaufwand mit Mietern, Eigentümern und Dienstleistern</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Unsere 5 Workflow-Lösungen</h2>
      </div>

      <div class="card-grid two">
        {immobilienverwaltungWorkflows.map((workflow) => (
          <article class="card" data-reveal>
            <h3>{workflow.name}</h3>
            <p>{workflow.short}</p>
            <p style="margin-top: 0.8rem;"><strong>Für wen:</strong> {workflow.who}</p>
            <p style="margin-top: 0.55rem;"><strong>Typischer Effekt:</strong> {workflow.effect}</p>
            <div class="button-row">
              <a
                href={`/kontakt?workflow=${workflow.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`immo_${workflow.slug}`}
              >
                Workflow besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Wirkung im Alltag</h2>
      </div>

      <div class="card-grid five" style="display: grid; gap: 0.85rem; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
        <article class="card" data-reveal><p>Vollständigere Eingänge</p></article>
        <article class="card" data-reveal><p>Schnellere Bearbeitung</p></article>
        <article class="card" data-reveal><p>Weniger Rückfragen</p></article>
        <article class="card" data-reveal><p>Strukturiertere Kommunikation</p></article>
        <article class="card" data-reveal><p>Entlastete Sachbearbeitung</p></article>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Preislogik</h2>
        <p>Projektbezogene Orientierung für Verwaltungsprozesse mit höherer Prozesskomplexität.</p>
      </div>

      <div class="card-grid three">
        <article class="card card-accent" data-reveal>
          <h3>Workflow-Audit</h3>
          <p class="price-badge">ab 590 € einmalig</p>
          <p>Diagnose, Prozessanalyse und Priorisierung. Bei Projektstart anrechenbar.</p>
        </article>

        <article class="card card-accent" data-reveal>
          <h3>Build / Umsetzung</h3>
          <p class="price-badge">ab 3.900 €</p>
          <p>Umsetzung mit klaren Statusflüssen, Übergaben und operativer Testphase.</p>
        </article>

        <article class="card card-accent" data-reveal>
          <h3>Betrieb / Optimierung</h3>
          <p class="price-badge">ab 590 €/Monat</p>
          <p>Laufende Betreuung, Monitoring und strukturiertes Finetuning im Betrieb.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Beispielhafte Wirkungsbilder</h2>
        <p>Transparente Simulationen zur Einordnung, keine veröffentlichten Kunden-Referenzen.</p>
      </div>

      <div class="card-grid three">
        {simulatedSnapshots.map((item) => (
          <article class="card card-muted" data-reveal>
            <span class="chip">Simulation</span>
            <h3>{item.title}</h3>
            <p style="margin-top: 0.6rem;"><strong>Ausgangslage:</strong> {item.situation}</p>
            <p style="margin-top: 0.55rem;"><strong>Orientierung:</strong> {item.impact}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>FAQ Immobilienverwaltung</h2>
      </div>

      <div class="faq-list">
        {faqItems.map((faq) => (
          <details data-reveal>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>

      <div class="button-row" data-reveal>
        <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="immo_final_cta">
          Jetzt Verwaltungs-Workflow besprechen
        </a>
      </div>
    </div>
  </section>
</Layout>
