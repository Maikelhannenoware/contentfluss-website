---
import Layout from '../layouts/Layout.astro';
import { pageMeta, breadcrumbSchema, professionalServiceSchema } from '../lib/seo';
import { immobilienverwaltungWorkflows } from '../lib/workflows';

const meta = pageMeta.immobilienverwaltung;
const schemas = [
  breadcrumbSchema([{name:'Startseite',path:'/'},{name:'Immobilienverwaltung',path:'/immobilienverwaltung'}]),
  professionalServiceSchema('/immobilienverwaltung', meta.description),
];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <section class="hero-sub">
    <div class="container content-narrow">
      <span class="eyebrow">Für Immobilienverwaltungen</span>
      <h1 style="margin-top:1rem">Weniger unstrukturierte Eingänge. Weniger Rückfragen. Schnellere Bearbeitung.</h1>
      <p class="page-intro" style="margin-top:1rem">Wenn Schadenmeldungen über verschiedene Kanäle unsauber reinkommen und Informationen ständig nachgezogen werden müssen, braucht es einen klareren Workflow statt mehr Kleinarbeit.</p>
      <div class="flex-row" style="margin-top:2rem">
        <a href="/kontakt" class="btn btn-primary btn-lg" data-track="immo_hero_cta">Fit-Call buchen</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Typische Engpässe</span>
        <h2>Was täglich Zeit frisst</h2>
      </div>
      <div class="grid-2" data-stagger>
        {[
          { title: 'Unstrukturierte Schadenmeldungen', body: 'Meldungen kommen per Anruf, Mail, WhatsApp — oft ohne Fotos, ohne Einheitsnummer, ohne klare Beschreibung. Jeder Eingang erzeugt Rückfragen.' },
          { title: 'Endlose Rückfragen', body: 'Fehlende Infos müssen einzeln nachgezogen werden. E-Mail hin, Anruf her. Bis alles zusammen ist, geht ein halber Tag drauf.' },
          { title: 'Informationen in verschiedenen Kanälen', body: 'Eigentümer schreiben per Mail, Mieter rufen an, Handwerker melden per WhatsApp. Nichts landet zentral, nichts ist nachvollziehbar.' },
          { title: 'Prozesse hängen an Personen', body: 'Wenn die Sachbearbeiterin krank ist, weiß niemand, wo der Vorgang steht. Übergaben kosten mehr Zeit als die Bearbeitung selbst.' },
        ].map(p => (
          <div class="card">
            <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.5rem">{p.title}</h3>
            <p style="font-size:0.875rem;max-width:none">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Workflows</span>
        <h2>Was automatisiert werden kann</h2>
        <p>Konkrete Abläufe für wiederkehrende Aufgaben in der Hausverwaltung.</p>
      </div>
      <div class="grid-2" data-stagger>
        {immobilienverwaltungWorkflows.map(wf => (
          <div class="workflow-card">
            <div class="workflow-card-meta">
              <h3 class="workflow-card-title">{wf.name}</h3>
            </div>
            <div>
              <p class="workflow-col-label">Problem</p>
              <p class="workflow-problem-block">{wf.problem}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was automatisiert wird</p>
              <p style="font-size:0.875rem;color:var(--color-text-secondary)">{wf.solution}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was dadurch besser läuft</p>
              <ul class="workflow-benefits">
                {wf.benefits.map(b => <li>{b}</li>)}
              </ul>
            </div>
            <div class="card-footer">
              <a href={`/kontakt?workflow=${wf.slug}`} class="btn btn-secondary btn-sm" data-track={`immo_wf_${wf.slug}`}>Anfragen</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Zusammenarbeit</span>
        <h2>Wie es abläuft</h2>
      </div>
      <div class="grid-3" data-stagger>
        {[
          { n:'01', title:'Prozesslast klären', body:'Im Fit-Call schauen wir, welche Abläufe am meisten Zeit kosten und wo Übergaben hängen.' },
          { n:'02', title:'Workflow aufsetzen', body:'Wir bauen den Ablauf auf eure Kanäle, Systeme und typischen Vorgangsmuster zu.' },
          { n:'03', title:'Einsetzen und nachschärfen', body:'Live-Gang im Tagesgeschäft, Begleitung beim Start, Anpassung wo nötig.' },
        ].map(s => (
          <div class="process-step">
            <span class="process-step-num">{s.n}</span>
            <p class="process-step-title">{s.title}</p>
            <p class="process-step-body">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container content-center">
      <h2>Welcher Ablauf bindet bei euch die meiste Zeit?</h2>
      <p style="margin-top:0.75rem;margin-bottom:2rem;margin-inline:auto">Im Fit-Call klären wir, ob ein Workflow das lösen kann — und was das kosten würde.</p>
      <a href="/kontakt" class="btn btn-primary btn-lg" data-track="immo_final_cta">Fit-Call buchen</a>
    </div>
  </section>

</Layout>
