---
import Layout from '../layouts/Layout.astro';
import { immobilienverwaltungOffers } from '../lib/offers';
import { breadcrumbSchema, professionalServiceSchema } from '../lib/seo';

const description =
  'Contentfluss baut AI-Operations fuer Immobilienverwaltungen: Schadenmeldung, Inbox-Triage, Koordination, Serienkommunikation und Rueckstandsprozesse.';

const painpoints = [
  'Schadenmeldungen kommen unvollstaendig an und brauchen viele Rueckfragen.',
  'Inbox-Triage kostet Zeit, Prioritaeten bleiben unklar.',
  'Koordination mit Mietern, Eigentuemern und Dienstleistern ist stark manuell.',
  'Dokumentenanforderungen laufen ohne klare Frist- und Ruecklaufsteuerung.',
  'Rueckstands- und Mahnkommunikation ist uneinheitlich und sensibel.',
];

const processSteps = [
  {
    title: 'Workflow-Audit',
    text: 'Vorgangsarten, Mail-Volumen und Engpaesse analysieren. Danach den groessten operativen Hebel priorisieren.',
  },
  {
    title: 'Build / Umsetzung',
    text: 'Workflow mit klaren Kategorien, Priorisierung und Teamrouting aufsetzen und mit realen Faellen testen.',
  },
  {
    title: 'Betrieb / Optimierung',
    text: 'Regeln, Vorlagen und Routing im Live-Betrieb nachschleifen. Fokus auf Durchlaufzeit und Bearbeitungsqualitaet.',
  },
];

const structuredData = [
  professionalServiceSchema('/immobilienverwaltung', description),
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Immobilienverwaltung', path: '/immobilienverwaltung' },
  ]),
];
---

<Layout
  title="AI-Operations fuer Immobilienverwaltung | Contentfluss"
  description={description}
  canonicalPath="/immobilienverwaltung"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">AI-Operations fuer Immobilienverwaltungen</p>
        <h1>Weniger Kommunikationschaos. Schnellere Bearbeitung. Strukturierte Vorgaenge statt Inbox-Feuerwehr.</h1>
        <p class="lead">
          Contentfluss baut einen AI-Layer ueber bestehende Verwaltungsprozesse. Fokus: Schadenmeldung,
          Triage, Routing, Koordination und wiederkehrende Kommunikationsablaeufe.
        </p>
        <p class="trustline">Struktur: Workflow-Audit -> Build -> Betrieb.</p>
        <div class="button-row">
          <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="immo_hero_cta">
            Erstgespraech buchen
          </a>
          <a href="#offers" class="btn btn-secondary" data-track="cta_clicked" data-track-label="immo_hero_offers">
            5 Immo-Offers ansehen
          </a>
        </div>
      </div>

      <aside class="workflow-visual" data-reveal>
        <header>
          <strong>Typische Hebel in der Verwaltung</strong>
          <span>Schaden, Inbox, Koordination</span>
        </header>
        <ul class="metric-list">
          <li>Vollstaendigere Schadenmeldungen ab Erstkontakt</li>
          <li>Schnellere Inbox-Sortierung und Priorisierung</li>
          <li>Weniger manuelle Abstimmung mit Dienstleistern</li>
          <li>Klare Fristen und Ruecklaufsteuerung fuer Dokumente</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Typische Painpoints in der Immobilienverwaltung</h2>
      </div>
      <div class="card surface" data-reveal style="padding: 1.3rem;">
        <ul class="list">
          {painpoints.map((painpoint) => (
            <li>{painpoint}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section id="offers" class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Die 5 Offers fuer Immobilienverwaltung</h2>
        <p>Alle Angebote sind auf wiederholbare Ops-Workflows statt Einzelfallprojekte ausgerichtet.</p>
      </div>

      <div class="card-grid two">
        {immobilienverwaltungOffers.map((offer) => (
          <article class="card" data-reveal>
            <span class="chip">{offer.code}</span>
            <h3 style="margin-top: 0.65rem;">{offer.name}</h3>
            <p>{offer.shortDescription}</p>
            <p style="margin-top: 0.75rem;"><strong>Setup:</strong> {offer.setupPrice}</p>
            <p style="margin-top: 0.35rem;"><strong>Betrieb:</strong> {offer.retainerPrice}</p>
            <ul class="list list-check" style="margin-top: 0.85rem;">
              {offer.deliverables.slice(0, 3).map((deliverable) => (
                <li>{deliverable}</li>
              ))}
            </ul>
            <div class="button-row">
              <a
                href={`/immobilienverwaltung/${offer.slug}`}
                class="btn btn-secondary"
                data-track="cta_clicked"
                data-track-label={`immo_offer_detail_${offer.slug}`}
              >
                Details ansehen
              </a>
              <a
                href={`/kontakt?workflow=${offer.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`immo_offer_contact_${offer.slug}`}
              >
                Offer besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Prozessmodell fuer jedes Projekt</h2>
      </div>

      <div class="card-grid three">
        {processSteps.map((step, index) => (
          <article class="card" data-reveal>
            <span class="kicker-number">{index + 1}</span>
            <h3 style="margin-top: 0.8rem;">{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container surface" style="padding: clamp(1.4rem, 4vw, 2.1rem);" data-reveal>
      <h2>Immo-Pivot operativ umsetzen</h2>
      <p class="lead">
        Einstieg ueber die priorisierten Kernoffers IM-01 und IM-02. Danach folgt der Ausbau Richtung
        Koordination, Serienkommunikation und Rueckstandsprozesse.
      </p>
      <div class="button-row">
        <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="immo_final_cta">
          Erstes Offer priorisieren
        </a>
      </div>
    </div>
  </section>
</Layout>
