---
import Layout from '../../layouts/Layout.astro';
import type { OfferDefinition } from '../../lib/offers';
import { handwerkOffers } from '../../lib/offers';
import { breadcrumbSchema, professionalServiceSchema } from '../../lib/seo';

export function getStaticPaths() {
  return handwerkOffers.map((offer) => ({
    params: { offerSlug: offer.slug },
    props: { offer },
  }));
}

interface Props {
  offer: OfferDefinition;
}

const { offer } = Astro.props as Props;

const description = `${offer.code} ${offer.name}: ${offer.shortDescription}`;

const structuredData = [
  professionalServiceSchema(`/handwerk/${offer.slug}`, description),
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Handwerk', path: '/handwerk' },
    { name: `${offer.code} ${offer.name}`, path: `/handwerk/${offer.slug}` },
  ]),
];
---

<Layout
  title={`${offer.code} ${offer.name} | Handwerk Offer`}
  description={description}
  canonicalPath={`/handwerk/${offer.slug}`}
  structuredData={structuredData}
>
  <section class="hero-sub">
    <div class="container hero-split">
      <div data-reveal>
        <p class="eyebrow">{offer.code} · Handwerk Offer</p>
        <h1>{offer.name}</h1>
        <p class="page-intro">{offer.shortDescription}</p>
        <p style="font-size:0.875rem;color:var(--color-text-secondary);margin-top:0.5rem"><strong>Zielgruppe:</strong> {offer.targetGroup}</p>
        <div class="flex-row" style="margin-top:1.5rem">
          <a
            href={`/kontakt?workflow=${offer.slug}`}
            class="btn btn-primary"
            data-track="cta_clicked"
            data-track-label={`offer_hw_contact_${offer.slug}`}
          >
            Offer besprechen
          </a>
          <a href="/handwerk" class="btn btn-secondary" data-track="cta_clicked" data-track-label="offer_hw_back">
            Zurück zu Handwerk
          </a>
        </div>
      </div>

      <aside class="card card-elevated" data-reveal>
        <header>
          <strong>Projektstart</strong>
          <span>{offer.code}</span>
        </header>
        <ul class="benefit-list">
          <li>Pilot ab: {offer.pilotFromPrice}</li>
          <li>Care optional ab: {offer.careFromPrice}</li>
          <li>Implementierung: {offer.implementationTime}</li>
          <li>Hinweis: Finale Kalkulation nach Workflow-Audit.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section-sm">
    <div class="container grid-2">
      <article class="card" data-reveal>
        <h2 style="font-size: 1.5rem;">Problem</h2>
        <p>{offer.problem}</p>
      </article>
      <article class="card card-accent" data-reveal>
        <h2 style="font-size: 1.5rem;">Lösung</h2>
        <p>{offer.solution}</p>
      </article>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Deliverables</h2>
      </div>
      <div class="card" data-reveal>
        <ul class="benefit-list">
          {offer.deliverables.map((deliverable) => (
            <li>{deliverable}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container grid-2">
      <article class="card" data-reveal>
        <h2 style="font-size: 1.5rem;">Tech-Stack</h2>
        <ul class="benefit-list" style="margin-top: 0.75rem;">
          {offer.techStack.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>

      <article class="card" data-reveal>
        <h2 style="font-size: 1.5rem;">Onboarding-Ablauf</h2>
        <ul class="benefit-list" style="margin-top: 0.75rem;">
          {offer.onboarding.map((step) => (
            <li>{step}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  {offer.caution && (
    <section class="section-sm">
      <div class="container" data-reveal>
        <article class="card card-elevated">
          <h2 style="font-size: 1.35rem;">Hinweis</h2>
          <p>{offer.caution}</p>
        </article>
      </div>
    </section>
  )}

  <section class="section-sm">
    <div class="container" data-reveal>
      <div class="card card-accent" style="padding: clamp(1.4rem, 4vw, 2.1rem);">
        <h2>Nächster Schritt</h2>
        <p class="page-intro">
          Im Erstgespräch klären wir Datenlage, Kanalpräferenzen und den kleinsten sinnvollen
          Pilot für {` ${offer.code}`}. Danach folgt ein klarer Implementierungsplan.
        </p>
        <div class="flex-row" style="margin-top:1.5rem">
          <a
            href={`/kontakt?workflow=${offer.slug}`}
            class="btn btn-primary"
            data-track="cta_clicked"
            data-track-label={`offer_hw_final_${offer.slug}`}
          >
            Erstgespräch zu {offer.code}
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
