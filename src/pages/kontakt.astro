---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kontakt & Erstgespräch | Contentfluss"
  description="Kostenloses 15-Minuten-Erstgespräch buchen. Wir beraten deutschlandweit - remote oder vor Ort."
>
  <section class="mx-auto w-full max-w-6xl px-6 pb-20 pt-16">
    <div class="mb-16">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Erstgespräch buchen</h1>
      <p class="mb-8 mt-3 text-slate-600">Wähle einfach einen freien Slot - 15 Minuten, kostenlos und unverbindlich.</p>
      <div class="calendly-inline-widget overflow-hidden rounded-xl border border-slate-200" data-url="https://calendly.com/maikel-hannen/kostenloses-erstgesprach" style="min-width:320px;height:700px;"></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async is:inline></script>
    </div>

    <div class="mb-16 flex items-center gap-4">
      <div class="flex-1 border-t border-slate-200"></div>
      <span class="text-sm text-slate-400">oder Formular nutzen</span>
      <div class="flex-1 border-t border-slate-200"></div>
    </div>

    <div class="grid gap-16 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Gespräch anfragen</h2>
        <p class="mb-8 mt-4 leading-relaxed text-slate-600">
          Wir arbeiten deutschlandweit - remote oder vor Ort. In 15 Minuten sehen wir, welche KI-Lösung für euren Betrieb sinnvoll ist.
        </p>

        <div class="space-y-4 text-sm">
          <div>
            <p class="font-semibold text-slate-900">E-Mail</p>
            <a href="mailto:hallo@contentfluss.de" class="text-slate-600 transition-colors hover:text-slate-900">hallo@contentfluss.de</a>
          </div>
          <div>
            <p class="font-semibold text-slate-900">Zusammenarbeit</p>
            <p class="text-slate-600">Deutschlandweit - remote oder vor Ort</p>
          </div>
          <div>
            <p class="font-semibold text-slate-900">Reaktionszeit</p>
            <p class="text-slate-600">In der Regel innerhalb von 24 Stunden</p>
          </div>
        </div>
      </div>

      <div>
        <form id="kontaktform" class="space-y-4">
          <div class="hidden" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div>
            <label for="name" class="mb-1 block text-sm font-medium text-slate-900">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-slate-400 focus:outline-none"
              placeholder="Max Mustermann"
            />
          </div>

          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-slate-900">E-Mail</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-slate-400 focus:outline-none"
              placeholder="max@unternehmen.de"
            />
          </div>

          <div>
            <label for="betrieb" class="mb-1 block text-sm font-medium text-slate-900">Unternehmen</label>
            <input
              type="text"
              id="betrieb"
              name="betrieb"
              class="w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-slate-400 focus:outline-none"
              placeholder="z.B. Muster GmbH"
            />
          </div>

          <div>
            <label for="nachricht" class="mb-1 block text-sm font-medium text-slate-900">Was soll automatisiert werden?</label>
            <textarea
              id="nachricht"
              name="nachricht"
              rows="4"
              required
              minlength="20"
              maxlength="4000"
              class="w-full resize-none rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:border-slate-400 focus:outline-none"
              placeholder="Beschreibt kurz eure aktuelle Situation und wo ihr Entlastung braucht..."
            ></textarea>
            <p class="mt-1 text-xs text-slate-500">Mindestens 20 Zeichen.</p>
          </div>

          <div id="form-error" role="alert" class="hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600"></div>

          <button
            type="submit"
            id="submit-btn"
            data-track="contact_submit_clicked"
            class="btn-primary w-full rounded-lg px-6 py-3 text-sm font-semibold text-white disabled:cursor-not-allowed disabled:opacity-50"
          >
            Anfrage senden
          </button>

          <p class="text-xs leading-relaxed text-slate-500">
            Mit dem Absenden stimmst du der Verarbeitung deiner Daten zur Bearbeitung der Anfrage zu.
            Details in der <a href="/datenschutz" class="underline hover:text-slate-700">Datenschutzerklärung</a>.
          </p>
        </form>

        <div id="form-success" class="hidden py-8 text-center">
          <p class="mb-2 text-2xl">✓</p>
          <p class="mb-1 font-medium text-slate-900">Nachricht angekommen!</p>
          <p class="text-sm text-slate-600">Wir melden uns innerhalb von 24 Stunden bei dir.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  type TrackFn = (eventName: string, data?: Record<string, string>) => void;
  type TrackWindow = Window & typeof globalThis & { contentflussTrack?: TrackFn };

  const form = document.getElementById('kontaktform') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorDiv = document.getElementById('form-error') as HTMLDivElement;
  const successDiv = document.getElementById('form-success') as HTMLDivElement;
  const nachrichtField = document.getElementById('nachricht') as HTMLTextAreaElement;

  let formStartedTracked = false;
  let isSubmitting = false;

  function track(eventName: string, data?: Record<string, string>) {
    (window as TrackWindow).contentflussTrack?.(eventName, data);
  }

  function setError(message: string) {
    errorDiv.textContent = message;
    errorDiv.classList.remove('hidden');
  }

  function clearError() {
    errorDiv.textContent = '';
    errorDiv.classList.add('hidden');
  }

  function setSubmitting(submitting: boolean) {
    isSubmitting = submitting;
    submitBtn.disabled = submitting;
    submitBtn.textContent = submitting ? 'Wird gesendet…' : 'Anfrage senden';
  }

  function mapApiError(code: string, fallback: string): string {
    if (code === 'NAME_REQUIRED') return 'Bitte gib deinen Namen ein.';
    if (code === 'EMAIL_INVALID') return 'Bitte gib eine gültige E-Mail-Adresse ein.';
    if (code === 'MESSAGE_TOO_SHORT') return 'Bitte beschreibe dein Anliegen in mindestens 20 Zeichen.';
    if (code === 'BOT_DETECTED') return 'Anfrage konnte nicht verarbeitet werden.';
    if (code === 'RATE_LIMITED') return 'Zu viele Anfragen. Bitte versuche es in einigen Minuten erneut.';
    if (code === 'CONTACT_UNAVAILABLE') return 'Der Service ist aktuell nicht verfügbar. Bitte schreibe direkt an hallo@contentfluss.de.';
    if (code === 'MAIL_SEND_FAILED') return 'E-Mail konnte nicht gesendet werden. Bitte versuche es erneut oder nutze hallo@contentfluss.de.';
    return fallback;
  }

  function getTrimmedValue(formData: FormData, field: string) {
    return String(formData.get(field) ?? '').trim();
  }

  function validateFormData(formData: FormData): string | null {
    const name = getTrimmedValue(formData, 'name');
    const email = getTrimmedValue(formData, 'email');
    const nachricht = getTrimmedValue(formData, 'nachricht');
    const website = getTrimmedValue(formData, 'website');

    if (website) return 'Anfrage konnte nicht verarbeitet werden.';
    if (!name) return 'Bitte gib deinen Namen ein.';
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return 'Bitte gib eine gültige E-Mail-Adresse ein.';
    if (!nachricht || nachricht.length < 20) return 'Bitte beschreibe dein Anliegen in mindestens 20 Zeichen.';

    return null;
  }

  form.addEventListener('input', () => {
    if (!formStartedTracked) {
      formStartedTracked = true;
      track('contact_form_started');
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (isSubmitting) return;

    clearError();

    const formData = new FormData(form);
    const validationError = validateFormData(formData);
    if (validationError) {
      setError(validationError);
      return;
    }

    setSubmitting(true);
    track('contact_form_submit_attempted');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: getTrimmedValue(formData, 'name'),
          email: getTrimmedValue(formData, 'email'),
          betrieb: getTrimmedValue(formData, 'betrieb'),
          nachricht: getTrimmedValue(formData, 'nachricht'),
          website: getTrimmedValue(formData, 'website'),
        }),
      });

      const json = (await res.json().catch(() => ({}))) as { success?: boolean; error?: string; code?: string };
      if (res.ok && json.success) {
        form.classList.add('hidden');
        successDiv.classList.remove('hidden');
        track('contact_form_submitted');
      } else {
        const code = typeof json.code === 'string' ? json.code : `HTTP_${res.status}`;
        const fallback = typeof json.error === 'string' ? json.error : `Fehler ${res.status}`;
        setError(mapApiError(code, fallback));
        track('contact_form_submit_failed', { code });
      }
    } catch (err) {
      setError(`Netzwerkfehler: ${err instanceof Error ? err.message : String(err)}`);
      track('contact_form_submit_failed', { code: 'NETWORK_ERROR' });
    } finally {
      setSubmitting(false);
    }
  });

  nachrichtField.addEventListener('blur', () => {
    const message = nachrichtField.value.trim();
    if (!message || message.length >= 20) return;
    setError('Bitte beschreibe dein Anliegen in mindestens 20 Zeichen.');
  });
</script>
