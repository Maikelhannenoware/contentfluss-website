---
import Layout from '../layouts/Layout.astro';
import { pageMeta, breadcrumbSchema, professionalServiceSchema } from '../lib/seo';

const meta = pageMeta.kontakt;
const schemas = [
  breadcrumbSchema([{name:'Startseite',path:'/'},{name:'Kontakt',path:'/kontakt'}]),
  professionalServiceSchema('/kontakt', meta.description),
];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <section class="hero-sub">
    <div class="container content-narrow">
      <span class="eyebrow">Kontakt</span>
      <h1 style="margin-top:1rem">Klären, ob ein Workflow bei euch Sinn ergibt.</h1>
      <p class="page-intro" style="margin-top:1rem">Im kostenlosen Fit-Call schauen wir uns an, wo bei euch manuelle Arbeit, Rückfragen oder verlorene Anfragen entstehen.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="content-aside">
        <!-- Left: context and trust -->
        <div>
          <div style="margin-bottom:2.5rem">
            <h3 style="margin-bottom:1rem">Was im Fit-Call passiert</h3>
            <ul class="benefit-list">
              <li>Wir schauen, wo heute Zeit verloren geht</li>
              <li>Wir besprechen, welcher Ablauf zuerst Sinn ergibt</li>
              <li>Wir klären, wie eine Umsetzung aussehen könnte</li>
              <li>Wir schätzen den Aufwand realistisch ein</li>
            </ul>
          </div>

          <div style="margin-bottom:2.5rem">
            <h3 style="margin-bottom:1rem">Für wen das passt</h3>
            <ul class="benefit-list">
              <li>Handwerksbetriebe oder Hausverwaltungen mit 3–30 Mitarbeitern</li>
              <li>Wiederkehrende operative Engpässe im Tagesgeschäft</li>
              <li>Bereitschaft, einen konkreten Ablauf zu verändern</li>
            </ul>
          </div>

          <div>
            <h3 style="margin-bottom:1rem">Wann ein Fit-Call keinen Sinn ergibt</h3>
            <ul class="pain-list">
              <li>Kein klarer Prozessschmerz — nur allgemeines Interesse an KI</li>
              <li>Einmaliges Projekt ohne operativen Kontext</li>
              <li>Erwartung einer fertigen Software statt eines Workflows</li>
            </ul>
          </div>
        </div>

        <!-- Right: conversion elements -->
        <div>
          <!-- Primary: Calendly -->
          <div class="card card-accent" style="margin-bottom:2rem" data-reveal>
            <h2 style="font-size:1.25rem;margin-bottom:0.75rem">Fit-Call buchen</h2>
            <p style="font-size:0.875rem;margin-bottom:1.25rem;max-width:none">Ca. 30 Minuten, kostenlos, kein Pitch. Wir klären gemeinsam, ob ein Workflow bei euch Sinn ergibt.</p>
            <a
              href="https://calendly.com/maikel-hannen/kostenloses-erstgesprach"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-full"
              data-track="kontakt_calendly"
            >
              Termin wählen
            </a>
          </div>

          <!-- Divider -->
          <div style="text-align:center;margin-bottom:2rem;position:relative">
            <hr class="divider" />
            <span style="position:relative;top:-0.75rem;background:var(--color-bg);padding:0 1rem;font-size:0.875rem;color:var(--color-text-muted)">oder Anfrage senden</span>
          </div>

          <!-- Secondary: Form -->
          <form id="contact-form" class="form-stack" data-reveal>
            <div class="hidden" aria-hidden="true">
              <label for="website">Website</label>
              <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-row">
              <div class="form-field">
                <label class="form-label" for="name">Name</label>
                <input class="form-input" id="name" name="name" type="text" required placeholder="Vor- und Nachname" />
              </div>
              <div class="form-field">
                <label class="form-label" for="company">Unternehmen</label>
                <input class="form-input" id="company" name="company" type="text" required placeholder="Unternehmensname" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label class="form-label" for="email">E-Mail</label>
                <input class="form-input" id="email" name="email" type="email" required placeholder="name@unternehmen.de" />
              </div>
              <div class="form-field">
                <label class="form-label" for="branche">Branche</label>
                <select class="form-select" id="branche" name="branche" required>
                  <option value="">Bitte auswählen</option>
                  <option value="handwerk">Handwerk</option>
                  <option value="immobilienverwaltung">Immobilienverwaltung</option>
                  <option value="sonstiges">Sonstiges</option>
                </select>
              </div>
            </div>

            <div class="form-field">
              <label class="form-label" for="engpass">Aktueller Engpass</label>
              <textarea class="form-textarea" id="engpass" name="engpass" required minlength="15" placeholder="Wo hakt es im Alltag am stärksten?"></textarea>
            </div>

            <div class="form-field">
              <label class="form-label" for="ziel">Was soll automatisiert oder verbessert werden?</label>
              <textarea class="form-textarea" id="ziel" name="ziel" required minlength="20" placeholder="Welche Ergebnisse wollt ihr konkret erreichen?"></textarea>
            </div>

            <label class="form-consent" for="consent">
              <input id="consent" name="consent" type="checkbox" value="true" required />
              <span class="form-consent-text">Ich stimme der Verarbeitung meiner Angaben zur Bearbeitung der Anfrage zu. <a href="/datenschutz" style="text-decoration:underline">Datenschutzhinweise</a></span>
            </label>

            <div id="form-error" class="form-feedback form-feedback-error hidden" role="alert"></div>

            <button
              id="submit-btn"
              type="submit"
              class="btn btn-primary btn-full"
              data-track="kontakt_form_submit"
            >
              Anfrage senden
            </button>

            <p style="font-size:0.8125rem;color:var(--color-text-muted)">Antwort in der Regel innerhalb von 24 Stunden.</p>
          </form>

          <div id="form-success" class="form-feedback form-feedback-success hidden" role="status">
            Danke, eure Anfrage ist eingegangen. Wir melden uns zeitnah mit einem konkreten Vorschlag.
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const errorBox = document.getElementById('form-error') as HTMLDivElement | null;
  const successBox = document.getElementById('form-success') as HTMLDivElement | null;

  if (form && submitBtn && errorBox && successBox) {
    const formEl = form;
    const submitButton = submitBtn;
    const errorElement = errorBox;
    const successElement = successBox;

    type ContactApiResponse = {
      success?: boolean;
      code?: string;
    };

    let formStartedTracked = false;
    let submitting = false;

    function track(eventName: string, data: Record<string, string> = {}) {
      if (typeof window.contentflussTrack === 'function') {
        window.contentflussTrack(eventName, data);
      }
    }

    function setError(message: string) {
      errorElement.textContent = message;
      errorElement.classList.remove('hidden');
    }

    function clearError() {
      errorElement.textContent = '';
      errorElement.classList.add('hidden');
    }

    function setSubmitting(state: boolean) {
      submitting = state;
      submitButton.disabled = state;
      submitButton.textContent = state ? 'Wird gesendet…' : 'Anfrage senden';
    }

    function valueOf(formData: FormData, field: string): string {
      return String(formData.get(field) || '').trim();
    }

    function mapApiError(code: string): string {
      switch (code) {
        case 'NAME_REQUIRED':
          return 'Bitte tragt euren Namen ein.';
        case 'COMPANY_REQUIRED':
          return 'Bitte tragt euer Unternehmen ein.';
        case 'EMAIL_INVALID':
          return 'Bitte gebt eine gültige E-Mail-Adresse ein.';
        case 'BRANCH_INVALID':
          return 'Bitte wählt eine Branche aus.';
        case 'BOT_DETECTED':
          return 'Anfrage konnte nicht verarbeitet werden.';
        case 'CONSENT_REQUIRED':
          return 'Bitte bestätigt die Datenschutzeinwilligung.';
        case 'BOT_OR_INVALID_INPUT':
          return 'Anfrage konnte nicht verarbeitet werden.';
        case 'MESSAGE_TOO_SHORT':
          return 'Bitte beschreibt den Engpass und das Ziel etwas genauer.';
        case 'RATE_LIMITED':
          return 'Zu viele Anfragen. Bitte versucht es in einigen Minuten erneut.';
        case 'CONTACT_UNAVAILABLE':
          return 'Der Service ist aktuell nicht verfügbar. Bitte schreibt an hallo@contentfluss.de.';
        case 'MAIL_SEND_FAILED':
          return 'E-Mail konnte nicht gesendet werden. Bitte versucht es erneut.';
        default:
          return 'Es gab ein Problem beim Senden. Bitte versucht es erneut.';
      }
    }

    function validate(formData: FormData): string | null {
      const name = valueOf(formData, 'name');
      const company = valueOf(formData, 'company');
      const email = valueOf(formData, 'email');
      const branche = valueOf(formData, 'branche');
      const engpass = valueOf(formData, 'engpass');
      const ziel = valueOf(formData, 'ziel');
      const consent = formData.get('consent');

      if (!name) return 'Bitte tragt euren Namen ein.';
      if (!company) return 'Bitte tragt euer Unternehmen ein.';
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return 'Bitte gebt eine gültige E-Mail-Adresse ein.';
      if (!branche) return 'Bitte wählt eine Branche aus.';
      if (!engpass || engpass.length < 15) return 'Bitte beschreibt den aktuellen Engpass mit mindestens 15 Zeichen.';
      if (!ziel || ziel.length < 20) return 'Bitte beschreibt das gewünschte Ziel mit mindestens 20 Zeichen.';
      if (!consent) return 'Bitte bestätigt die Datenschutzeinwilligung.';
      return null;
    }

    formEl.addEventListener('input', () => {
      if (!formStartedTracked) {
        formStartedTracked = true;
        track('contact_form_started');
      }
    });

    formEl.addEventListener('submit', async (event: SubmitEvent) => {
      event.preventDefault();
      if (submitting) return;

      clearError();
      const formData = new FormData(formEl);
      const validationError = validate(formData);
      if (validationError) {
        setError(validationError);
        return;
      }

      setSubmitting(true);
      track('contact_form_submit_attempted');

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: valueOf(formData, 'name'),
            company: valueOf(formData, 'company'),
            email: valueOf(formData, 'email'),
            branche: valueOf(formData, 'branche'),
            teamgroesse: valueOf(formData, 'teamgroesse'),
            engpass: valueOf(formData, 'engpass'),
            ziel: valueOf(formData, 'ziel'),
            audit: formData.get('audit') ? 'true' : 'false',
            consent: formData.get('consent') ? 'true' : 'false',
            website: valueOf(formData, 'website'),
          }),
        });

        const payload = (await response.json().catch(() => ({}))) as ContactApiResponse;
        if (response.ok && payload.success) {
          formEl.classList.add('hidden');
          successElement.classList.remove('hidden');
          track('contact_form_submitted');
        } else {
          const code = typeof payload.code === 'string' ? payload.code : `HTTP_${response.status}`;
          setError(mapApiError(code));
          track('contact_form_submit_failed', { code });
        }
      } catch (error) {
        setError(`Netzwerkfehler: ${error instanceof Error ? error.message : String(error)}`);
        track('contact_form_submit_failed', { code: 'NETWORK_ERROR' });
      } finally {
        setSubmitting(false);
      }
    });

    const params = new URLSearchParams(window.location.search);
    const workflowParam = params.get('workflow');
    const auditParam = params.get('audit');

    if (workflowParam) {
      const normalized = workflowParam.replace(/-/g, ' ');
      const zielField = document.getElementById('ziel') as HTMLTextAreaElement | null;
      if (zielField) {
        zielField.value = `Wir möchten vor allem diesen Workflow besprechen: ${normalized}.`;
      }
    }

    if (auditParam === '1') {
      const auditField = document.getElementById('audit') as HTMLInputElement | null;
      if (auditField) {
        auditField.checked = true;
      }
    }
  }
</script>
