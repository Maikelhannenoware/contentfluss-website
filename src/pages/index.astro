---
import Layout from '../layouts/Layout.astro';
import {
  handwerkWorkflows,
  immobilienverwaltungWorkflows,
  featuredWorkflowIds,
  type WorkflowDefinition,
} from '../lib/workflows';
import { professionalServiceSchema } from '../lib/seo';

const description =
  'Contentfluss ist AI-Operations-Partner für Handwerk und Immobilienverwaltung. Wir bauen Workflows, die Bürochaos reduzieren, Abläufe beschleunigen und messbar entlasten.';

const workflowMap = new Map(
  [...handwerkWorkflows, ...immobilienverwaltungWorkflows].map((workflow) => [workflow.slug, workflow])
);

const featuredWorkflows = featuredWorkflowIds
  .map((slug) => workflowMap.get(slug))
  .filter((workflow): workflow is WorkflowDefinition => workflow !== undefined)
  .map((workflow) => ({
    ...workflow,
    vertical: handwerkWorkflows.some((entry) => entry.slug === workflow.slug)
      ? 'Handwerk'
      : 'Immobilienverwaltung',
  }));

const proofExamples = [
  {
    before: 'Anfragen kommen per Mail, Telefon und Messenger unsortiert rein.',
    after: 'Der Eingang wird automatisch kategorisiert, priorisiert und als sauberer Task vorbereitet.',
  },
  {
    before: 'Offene Angebote werden manuell nachgehalten und geraten aus dem Blick.',
    after: 'Follow-ups laufen strukturiert nach Zeitplan mit klaren Wiedervorlagen.',
  },
  {
    before: 'Schadenmeldungen sind unvollständig und führen zu langen Rückfragen.',
    after: 'Pflichtinfos werden vorqualifiziert, damit Vorgänge schneller bearbeitet werden können.',
  },
];

const simulatedProofCases = [
  {
    title: 'Handwerk: Anfrageannahme',
    input: 'Bei rund 90 Anfragen pro Monat fehlen in der Ausgangslage oft Pflichtinfos.',
    effect: 'Mit strukturiertem Intake sinkt der Rückfrageaufwand deutlich und Anfragen werden schneller verteilt.',
    corridor: 'Simulierter Zielkorridor: 25-40 % weniger Rückfragen in der Erstbearbeitung.',
  },
  {
    title: 'Handwerk: Angebots-Follow-up',
    input: 'Bei vielen offenen Angeboten gehen Nachfassungen im Tagesgeschäft unter.',
    effect: 'Mit klarer Follow-up-Logik steigen Kontaktquote und Verbindlichkeit in der Nachverfolgung.',
    corridor: 'Simulierter Zielkorridor: 20-35 % höhere Follow-up-Quote.',
  },
  {
    title: 'Immobilienverwaltung: Schaden-Triage',
    input: 'Unvollständige Meldungen erzeugen lange Schleifen mit Mietern und Dienstleistern.',
    effect: 'Vorqualifizierte Eingänge machen die Erstbearbeitung und Priorisierung deutlich robuster.',
    corridor: 'Simulierter Zielkorridor: 30-50 % weniger Nachforderungen je Vorgang.',
  },
];

const structuredData = [professionalServiceSchema('/', description)];
---

<Layout
  title="Contentfluss | AI-Operations für Handwerk & Immobilienverwaltung"
  description={description}
  canonicalPath="/"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">AI-Operations für Handwerk & Immobilienverwaltung</p>
        <h1>Weniger Bürochaos. Schnellere Abläufe. Mehr erledigt.</h1>
        <p class="lead">
          Contentfluss baut AI-gestützte Workflows für Handwerksbetriebe und Immobilienverwaltungen,
          damit Anfragen, Angebote, Meldungen und Kommunikation nicht mehr im Alltag stecken bleiben.
        </p>
        <div class="button-row">
          <a
            href="/kontakt"
            class="btn btn-primary"
            data-track="cta_clicked"
            data-track-label="home_hero_erstgespraech"
          >
            Erstgespräch buchen
          </a>
          <a
            href="/workflows"
            class="btn btn-secondary"
            data-track="cta_clicked"
            data-track-label="home_hero_loesungen"
          >
            Lösungen ansehen
          </a>
        </div>
        <p class="trustline">Pragmatisch. DSGVO-orientiert. Ohne unnötigen Tool-Zirkus.</p>
      </div>

      <aside class="workflow-visual" aria-label="Beispiel eines Workflow-Dashboards" data-reveal>
        <header>
          <strong>Operatives Dashboard</strong>
          <span>Demo-Ansicht</span>
        </header>
        <div class="metric-grid">
          <div class="metric">
            <span>Neue Anfragen</span>
            <strong>18</strong>
          </div>
          <div class="metric">
            <span>Angebote offen</span>
            <strong>7</strong>
          </div>
          <div class="metric">
            <span>Tickets priorisiert</span>
            <strong>24</strong>
          </div>
          <div class="metric">
            <span>Follow-ups heute</span>
            <strong>11</strong>
          </div>
        </div>
        <ul class="metric-list">
          <li>Schadenmeldungen automatisch vorqualifiziert</li>
          <li>Dispo-Updates in Echtzeit ans Team gesendet</li>
          <li>Heute automatisiert erledigt: Demo-Zähler</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section-tight">
    <div class="container value-bar">
      <div class="value-pill" data-reveal>Fokus auf Handwerk & Immobilienverwaltung</div>
      <div class="value-pill" data-reveal>Messbare Entlastung statt KI-Spielerei</div>
      <div class="value-pill" data-reveal>Offene Lösungen ohne unnötigen Vendor Lock-in</div>
      <div class="value-pill" data-reveal>Deutschlandweit, remote oder vor Ort</div>
    </div>
  </section>

  <section class="section">
    <div class="container split two">
      <article class="card card-muted" data-reveal>
        <p class="eyebrow">Wo Prozesse heute hängen bleiben</p>
        <h2>Viele operative Teams verlieren Zeit an Wiederholung</h2>
        <p class="lead">
          Viele Betriebe und Verwaltungen verlieren täglich Zeit in wiederkehrender Kommunikation,
          manuellen Rückfragen und unstrukturierten Abläufen.
        </p>
        <ul class="list">
          <li>Anfragen bleiben liegen</li>
          <li>Angebote werden nicht nachverfolgt</li>
          <li>Schadenmeldungen sind unvollständig</li>
          <li>E-Mails und Telefonate reißen das Team auseinander</li>
          <li>Rückfragen und Abstimmungen kosten zu viel Zeit</li>
        </ul>
      </article>

      <article class="card card-accent" data-reveal>
        <p class="eyebrow">Was Contentfluss daraus macht</p>
        <h2>Struktur statt Kommunikationschaos</h2>
        <p class="lead">Genau dort setzen wir an: in den Engpässen, die jeden Tag wirklich Zeit kosten.</p>
        <ul class="list list-check">
          <li>Strukturierte Eingänge</li>
          <li>Automatische Vorqualifikation</li>
          <li>Intelligentes Nachfassen</li>
          <li>Klare Zuständigkeiten</li>
          <li>Saubere Follow-ups</li>
          <li>Messbare Entlastung im Alltag</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Spezialisiert auf zwei operative Umfelder</p>
        <h2>Klare Branchenfokussierung statt Bauchladen</h2>
      </div>

      <div class="card-grid two">
        <article class="card" data-reveal>
          <h3>Handwerk</h3>
          <p>
            Für Betriebe, die Anfragen schneller bearbeiten, Angebote besser nachverfolgen und
            Büroprozesse sauberer organisieren wollen.
          </p>
          <div class="button-row">
            <a
              href="/handwerk"
              class="btn btn-secondary"
              data-track="vertical_page_clicked"
              data-track-label="home_handwerk"
            >
              Für Handwerksbetriebe
            </a>
          </div>
        </article>

        <article class="card" data-reveal>
          <h3>Immobilienverwaltung</h3>
          <p>
            Für Verwaltungen, die E-Mail-Chaos reduzieren, Schadenmeldungen strukturieren und
            Kommunikation spürbar entlasten wollen.
          </p>
          <div class="button-row">
            <a
              href="/immobilienverwaltung"
              class="btn btn-secondary"
              data-track="vertical_page_clicked"
              data-track-label="home_immobilienverwaltung"
            >
              Für Immobilienverwaltungen
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Beispiele für Workflows mit echtem Hebel</p>
        <h2>Kuratiert für Handwerk und Immobilienverwaltung</h2>
      </div>

      <div class="card-grid three">
        {featuredWorkflows.map((workflow) => (
          <article class="card" data-reveal>
            <span class="chip">{workflow.vertical}</span>
            <h3>{workflow.name}</h3>
            <p>{workflow.short}</p>
            <ul class="list list-check" style="margin-top: 0.9rem;">
              {workflow.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>
            <div class="button-row">
              <a
                href={`/kontakt?workflow=${workflow.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`home_${workflow.slug}`}
              >
                Workflow besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">So läuft ein Projekt mit uns ab</p>
        <h2>Audit. Build. Betrieb.</h2>
      </div>

      <div class="card-grid three">
        <article class="card" data-reveal>
          <span class="kicker-number">1</span>
          <h3 style="margin-top: 0.8rem;">Audit</h3>
          <p>Wir schauen auf euren Prozess, die Engpässe und den größten Hebel.</p>
        </article>
        <article class="card" data-reveal>
          <span class="kicker-number">2</span>
          <h3 style="margin-top: 0.8rem;">Build</h3>
          <p>Wir bauen den Workflow, testen ihn mit euch und bringen ihn produktiv.</p>
        </article>
        <article class="card" data-reveal>
          <span class="kicker-number">3</span>
          <h3 style="margin-top: 0.8rem;">Betrieb</h3>
          <p>Wir betreuen, optimieren und entwickeln weiter – nur wenn sinnvoll.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Warum Unternehmen mit Contentfluss arbeiten</p>
        <h2>Klare Arbeitsweise, belastbare Umsetzung</h2>
      </div>

      <div class="card-grid four">
        <article class="card" data-reveal>
          <h3>Klar statt kompliziert</h3>
          <p>Keine Tool-Show. Nur Lösungen, die im Alltag funktionieren.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Operativ statt theoretisch</h3>
          <p>Wir denken vom Prozess, nicht vom Trend.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Hochwertig statt gebastelt</h3>
          <p>Saubere Umsetzung, strukturierte Übergabe, professionelle Standards.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Partnerschaft statt Projekt-Abwurf</h3>
          <p>Kurze Wege, ehrliche Empfehlungen, langfristig nutzbare Lösungen.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Wie das in der Praxis aussehen kann</p>
        <h2>Beispielhafte Vorher/Nachher-Situationen</h2>
      </div>

      <div class="card-grid three">
        {proofExamples.map((example) => (
          <article class="card" data-reveal>
            <p style="font-weight: 700; margin-bottom: 0.45rem;">Vorher</p>
            <p>{example.before}</p>
            <p style="font-weight: 700; margin-top: 1rem; margin-bottom: 0.45rem;">Nachher</p>
            <p>{example.after}</p>
          </article>
        ))}
      </div>

      <div class="button-row" data-reveal>
        <a
          href="/fallbeispiele"
          class="btn btn-secondary"
          data-track="cta_clicked"
          data-track-label="home_fallbeispiele"
        >
          Mehr erfahren
        </a>
      </div>
      <p style="margin-top: 0.7rem; color: var(--color-muted);" data-reveal>
        Hinweis: Ohne veröffentlichte Kundenreferenzen arbeiten wir mit transparent gekennzeichneten Beispiel-Setups.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Proof ohne Fake-Referenzen</p>
        <h2>Simulierte Wirkungskorridore zur Einordnung</h2>
        <p>Diese Werte sind Beispielrechnungen auf Basis typischer Prozessvolumina, keine Leistungszusage.</p>
      </div>

      <div class="card-grid three">
        {simulatedProofCases.map((item) => (
          <article class="card card-muted" data-reveal>
            <span class="chip">Simulation</span>
            <h3>{item.title}</h3>
            <p style="margin-top: 0.6rem;"><strong>Ausgangslage:</strong> {item.input}</p>
            <p style="margin-top: 0.5rem;"><strong>Wirkungslogik:</strong> {item.effect}</p>
            <p style="margin-top: 0.5rem;"><strong>Orientierung:</strong> {item.corridor}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container surface" style="padding: clamp(1.5rem, 4vw, 2.3rem);" data-reveal>
      <p class="eyebrow">Nächster Schritt</p>
      <h2>Lasst uns prüfen, welcher Workflow bei euch den größten Hebel hat</h2>
      <p class="lead">
        In einem kurzen Erstgespräch schauen wir auf euren Prozess und sagen euch offen, ob sich
        eine Umsetzung wirtschaftlich lohnt.
      </p>
      <div class="button-row">
        <a
          href="/kontakt"
          class="btn btn-primary"
          data-track="cta_clicked"
          data-track-label="home_final_erstgespraech"
        >
          Erstgespräch buchen
        </a>
      </div>
    </div>
  </section>
</Layout>
