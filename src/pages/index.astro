---
import Layout from '../layouts/Layout.astro';
import { pageMeta, faqSchema, organizationSchema, websiteSchema } from '../lib/seo';
import { handwerkWorkflows, immobilienverwaltungWorkflows } from '../lib/workflows';

const meta = pageMeta.home;
const featuredWorkflows = [
  handwerkWorkflows[0],
  handwerkWorkflows[1],
  immobilienverwaltungWorkflows[0],
];
const faqs = [
  { q: 'Ist das ein Softwarewechsel?', a: 'Nein. Wir setzen auf bestehende Abläufe und Systeme auf. Kein neues Tool als Voraussetzung.' },
  { q: 'Passt das auch für kleinere Betriebe?', a: 'Ja. Die meisten Workflows sind für Betriebe mit 3–30 Mitarbeitern gemacht, dort entsteht der größte Nutzen pro Stunde.' },
  { q: 'Wo setzt KI hier konkret an?', a: 'Anfragen einordnen, Informationen nachziehen, Standardantworten versenden, Status kommunizieren, Übergaben dokumentieren.' },
  { q: 'Was passiert im Fit-Call?', a: 'Kein Pitch. Wir schauen gemeinsam, wo bei euch Engpässe entstehen, und ob ein Workflow das lösen kann.' },
  { q: 'Wie lange dauert die Umsetzung?', a: 'Die meisten Workflows gehen in 3–5 Wochen live. Das hängt vom Umfang und den nötigen Integrationen ab.' },
];
const schemas = [organizationSchema(), websiteSchema(), faqSchema(faqs.map(f => ({ question: f.q, answer: f.a })))];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="container hero-shell">
      <div class="hero-split">
        <div class="stack gap-8 hero-copy">
          <span class="eyebrow hero-badge">
            <span class="eyebrow-dot"></span>
            KI-Workflows für Handwerk &amp; Hausverwaltung
          </span>
          <div class="stack gap-4">
            <h1>
              Weniger operative <span class="serif-accent">Reibung.</span>
              <span class="headline-break">Mehr Flow im Tagesgeschäft.</span>
            </h1>
            <p class="page-intro">Contentfluss automatisiert Anfragen, Meldungen, Angebote und Kommunikation — auf euren bestehenden Abläufen, ohne Systemwechsel.</p>
          </div>
          <div class="cta-group">
            <a href="/kontakt" class="btn btn-primary btn-lg" data-track="home_hero_cta">Fit-Call buchen</a>
            <a href="/workflows" class="cta-link" data-track="home_hero_workflows">Workflows ansehen →</a>
          </div>
          <ul class="trust-row" aria-label="Wichtige Eckpunkte">
            <li class="trust-pill">Pilot in 3–5 Wochen</li>
            <li class="trust-pill">Kein Systemwechsel</li>
            <li class="trust-pill">DSGVO-orientiert</li>
            <li class="trust-pill">3–30 Mitarbeitende</li>
          </ul>
        </div>

        <div class="operations-canvas-parallax">
          <div class="operations-canvas-wrap">
            <div class="operations-canvas" aria-hidden="true">
              <div class="canvas-bar">
                <span class="canvas-bar-dots">
                  <span class="canvas-bar-dot"></span>
                  <span class="canvas-bar-dot"></span>
                  <span class="canvas-bar-dot"></span>
                </span>
                <span class="canvas-bar-title">Operations Canvas</span>
                <span class="canvas-bar-status">
                  <span class="status-dot status-dot-live"></span>
                  aktiv
                </span>
              </div>
              <div class="canvas-body">
                <div class="canvas-grid">
                  <article class="canvas-node canvas-node-start">
                    <span class="canvas-node-title">Anfrage</span>
                    <span class="canvas-badge canvas-badge-live">neu</span>
                  </article>
                  <div class="canvas-connector canvas-connector-horizontal"></div>
                  <article class="canvas-node canvas-node-active">
                    <span class="canvas-node-title">Qualifi-<br />zierung</span>
                    <span class="canvas-badge canvas-badge-live">läuft</span>
                  </article>
                  <div class="canvas-connector canvas-connector-vertical"></div>
                  <article class="canvas-node canvas-node-done">
                    <span class="canvas-node-title">Routing</span>
                    <span class="canvas-badge canvas-badge-done">done</span>
                  </article>
                </div>
              </div>
              <div class="canvas-stats">
                <div class="canvas-stat">
                  <span class="canvas-stat-value">-18 Min / Tag</span>
                  <span class="canvas-stat-label">weniger Koordination</span>
                </div>
                <div class="canvas-stat">
                  <span class="canvas-stat-value">12 verarbeitet</span>
                  <span class="canvas-stat-label">heute im Ablauf</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. TARGET GROUPS -->
  <section class="section has-glow glow-br">
    <div class="container">
      <div class="section-head-center" data-reveal>
        <span class="section-label">Für wen</span>
        <h2><span class="serif-accent">Spezialisiert</span> auf zwei Branchen</h2>
        <p>Nicht generisch. Zwei Problemräume, zwei Lösungsansätze.</p>
      </div>
      <div class="target-panels" data-stagger>
        <div class="target-panel">
          <span class="panel-eyebrow"><span class="dot dot-blue"></span>Handwerk</span>
          <p class="target-panel-title">Handwerksbetriebe</p>
          <div class="target-panel-pains">
            <ul class="pain-list">
              <li>Anfragen kommen ohne alle Infos rein</li>
              <li>Angebote werden nicht nachverfolgt</li>
              <li>Rückfragen zerhacken den Arbeitstag</li>
            </ul>
          </div>
          <a href="/handwerk" class="btn btn-secondary btn-sm" data-track="home_target_handwerk">Mehr für Handwerk →</a>
        </div>
        <div class="target-panel">
          <span class="panel-eyebrow"><span class="dot dot-violet"></span>Hausverwaltung</span>
          <p class="target-panel-title">Immobilienverwaltungen</p>
          <div class="target-panel-pains">
            <ul class="pain-list">
              <li>Schadenmeldungen kommen unstrukturiert über mehrere Kanäle</li>
              <li>Informationen müssen ständig nachgezogen werden</li>
              <li>Prozesse hängen an einzelnen Personen</li>
            </ul>
          </div>
          <a href="/immobilienverwaltung" class="btn btn-secondary btn-sm" data-track="home_target_immo">Mehr für Hausverwaltung →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. PROBLEM FRAMING -->
  <section class="section section-alt">
    <div class="container">
      <div class="content-aside" data-reveal>
        <div class="stack gap-6">
          <div>
            <span class="section-label">Das Problem</span>
            <h2>Operative Arbeit, die ständig hängen bleibt</h2>
            <p class="mt-4">Anfragen gehen ein, unvollständig. Angebote werden nicht nachverfolgt. Schadenmeldungen landen auf drei verschiedenen Kanälen. Das ist kein Software-Problem. Es ist ein Ablauf-Problem.</p>
            <p class="mt-4">KI-Workflows lösen genau das, nicht als IT-Großprojekt, sondern als konkreter Ablauf, der morgen läuft.</p>
          </div>
        </div>
        <div class="card card-elevated pain-card-elevated">
          <p class="section-label">Typische Engpässe</p>
          <ul class="pain-list">
            <li>Anfragen kommen unvollständig oder über viele Kanäle rein</li>
            <li>Angebote werden nie sauber nachverfolgt</li>
            <li>Rückfragen zu offenen Terminen landen beim falschen Ansprechpartner</li>
            <li>Schadenmeldungen sind manuell koordiniert, langsam und fehleranfällig</li>
            <li>Prozesse hängen an einzelnen Personen, nicht an Abläufen</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. FEATURED WORKFLOWS -->
  <section class="section has-glow glow-tl" style="--glow-color: rgba(100, 60, 200, 0.05);">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="section-label">Was konkret automatisiert wird</span>
        <h2>Operative Abläufe, nicht Feature-Listen</h2>
        <p>Jeder Workflow löst ein reales Problem, keine abstrakten KI-Anwendungen.</p>
      </div>
      <div class="grid-3 featured-workflows" data-stagger>
        {featuredWorkflows.map((wf, i) => (
          <div class="workflow-card">
            <div class="workflow-card-meta">
              <h3 class="workflow-card-title">{wf.name}</h3>
              <span class="mono-tag">{i < 2 ? 'HW' : 'IM'}</span>
            </div>
            <div>
              <p class="workflow-col-label">Problem</p>
              <p class="workflow-problem-block">{wf.problem}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was dadurch besser läuft</p>
              <ul class="workflow-benefits">
                {wf.benefits.map(b => <li>{b}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/workflows" class="btn btn-secondary" data-track="home_workflows_all">Alle Workflows ansehen</a>
      </div>
    </div>
  </section>

  <!-- 5. HOW IT WORKS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="section-label">Ablauf</span>
        <h2>Wie die Zusammenarbeit funktioniert</h2>
      </div>
      <div class="process-flow" data-stagger>
        {[
          { n: '01', title: 'Engpass verstehen', body: 'Im Fit-Call sprechen wir über eure Abläufe. Wo verliert ihr täglich Zeit? Was geht verloren?' },
          { n: '02', title: 'Workflow bauen', body: 'Wir entwickeln und implementieren den Ablauf, auf eure Systeme und Sprache abgestimmt.' },
          { n: '03', title: 'Im Alltag einsetzen', body: 'Der Workflow geht live. Wir begleiten den Start und schärfen nach, was im Betrieb nicht stimmt.' },
        ].map(s => (
          <div class="process-step">
            <span class="process-step-num">{s.n}</span>
            <p class="process-step-title">{s.title}</p>
            <p class="process-step-body">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. FAQ -->
  <section class="section">
    <div class="container content-narrow">
      <div class="section-head">
        <span class="section-label">FAQ</span>
        <h2>Häufige Fragen</h2>
      </div>
      <ul class="faq-list">
        {faqs.map(faq => (
          <li class="faq-item">
            <details>
              <summary>{faq.q}</summary>
              <p class="faq-answer">{faq.a}</p>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 7. FINAL CTA -->
  <section class="section-feature has-glow glow-center" style="--glow-color: rgba(21, 88, 255, 0.10);">
    <div class="container">
      <div class="conviction-block" data-reveal>
        <span class="eyebrow">Fit-Call: kostenlos, 30 Minuten</span>
        <h2>Welcher Ablauf kostet euch täglich die meiste <span class="serif-accent">Zeit?</span></h2>
        <p class="page-intro">Im Fit-Call klären wir, ob ein Workflow das lösen kann. Kein Pitch, keine Verpflichtung.</p>
        <div class="cta-group" style="justify-content:center;margin-top:2rem">
          <a href="/kontakt" class="btn btn-primary btn-lg" data-track="home_final_cta">Fit-Call buchen</a>
          <a href="/workflows" class="cta-link" data-track="home_final_workflows">Workflows ansehen →</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
