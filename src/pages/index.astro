---
import Layout from '../layouts/Layout.astro';
import { pageMeta, faqSchema, organizationSchema, websiteSchema } from '../lib/seo';
import { handwerkWorkflows, immobilienverwaltungWorkflows } from '../lib/workflows';

const meta = pageMeta.home;
const featuredWorkflows = [
  handwerkWorkflows[0],
  handwerkWorkflows[1],
  immobilienverwaltungWorkflows[0],
  immobilienverwaltungWorkflows[1],
];
const faqs = [
  { q: 'Ist das ein Softwarewechsel?', a: 'Nein. Wir setzen auf bestehende Abläufe und Systeme auf. Kein neues Tool als Voraussetzung.' },
  { q: 'Passt das auch für kleinere Betriebe?', a: 'Ja. Die meisten Workflows sind für Betriebe mit 3–30 Mitarbeitern gemacht — dort entsteht der größte Nutzen pro Stunde.' },
  { q: 'Wo setzt KI hier konkret an?', a: 'Anfragen einordnen, Informationen nachziehen, Standardantworten versenden, Status kommunizieren, Übergaben dokumentieren.' },
  { q: 'Was passiert im Fit-Call?', a: 'Kein Pitch. Wir schauen gemeinsam, wo bei euch Engpässe entstehen — und ob ein Workflow das lösen kann.' },
  { q: 'Wie lange dauert die Umsetzung?', a: 'Die meisten Workflows gehen in 3–5 Wochen live. Das hängt vom Umfang und den nötigen Integrationen ab.' },
];
const schemas = [organizationSchema(), websiteSchema(), faqSchema(faqs.map(f => ({ question: f.q, answer: f.a })))];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-split">
        <div class="stack gap-6">
          <span class="eyebrow">KI-Workflows für KMU</span>
          <h1>KI-Workflows für Betriebe, die im Alltag wirklich Arbeit abnehmen.</h1>
          <p class="page-intro mt-4">Contentfluss baut KI-Workflows für Handwerksbetriebe und Hausverwaltungen — auf bestehende Abläufe aufgesetzt, ohne IT-Großprojekt.</p>
          <div class="cta-group mt-6">
            <a href="/kontakt" class="btn btn-primary btn-lg" data-track="home_hero_cta">Fit-Call buchen</a>
            <a href="/workflows" class="btn btn-ghost" data-track="home_hero_workflows">Workflows ansehen →</a>
          </div>
        </div>

        <div class="ops-flow" aria-hidden="true">
          <p class="ops-flow-title">Eingehende Anfrage — Live</p>
          <div class="ops-flow-nodes">
            <div class="ops-node">
              <span class="ops-node-dot success"></span>
              <span class="ops-node-label">Anfrage eingegangen</span>
              <span class="ops-badge ops-badge-green" style="margin-left:auto">empfangen</span>
            </div>
            <div class="ops-connector"><div class="ops-connector-line active"></div></div>
            <div class="ops-node">
              <span class="ops-node-dot active"></span>
              <span class="ops-node-label active">Vollständigkeit prüfen</span>
              <span class="ops-badge ops-badge-blue" style="margin-left:auto">läuft</span>
            </div>
            <div class="ops-connector"><div class="ops-connector-line active"></div></div>
            <div class="ops-node">
              <span class="ops-node-dot pending"></span>
              <span class="ops-node-label muted">Zuweisen &amp; weiterleiten</span>
              <span class="ops-badge ops-badge-muted" style="margin-left:auto">wartet</span>
            </div>
            <div class="ops-connector"><div class="ops-connector-line"></div></div>
            <div class="ops-node">
              <span class="ops-node-dot pending"></span>
              <span class="ops-node-label muted">Eingangsbestätigung senden</span>
              <span class="ops-badge ops-badge-muted" style="margin-left:auto">wartet</span>
            </div>
            <div class="ops-connector"><div class="ops-connector-line"></div></div>
            <div class="ops-node">
              <span class="ops-node-dot pending"></span>
              <span class="ops-node-label muted">Übergabe ins CRM</span>
              <span class="ops-badge ops-badge-muted" style="margin-left:auto">—</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. TRUST STRIP -->
  <div class="trust-strip">
    <div class="container">
      <ul class="trust-strip-list">
        <li class="trust-item">Für Handwerk &amp; Hausverwaltung</li>
        <li class="trust-item">Auf bestehende Abläufe aufgesetzt</li>
        <li class="trust-item">Keine generische KI-Beratung</li>
        <li class="trust-item">Umsetzung, nicht Konzept</li>
      </ul>
    </div>
  </div>

  <!-- 3. AUDIENCE SPLIT -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Für wen</span>
        <h2>Spezialisiert auf zwei Branchen</h2>
      </div>
      <div class="grid-2" data-stagger>
        <div class="card card-elevated">
          <div class="card-header">
            <span class="eyebrow">Handwerk</span>
            <h3 style="margin-top:1rem">Handwerksbetriebe</h3>
          </div>
          <div class="card-body">
            <ul class="pain-list">
              <li>Anfragen kommen unvollständig oder über viele Kanäle rein</li>
              <li>Angebote werden nicht sauber nachverfolgt</li>
              <li>Rückfragen zerhacken den Arbeitstag</li>
            </ul>
          </div>
          <div class="card-footer">
            <a href="/handwerk" class="btn btn-secondary btn-sm" data-track="home_audience_handwerk">Mehr für Handwerk →</a>
          </div>
        </div>
        <div class="card card-elevated">
          <div class="card-header">
            <span class="eyebrow">Hausverwaltung</span>
            <h3 style="margin-top:1rem">Immobilienverwaltungen</h3>
          </div>
          <div class="card-body">
            <ul class="pain-list">
              <li>Schadenmeldungen kommen unstrukturiert über mehrere Kanäle</li>
              <li>Informationen müssen ständig nachgezogen werden</li>
              <li>Prozesse hängen an einzelnen Personen</li>
            </ul>
          </div>
          <div class="card-footer">
            <a href="/immobilienverwaltung" class="btn btn-secondary btn-sm" data-track="home_audience_immo">Mehr für Hausverwaltung →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. WORKFLOW EXAMPLES -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Was konkret automatisiert wird</span>
        <h2>Operative Abläufe, nicht Feature-Listen</h2>
        <p>Jeder Workflow löst ein reales Problem — keine abstrakten KI-Anwendungen.</p>
      </div>
      <div class="grid-2" data-stagger>
        {featuredWorkflows.map((wf, i) => (
          <div class="workflow-card">
            <div class="workflow-card-meta">
              <h3 class="workflow-card-title">{wf.name}</h3>
              <span class="mono-tag">{i < 2 ? 'HW' : 'IM'}</span>
            </div>
            <div>
              <p class="workflow-col-label">Problem</p>
              <p class="workflow-problem-block">{wf.problem}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was dadurch besser läuft</p>
              <ul class="workflow-benefits">
                {wf.benefits.map(b => <li>{b}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top:2rem;text-align:center">
        <a href="/workflows" class="btn btn-secondary" data-track="home_workflows_all">Alle Workflows ansehen</a>
      </div>
    </div>
  </section>

  <!-- 5. WHY CONTENTFLUSS -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Warum Contentfluss</span>
        <h2>Umsetzung statt Beratung</h2>
      </div>
      <div class="grid-4" data-stagger>
        {[
          { title: 'Keine Theoriefolien', body: 'Was wir liefern, läuft. Kein Konzept-Deliverable, keine Empfehlungsliste zum Selbstumsetzen.' },
          { title: 'Kein Systemwechsel', body: 'Auf bestehende Tools und Abläufe aufgesetzt. Kein IT-Großprojekt als Voraussetzung.' },
          { title: 'Branchenfokus', body: 'Spezialisiert auf Handwerk und Hausverwaltung — nicht auf alles für alle.' },
          { title: 'Klare Abläufe', body: 'Kurze Analyse, schnelle Umsetzung, Nachschärfen im Betrieb.' },
        ].map(item => (
          <div class="card">
            <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.5rem">{item.title}</h3>
            <p style="font-size:0.875rem;max-width:none">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. PROCESS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Ablauf</span>
        <h2>Wie die Zusammenarbeit funktioniert</h2>
      </div>
      <div class="grid-3" data-stagger>
        {[
          { n: '01', title: 'Engpass verstehen', body: 'Im Fit-Call sprechen wir über eure Abläufe. Wo verliert ihr täglich Zeit? Was geht verloren?' },
          { n: '02', title: 'Workflow bauen', body: 'Wir entwickeln und implementieren den Ablauf — auf eure Systeme und Sprache abgestimmt.' },
          { n: '03', title: 'Im Alltag einsetzen', body: 'Der Workflow geht live. Wir begleiten den Start und schärfen nach, was im Betrieb nicht stimmt.' },
        ].map(s => (
          <div class="process-step">
            <span class="process-step-num">{s.n}</span>
            <p class="process-step-title">{s.title}</p>
            <p class="process-step-body">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. FAQ -->
  <section class="section">
    <div class="container content-narrow">
      <div class="section-head">
        <span class="section-label">FAQ</span>
        <h2>Häufige Fragen</h2>
      </div>
      <ul class="faq-list">
        {faqs.map(faq => (
          <li class="faq-item">
            <details>
              <summary>{faq.q}</summary>
              <p class="faq-answer">{faq.a}</p>
            </details>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 8. FINAL CTA -->
  <section class="section section-alt">
    <div class="container content-center">
      <h2>Sagt uns, was manuell laufen bleibt. Wir sagen euch, ob ein Workflow das löst.</h2>
      <p style="margin-top:1rem;margin-bottom:2rem;margin-inline:auto">Kostenloser Fit-Call, ca. 30 Minuten. Kein Pitch, keine Verpflichtung.</p>
      <a href="/kontakt" class="btn btn-primary btn-lg" data-track="home_final_cta">Fit-Call buchen</a>
    </div>
  </section>

</Layout>
