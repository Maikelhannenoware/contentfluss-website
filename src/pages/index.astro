---
import Layout from '../layouts/Layout.astro';
import { pageMeta, organizationSchema, websiteSchema } from '../lib/seo';
import {
  handwerkWorkflows,
  immobilienverwaltungWorkflows,
  type WorkflowDefinition,
} from '../lib/workflows';

const meta = pageMeta.home;
const workflowIndex = new Map<string, WorkflowDefinition>(
  [...handwerkWorkflows, ...immobilienverwaltungWorkflows].map((workflow) => [workflow.slug, workflow])
);
const getWorkflow = (slug: string) => workflowIndex.get(slug)!;

const featuredWorkflow = getWorkflow('anfrageannahme-vorqualifikation');
const supportingWorkflows = [
  getWorkflow('angebots-follow-up-conversion'),
  getWorkflow('schadenmeldung-vorqualifikation'),
];

const trustPills = [
  'Pilot in 3–5 Wochen',
  'Kein Systemwechsel',
  'DSGVO-orientiert',
  'Für Teams mit 3–30 Mitarbeitenden',
];

const inboundFragments = [
  { channel: 'Telefon', text: 'Anfrage ohne Adresse' },
  { channel: 'WhatsApp', text: 'Foto ohne Kontext' },
  { channel: 'E-Mail', text: 'Mail ohne Rückrufnummer' },
  { channel: 'Schaden', text: 'Meldung ohne Ticket' },
];

const structuredOutputs = [
  { label: 'Vollständige Anfrage', detail: 'Adresse, Fotos und Rückrufnummer ergänzt' },
  { label: 'Zuständigkeit erkannt', detail: 'passende Rolle oder Team direkt zugeordnet' },
  { label: 'Follow-up gesetzt', detail: 'Status und nächste Aktion klar' },
  { label: 'Bearbeitung vorbereitet', detail: 'Rückruf, Routing oder Ticket vorbereitet' },
];

const handwerkPoints = [
  'Anfragen ohne Adresse, Foto oder klaren Umfang',
  'Follow-up ohne festen Takt',
  'Statusfragen direkt ins Büro statt in den Ablauf',
];

const handwerkTags = ['Frontoffice', 'Angebot', 'Terminstatus'];

const immoRows = [
  { label: 'Schadenmeldung', detail: 'Einheit, Fotos und Dringlichkeit ergänzt' },
  { label: 'Zuständigkeit', detail: 'Sachbearbeitung oder Dienstleister direkt erkannt' },
  { label: 'Status', detail: 'Rückfrage und Update bleiben im dokumentierten Ablauf' },
];

const processSteps = [
  {
    number: '01',
    title: 'Engpass verstehen',
    body: 'Wir schauen auf den konkreten Vorgang und trennen echten Ablaufdruck von allgemeinem Tool-Lärm.',
  },
  {
    number: '02',
    title: 'Workflow bauen',
    body: 'Der Ablauf wird auf eure Sprache, Rollen und vorhandenen Systeme zugeschnitten statt darübergestülpt.',
  },
  {
    number: '03',
    title: 'Im Alltag einsetzen',
    body: 'Der Workflow läuft im Betrieb, wird nachgeschärft und muss dort tragen, wo heute Reibung entsteht.',
  },
];

const finalProofs = [
  'Pilot in 3–5 Wochen',
  'Für Teams mit 3–30 Mitarbeitenden',
  'Ohne Systemwechsel in bestehende Abläufe',
];

const schemas = [organizationSchema(), websiteSchema()];
---

<Layout title={meta.title} description={meta.description} schemas={schemas}>
  <section class="home-hero">
    <div class="home-hero-glow home-hero-glow-a" aria-hidden="true"></div>
    <div class="home-hero-glow home-hero-glow-b" aria-hidden="true"></div>
    <div class="home-hero-blob home-hero-blob-a" aria-hidden="true"></div>
    <div class="home-hero-blob home-hero-blob-b" aria-hidden="true"></div>

    <div class="container home-hero-content">
      <span class="eyebrow home-hero-eyebrow">
        <span class="eyebrow-dot"></span>
        KI-Workflows für Handwerk &amp; Hausverwaltung
      </span>

      <h1 class="home-hero-headline">
        <span class="home-hero-line">
          Weniger operative <span class="serif-accent">Reibung.</span>
        </span>
        <span class="home-hero-line">Mehr Flow im Tagesgeschäft.</span>
      </h1>

      <p class="page-intro home-hero-sub">
        Contentfluss automatisiert Anfragen, Meldungen und Angebote
        — auf euren bestehenden Abläufen, ohne Systemwechsel.
      </p>

      <div class="home-hero-actions">
        <a href="/kontakt" class="btn btn-primary btn-lg" data-track="home_hero_cta">
          Fit-Call buchen
        </a>
        <a href="/workflows" class="btn btn-ghost" data-track="home_hero_workflows">
          Workflows ansehen
        </a>
      </div>

      <ul class="home-hero-trust" aria-label="Eckpunkte">
        {trustPills.map((pill) => <li>{pill}</li>)}
      </ul>

      <div class="home-hero-scroll" aria-hidden="true">
        <span class="home-hero-scroll-line"></span>
        Scroll
      </div>
    </div>
  </section>

  <section class="section home-signature">
    <div class="container home-shell">
      <div class="home-section-head home-section-head-center" data-reveal>
        <span class="section-label">Signature Transformation</span>
        <h2>Vom täglichen Durcheinander zum klaren Ablauf</h2>
        <p>
          Was heute per Telefon, Mail, WhatsApp und Rückfragen auseinanderläuft,
          wird in einen sauberen operativen Flow überführt.
        </p>
      </div>

      <div class="home-signature-stage" data-stagger>
        <div class="home-before">
          <div class="home-stage-head">
            <span class="home-stage-label">Before</span>
            <h3>Fragmente statt Vorgang</h3>
          </div>
          <div class="home-fragment-stack">
            {inboundFragments.map((fragment, index) => (
              <article class:list={['home-fragment', index === 1 && 'home-fragment-glass', index === 3 && 'home-fragment-glass']}>
                <span class="home-fragment-channel">{fragment.channel}</span>
                <p>{fragment.text}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="home-spine">
          <span class="home-spine-label">Contentfluss Workflow</span>
          <span class="home-spine-line"></span>
          <p>ordnet Eingang und Routing, bevor operative Zeit verloren geht.</p>
        </div>

        <div class="home-after">
          <div class="home-stage-head">
            <span class="home-stage-label">After</span>
            <h3>Strukturierter operativer Flow</h3>
          </div>
          <div class="home-after-board">
            {structuredOutputs.map((item) => (
              <div class="home-after-row">
                <span>{item.label}</span>
                <strong>{item.detail}</strong>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-industries">
    <div class="container home-shell">
      <div class="home-section-head home-section-head-center" data-reveal>
        <span class="section-label">Zwei Branchen, ein Prinzip</span>
        <h2>Gleiche <span class="serif-accent">Präzision.</span> Unterschiedlicher operativer Rhythmus.</h2>
      </div>

      <div class="home-industry-grid" data-stagger>
        <article class="home-industry-card home-industry-card-handwerk">
          <div class="home-industry-top">
            <span class="home-industry-chip">Handwerk</span>
            <span class="home-industry-kicker">Viele Eingänge, wenig Puffer</span>
          </div>
          <h3>Frontoffice, Angebot und Dispo gleichzeitig unter Druck.</h3>
          <ul class="home-industry-list">
            {handwerkPoints.map((point) => <li>{point}</li>)}
          </ul>
          <div class="home-industry-tags">
            {handwerkTags.map((tag) => <span>{tag}</span>)}
          </div>
          <a href="/handwerk" class="btn btn-secondary" data-track="home_industry_handwerk">Mehr für Handwerk</a>
        </article>

        <article class="home-industry-card home-industry-card-immo">
          <div class="home-industry-top">
            <span class="home-industry-chip">Hausverwaltung</span>
            <span class="home-industry-kicker">Koordination statt Kanalchaos</span>
          </div>
          <h3>Meldung, Rückfrage und Dienstleister-Status in einer Spur.</h3>
          <div class="home-industry-board">
            {immoRows.map((row) => (
              <div class="home-industry-board-row">
                <span>{row.label}</span>
                <strong>{row.detail}</strong>
              </div>
            ))}
          </div>
          <a href="/immobilienverwaltung" class="btn btn-secondary" data-track="home_industry_immo">
            Mehr für Hausverwaltung
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="section home-workflows">
    <div class="container home-shell">
      <div class="home-section-head home-section-head-center" data-reveal>
        <span class="section-label">Kuratiert statt katalogisiert</span>
        <h2>Drei Workflows, die im Alltag wirklich etwas verändern</h2>
      </div>

      <div class="home-workflow-stage" data-stagger>
        <article class="home-workflow-feature">
          <div class="home-workflow-feature-top">
            <span class="home-workflow-chip">Featured Workflow</span>
            <span class="mono-tag">Handwerk</span>
          </div>
          <div class="home-workflow-feature-copy">
            <h3>{featuredWorkflow.name}</h3>
            <p class="home-workflow-lead">{featuredWorkflow.short}</p>
          </div>
          <div class="home-workflow-feature-detail">
            <p class="home-workflow-problem-inline">{featuredWorkflow.problem}</p>
            <ul class="workflow-benefits">
              {featuredWorkflow.benefits.map((benefit) => <li>{benefit}</li>)}
            </ul>
            <p class="home-workflow-effect">{featuredWorkflow.effect}</p>
          </div>
        </article>

        <div class="home-workflow-support" data-stagger>
          {supportingWorkflows.map((workflow, index) => (
            <article class={`home-workflow-card home-workflow-card-${index + 1}`}>
              <div class="home-workflow-card-head">
                <h3>{workflow.name}</h3>
                <span class="mono-tag">{index === 0 ? 'Handwerk' : 'Immo'}</span>
              </div>
              <p class="home-workflow-lead">{workflow.short}</p>
              <ul class="workflow-benefits">
                {workflow.benefits.slice(0, 2).map((benefit) => <li>{benefit}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>

      <div class="home-workflow-cta">
        <a href="/workflows" class="btn btn-secondary" data-track="home_workflows_all">Alle Workflows ansehen</a>
      </div>
    </div>
  </section>

  <section class="section-sm home-process">
    <div class="container home-shell">
      <div class="home-section-head home-section-head-center" data-reveal>
        <span class="section-label">Zusammenarbeit</span>
        <h2>So läuft die Zusammenarbeit ab</h2>
      </div>

      <div class="home-process-rail" data-stagger>
        {processSteps.map((step) => (
          <article class="home-process-step">
            <span class="home-process-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section home-final">
    <div class="container home-shell home-final-shell">
      <div class="home-final-card" data-reveal>
        <span class="section-label">Fit-Call</span>
        <h2>Wenn täglich zu viel <span class="serif-accent">hängen bleibt,</span> ist es Zeit für einen besseren Ablauf.</h2>
        <p class="page-intro">
          Im Fit-Call schauen wir auf euren Engpass und prüfen, ob ein Workflow in eurem Alltag
          wirklich Sinn ergibt.
        </p>
        <ul class="home-final-proof" aria-label="Proof">
          {finalProofs.map((item) => <li>{item}</li>)}
        </ul>
        <a href="/kontakt" class="btn btn-primary btn-lg" data-track="home_final_cta">
          Fit-Call buchen
        </a>
      </div>
    </div>
  </section>
</Layout>
