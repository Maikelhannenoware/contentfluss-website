---
import Layout from '../layouts/Layout.astro';
import {
  handwerkWorkflows,
  immobilienverwaltungWorkflows,
  featuredWorkflowIds,
  type WorkflowDefinition,
} from '../lib/workflows';
import { professionalServiceSchema, faqSchema, type FaqItem } from '../lib/seo';

const description =
  'Contentfluss automatisiert Büroprozesse für Handwerksbetriebe und Immobilienverwaltungen. Weniger Rückfragen, schnellere Vorgänge, klare Abläufe. Erstgespräch kostenlos.';

const workflowMap = new Map(
  [...handwerkWorkflows, ...immobilienverwaltungWorkflows].map((workflow) => [workflow.slug, workflow])
);

const featuredWorkflows = featuredWorkflowIds
  .map((slug) => workflowMap.get(slug))
  .filter((workflow): workflow is WorkflowDefinition => workflow !== undefined)
  .map((workflow) => ({
    ...workflow,
    vertical: handwerkWorkflows.some((entry) => entry.slug === workflow.slug)
      ? 'Handwerk'
      : 'Immobilienverwaltung',
  }));

const proofExamples = [
  {
    before: 'Anfragen kommen per Mail, Telefon und Messenger unsortiert rein.',
    after: 'Der Eingang wird automatisch kategorisiert, priorisiert und als sauberer Task vorbereitet.',
  },
  {
    before: 'Offene Angebote werden manuell nachgehalten und geraten aus dem Blick.',
    after: 'Follow-ups laufen strukturiert nach Zeitplan mit klaren Wiedervorlagen.',
  },
  {
    before: 'Schadenmeldungen sind unvollständig und führen zu langen Rückfragen.',
    after: 'Pflichtinfos werden vorqualifiziert, damit Vorgänge schneller bearbeitet werden können.',
  },
];

const simulatedProofCases = [
  {
    value: '25–40 %',
    label: 'weniger Rückfragen',
    title: 'Handwerk: Anfrageannahme',
    note: 'Simulierter Zielkorridor bei ~90 Anfragen/Monat',
  },
  {
    value: '20–35 %',
    label: 'höhere Follow-up-Quote',
    title: 'Handwerk: Angebots-Follow-up',
    note: 'Simulierter Zielkorridor mit strukturierten Sequenzen',
  },
  {
    value: '30–50 %',
    label: 'weniger Nachforderungen',
    title: 'Immobilienverwaltung: Schadens-Triage',
    note: 'Simulierter Zielkorridor je Schadenfall',
  },
];

const faqItems: FaqItem[] = [
  {
    question: 'Was kostet ein Erstgespräch?',
    answer: 'Das Erstgespräch ist kostenlos und unverbindlich. Wir klären darin, ob und welcher Workflow bei euch den größten Hebel hat. Erst danach entscheiden wir gemeinsam, ob ein bezahlter Audit sinnvoll ist.',
  },
  {
    question: 'Wie hoch ist das Risiko für uns?',
    answer: 'Der Einstieg über den Workflow-Audit (590 €) ist bewusst so gebaut, dass ihr eine klare Entscheidungsgrundlage habt, bevor eine teurere Umsetzung beginnt. Es gibt keine Mindestvertragslaufzeit für den Audit.',
  },
  {
    question: 'Müssen wir bestehende Software ersetzen?',
    answer: 'Nein. Contentfluss arbeitet als AI-Layer über eurem bestehenden Setup. Wir binden an, was ihr bereits nutzt – kein System-Wechsel, kein Parallelbetrieb zweier Welten.',
  },
  {
    question: 'Ist das auch etwas für kleinere Betriebe?',
    answer: 'Ja. Unsere Klientel sind Betriebe mit 3 bis 30 Mitarbeitern. Gerade dort summiert sich der manuelle Aufwand am schnellsten und der Entlastungseffekt ist am deutlichsten spürbar.',
  },
  {
    question: 'Wie lange dauert die Umsetzung eines Workflows?',
    answer: 'Ein erster Pilot ist in der Regel innerhalb von 4–8 Wochen produktiv – abhängig von Komplexität und Integrationstiefe. Wir liefern kein Jahresprojekt, sondern abgegrenzte Umsetzungen mit klarem Enddatum.',
  },
  {
    question: 'Wie ist das mit Datenschutz und DSGVO?',
    answer: 'Wir legen Wert auf DSGVO-orientierte Umsetzung. Personenbezogene Daten werden nur dort eingesetzt, wo es notwendig und rechtlich abgesichert ist. Details klären wir im Audit.',
  },
];

const structuredData = [
  professionalServiceSchema('/', description),
  faqSchema(faqItems),
];
---

<Layout
  title="Contentfluss – AI-Workflows für Handwerk & Immobilien"
  description={description}
  canonicalPath="/"
  structuredData={structuredData}
>
  <!-- ── 1. HERO DARK ─────────────────────────────────────────────── -->
  <section class="hero hero-dark">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow eyebrow-light">AI-Workflows für Handwerk & Immobilienverwaltung</p>
        <h1 class="hero-h1">Büroprozesse <span class="text-gradient">automatisieren</span> – für Handwerk & Immobilien</h1>
        <p class="lead">
          Contentfluss legt einen AI-Layer über eure bestehenden Abläufe. Keine neue Software,
          kein Systemwechsel – sondern Workflows, die Anfragen, Angebote, Meldungen und
          Kommunikation automatisieren.
        </p>
        <div class="button-row">
          <a
            href="/kontakt"
            class="btn btn-primary"
            data-track="cta_clicked"
            data-track-label="home_hero_erstgespraech"
          >
            Erstgespräch buchen
          </a>
          <a
            href="/workflows"
            class="btn btn-ghost-light"
            data-track="cta_clicked"
            data-track-label="home_hero_loesungen"
          >
            Lösungen ansehen
          </a>
        </div>
        <p class="trustline">Pragmatisch. DSGVO-orientiert. Ohne unnötigen Tool-Zirkus.</p>
      </div>

      <aside class="workflow-visual workflow-visual-dark" aria-label="Beispiel eines Workflow-Dashboards" data-reveal>
        <header>
          <strong>Operatives Dashboard</strong>
          <span><span class="status-dot" aria-hidden="true"></span>Demo-Ansicht</span>
        </header>
        <div class="metric-grid">
          <div class="metric">
            <span>Neue Anfragen</span>
            <strong>18</strong>
          </div>
          <div class="metric">
            <span>Angebote offen</span>
            <strong>7</strong>
          </div>
          <div class="metric">
            <span>Tickets priorisiert</span>
            <strong>24</strong>
          </div>
          <div class="metric">
            <span>Follow-ups heute</span>
            <strong>11</strong>
          </div>
        </div>
        <ul class="metric-list">
          <li>Schadenmeldungen automatisch vorqualifiziert</li>
          <li>Dispo-Updates in Echtzeit ans Team gesendet</li>
          <li>Heute automatisiert erledigt: Demo-Zähler</li>
        </ul>
      </aside>
    </div>
  </section>

  <!-- ── 2. VALUE PILLS ─────────────────────────────────────────────── -->
  <section class="section-tight">
    <div class="container value-bar">
      <div class="value-pill value-pill-check" data-reveal>Spezialisiert auf Handwerk & Immobilienverwaltung</div>
      <div class="value-pill value-pill-check" data-reveal>Messbare Entlastung, keine leeren Versprechen</div>
      <div class="value-pill value-pill-check" data-reveal>Offene Lösungen – kein Vendor Lock-in</div>
      <div class="value-pill value-pill-check" data-reveal>Raum Neuss/Düsseldorf – remote oder vor Ort</div>
    </div>
  </section>

  <!-- ── 3. PROBLEM / SOLUTION ─────────────────────────────────────── -->
  <section class="section">
    <div class="container split two">
      <article class="card card-muted" data-reveal>
        <p class="eyebrow">Was täglich wirklich Zeit kostet</p>
        <h2>Viele operative Teams verlieren Stunden an Aufgaben, die sich täglich wiederholen</h2>
        <p class="lead">
          Rückfragen, Nachfassen, unstrukturierte Eingänge. Was sich nach kleinem Aufwand
          anfühlt, summiert sich im Monat auf Dutzende Stunden – unsichtbar, aber teuer.
        </p>
        <ul class="list" style="margin-top: 1rem;">
          <li>Anfragen kommen unvollständig über mehrere Kanäle rein</li>
          <li>Angebote werden nicht nachgefasst, Chancen gehen verloren</li>
          <li>Schadenmeldungen brauchen mehrere Klärungsrunden</li>
          <li>E-Mails und Anrufe reißen den Tagesablauf auseinander</li>
          <li>Abstimmungen und Rückfragen binden zu viel Bürozeit</li>
        </ul>
      </article>

      <article class="card card-accent" data-reveal>
        <p class="eyebrow">Contentfluss automatisiert genau diese Abläufe</p>
        <h2>Nicht als Generalüberholung, sondern gezielt am Engpass</h2>
        <p class="lead">
          Ein strukturierter Workflow ersetzt fünf manuelle Schritte – und läuft neben eurem
          Betrieb, ohne ihn zu unterbrechen.
        </p>
        <ul class="list list-check" style="margin-top: 1rem;">
          <li>Strukturierte Eingänge mit automatischer Vorqualifikation</li>
          <li>Angebots-Follow-up mit Wiedervorlage und Eskalation</li>
          <li>Vorqualifizierte Schadenmeldungen ab Erstkontakt</li>
          <li>Klare Zuständigkeiten und automatisches Routing</li>
          <li>Messbare Entlastung – sichtbar im Alltag</li>
        </ul>
      </article>
    </div>
  </section>

  <!-- ── 4. BRANCHENVERTICALS ──────────────────────────────────────── -->
  <section class="section" style="background: var(--color-panel); padding-block: clamp(3rem, 6vw, 5.5rem);">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Spezialisiert, nicht verallgemeinert</p>
        <h2>Wir kennen nur zwei operative Umfelder – und die kennen wir gut</h2>
      </div>

      <div class="card-grid two">
        <article class="card" data-reveal>
          <p class="eyebrow" style="margin-bottom: 0.8rem;">Handwerksbetriebe</p>
          <h3>Anfragen strukturieren, Angebote nachfassen, Auslastung stabilisieren</h3>
          <p style="margin-top: 0.6rem;">
            Für Betriebe, die Bürozeit reduzieren und vom Erstkontakt bis zum Folgeauftrag
            klare Prozesse wollen – ohne ihren Werkzeugkasten zu ersetzen.
          </p>
          <div class="button-row">
            <a
              href="/handwerk"
              class="btn btn-secondary"
              data-track="vertical_page_clicked"
              data-track-label="home_handwerk"
            >
              Für Handwerksbetriebe
            </a>
          </div>
        </article>

        <article class="card" data-reveal>
          <p class="eyebrow" style="margin-bottom: 0.8rem;">Immobilienverwaltungen</p>
          <h3>Schadenmeldungen triagieren, Inbox entlasten, Koordination automatisieren</h3>
          <p style="margin-top: 0.6rem;">
            Für Verwaltungen, die Reaktionszeiten verkürzen und Sachbearbeitung entlasten
            wollen – ohne ein weiteres Tool zu kaufen.
          </p>
          <div class="button-row">
            <a
              href="/immobilienverwaltung"
              class="btn btn-secondary"
              data-track="vertical_page_clicked"
              data-track-label="home_immobilienverwaltung"
            >
              Für Immobilienverwaltungen
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ── 5. FEATURED WORKFLOWS ─────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Beispiele für Workflows mit echtem Hebel</p>
        <h2>Drei Einsatzfelder, die sofort wirken können</h2>
      </div>

      <div class="card-grid three">
        {featuredWorkflows.map((workflow) => (
          <article class="card" data-reveal>
            <span class="chip">{workflow.vertical}</span>
            <h3 style="margin-top: 0.6rem;">{workflow.name}</h3>
            <p>{workflow.short}</p>
            <ul class="list list-check" style="margin-top: 0.9rem;">
              {workflow.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>
            <div class="button-row">
              <a
                href={`/kontakt?workflow=${workflow.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`home_${workflow.slug}`}
              >
                Workflow besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 6. PROCESS TIMELINE ──────────────────────────────────────── -->
  <section class="section" style="background: var(--color-panel); padding-block: clamp(3rem, 6vw, 5.5rem);">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">So läuft ein Projekt mit uns ab</p>
        <h2>Audit. Pilot. Betrieb. – In drei Schritten zur stabilen Automatisierung.</h2>
      </div>

      <div class="process-timeline">
        <article class="process-step" data-reveal>
          <div class="process-step-badge" aria-hidden="true">1</div>
          <h3>Audit</h3>
          <p style="margin-top: 0.5rem;">
            Wir schauen auf euren Prozess, identifizieren den größten operativen Hebel und
            liefern einen priorisierten Plan. Ihr wisst danach genau, was sich wirtschaftlich lohnt.
          </p>
        </article>
        <article class="process-step" data-reveal>
          <div class="process-step-badge" aria-hidden="true">2</div>
          <h3>Build / Pilot</h3>
          <p style="margin-top: 0.5rem;">
            Wir bauen den ersten Workflow, testen ihn mit echten Fällen und bringen ihn produktiv.
            Kein Big-Bang-Projekt – ein begrenzter Pilot mit klarem Ergebnis.
          </p>
        </article>
        <article class="process-step" data-reveal>
          <div class="process-step-badge" aria-hidden="true">3</div>
          <h3>Betrieb</h3>
          <p style="margin-top: 0.5rem;">
            Wir begleiten, optimieren und entwickeln weiter – aber nur wo es sinnvoll ist.
            Keine Dauerverträge ohne Mehrwert.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ── 7. WHY US ─────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Warum Unternehmen mit Contentfluss arbeiten</p>
        <h2>Klare Arbeitsweise. Belastbare Umsetzung. Ehrliche Empfehlungen.</h2>
      </div>

      <div class="card-grid four">
        <article class="card" data-reveal>
          <h3>Klar statt kompliziert</h3>
          <p>Keine Tool-Show. Nur Lösungen, die im Alltag funktionieren und verständlich erklärt sind.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Operativ statt theoretisch</h3>
          <p>Wir denken vom Engpass, nicht vom Trend. Was nichts bringt, bauen wir nicht.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Hochwertig statt gebastelt</h3>
          <p>Saubere Umsetzung, strukturierte Übergabe, dokumentierte Prozesse.</p>
        </article>
        <article class="card" data-reveal>
          <h3>Partnerschaft statt Projektabwurf</h3>
          <p>Kurze Wege, direkte Kommunikation, Empfehlungen die auch mal gegen uns sprechen.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ── 8. BEFORE / AFTER ─────────────────────────────────────────── -->
  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Wie das in der Praxis aussehen kann</p>
        <h2>Typische Situationen, die wir strukturieren</h2>
      </div>

      <div class="card-grid three">
        {proofExamples.map((example) => (
          <article class="card before-after-card" data-reveal>
            <div class="ba-pane">
              <p class="ba-label ba-label-before">Vorher</p>
              <p>{example.before}</p>
            </div>
            <div class="ba-pane">
              <p class="ba-label ba-label-after">Nachher</p>
              <p>{example.after}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="button-row" data-reveal>
        <a
          href="/fallbeispiele"
          class="btn btn-secondary"
          data-track="cta_clicked"
          data-track-label="home_fallbeispiele"
        >
          Mehr Beispiele ansehen
        </a>
      </div>
      <p style="margin-top: 0.65rem; color: var(--color-muted); font-size: 0.86rem;" data-reveal>
        Diese Beispiele zeigen typische Abläufe, keine verifizierten Kundendaten.
      </p>
    </div>
  </section>

  <!-- ── 9. SIMULATED PROOF ─────────────────────────────────────────── -->
  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Zahlen ohne Fake-Referenzen</p>
        <h2>Simulierte Orientierungskorridore – transparent gekennzeichnet</h2>
        <p>
          Wir haben noch keine veröffentlichten Kundenreferenzen. Stattdessen zeigen wir, was
          auf Basis typischer Prozessvolumina realistisch erreichbar ist.
        </p>
      </div>

      <div class="stat-grid">
        {simulatedProofCases.map((item) => (
          <div class="stat-card" data-reveal>
            <div class="stat-value">{item.value}</div>
            <div class="stat-label">{item.label}</div>
            <p class="mono-label" style="margin-top: 0.55rem;">{item.title}</p>
            <p class="stat-note">{item.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 10. FAQ ────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="eyebrow">Häufige Fragen</p>
        <h2>Was Betriebe uns vor dem Erstgespräch fragen</h2>
      </div>

      <div class="faq-accordion" data-reveal>
        {faqItems.map((item) => (
          <details>
            <summary>
              <span>{item.question}</span>
              <svg class="faq-chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="faq-body">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 11. FINAL CTA (DARK) ──────────────────────────────────────── -->
  <section class="section-dark-cta">
    <div class="container" data-reveal>
      <p class="eyebrow eyebrow-light">Nächster Schritt</p>
      <h2>Prüft in 20 Minuten, ob sich Automatisierung bei euch wirtschaftlich lohnt</h2>
      <p class="lead">
        Im kostenlosen Erstgespräch schauen wir auf euren Prozess und sagen euch offen,
        ob eine Umsetzung Sinn macht – und wenn ja, wo wir anfangen würden.
      </p>
      <div class="button-row">
        <a
          href="/kontakt"
          class="btn btn-primary"
          data-track="cta_clicked"
          data-track-label="home_final_erstgespraech"
        >
          Erstgespräch buchen
        </a>
      </div>
    </div>
  </section>
</Layout>
