---
import Layout from '../layouts/Layout.astro';
import { pageMeta, organizationSchema, websiteSchema } from '../lib/seo';
import {
  handwerkWorkflows,
  immobilienverwaltungWorkflows,
  type WorkflowDefinition,
} from '../lib/workflows';

const meta = pageMeta.home;
const workflowIndex = new Map<string, WorkflowDefinition>(
  [...handwerkWorkflows, ...immobilienverwaltungWorkflows].map((workflow) => [workflow.slug, workflow])
);
const getWorkflow = (slug: string) => workflowIndex.get(slug)!;

const featuredWorkflow = getWorkflow('anfrageannahme-vorqualifikation');
const supportingWorkflows = [
  getWorkflow('angebots-follow-up-conversion'),
  getWorkflow('schadenmeldung-vorqualifikation'),
];

const trustPills = [
  'Pilot in 3–5 Wochen',
  'Kein Systemwechsel',
  'DSGVO-orientiert',
  'Für Teams mit 3–30 Mitarbeitenden',
];

const inboundFragments = [
  { channel: 'Telefon', text: 'Telefonische Anfrage ohne Adresse' },
  { channel: 'WhatsApp', text: 'WhatsApp mit 2 Fotos' },
  { channel: 'E-Mail', text: 'E-Mail ohne Rückrufnummer' },
  { channel: 'Schaden', text: 'Schadensmeldung ohne Ticket' },
];

const structuredOutputs = [
  { label: 'Vollständige Anfrage', detail: 'Adresse, Fotos, Rückrufnummer, Anliegen' },
  { label: 'Zuständigkeit erkannt', detail: 'richtige Rolle oder Team direkt zugeordnet' },
  { label: 'Follow-up gesetzt', detail: 'Status und nächste Aktion stehen fest' },
  { label: 'Bearbeitung vorbereitet', detail: 'Rückruf, Routing oder Ticket sauber angelegt' },
];

const processSteps = [
  {
    number: '01',
    title: 'Engpass verstehen',
    body: 'Wir schauen auf den konkreten Vorgang und trennen echten Ablaufdruck von allgemeinem Tool-Lärm.',
  },
  {
    number: '02',
    title: 'Workflow bauen',
    body: 'Der Ablauf wird auf eure Sprache, Rollen und vorhandenen Systeme zugeschnitten statt darübergestülpt.',
  },
  {
    number: '03',
    title: 'Im Alltag einsetzen',
    body: 'Der Workflow läuft im Betrieb, wird nachgeschärft und muss dort tragen, wo heute Reibung entsteht.',
  },
];

const schemas = [organizationSchema(), websiteSchema()];
---

<Layout title={meta.title} description={meta.description} schemas={schemas}>
  <section class="premium-home-hero">
    <div class="premium-home-liquid premium-home-liquid-a" aria-hidden="true"></div>
    <div class="premium-home-liquid premium-home-liquid-b" aria-hidden="true"></div>
    <div class="premium-home-glow premium-home-glow-a" aria-hidden="true"></div>
    <div class="premium-home-glow premium-home-glow-b" aria-hidden="true"></div>

    <div class="container hero-shell premium-home-hero-shell">
      <div class="premium-home-copy" data-reveal data-hero-parallax="0.028">
        <span class="eyebrow premium-home-eyebrow">
          <span class="eyebrow-dot"></span>
          KI-Workflows für Handwerk &amp; Hausverwaltung
        </span>

        <div class="premium-home-copy-body stack gap-6">
          <h1>
            <span class="premium-home-line">Weniger operative</span>
            <span class="premium-home-line"><span class="serif-accent">Reibung.</span> Mehr Flow</span>
            <span class="premium-home-line">im Tagesgeschäft.</span>
          </h1>
          <p class="page-intro">
            Contentfluss automatisiert Anfragen, Meldungen, Angebote und Kommunikation
            — auf euren bestehenden Abläufen, ohne Systemwechsel.
          </p>
        </div>

        <div class="premium-home-actions">
          <a href="/kontakt" class="btn btn-primary btn-lg premium-home-primary" data-track="home_hero_cta">
            Fit-Call buchen
          </a>
          <a href="/workflows" class="btn premium-home-secondary" data-track="home_hero_workflows">
            Workflows ansehen
          </a>
        </div>

        <ul class="premium-home-trust" aria-label="Eckpunkte zum Einstieg">
          {trustPills.map((pill) => <li>{pill}</li>)}
        </ul>
      </div>

      <div class="premium-home-visual" data-reveal data-hero-parallax="-0.045" aria-hidden="true">
        <div class="premium-home-kpi premium-home-kpi-left">
          <span class="premium-home-kpi-label">Effekt</span>
          <strong>–18 Min / Tag</strong>
        </div>
        <div class="premium-home-kpi premium-home-kpi-right">
          <span class="premium-home-kpi-label">Heute</span>
          <strong>12 verarbeitet</strong>
        </div>

        <div class="premium-home-canvas">
          <div class="premium-home-canvas-header">
            <span class="premium-home-canvas-title">Operations Canvas</span>
            <span class="premium-home-canvas-status">
              <span class="status-dot status-dot-live"></span>
              aktiv
            </span>
          </div>

          <div class="premium-home-node-track">
            <article class="premium-home-node premium-home-node-anfrage">
              <span class="premium-home-node-index">01</span>
              <h2>Anfrage</h2>
              <p>Telefon, Mail und Messenger laufen in einen lesbaren Eingang.</p>
            </article>
            <article class="premium-home-node premium-home-node-qualifizierung">
              <span class="premium-home-node-index">02</span>
              <h2>Qualifizierung</h2>
              <p>Fehlende Infos werden nachgezogen und der Kontext strukturiert.</p>
            </article>
            <article class="premium-home-node premium-home-node-routing">
              <span class="premium-home-node-index">03</span>
              <h2>Routing</h2>
              <p>Der Vorgang landet mit Zuständigkeit und nächster Aktion im Team.</p>
            </article>
          </div>

          <div class="premium-home-canvas-panels">
            <div class="premium-home-input-stack">
              <span class="premium-home-panel-label">Unsortierte Eingänge</span>
              <div class="premium-home-signal-list">
                <div class="premium-home-signal premium-home-signal-mail">
                  <span>Mail</span>
                  <small>ohne Rückrufnummer</small>
                </div>
                <div class="premium-home-signal premium-home-signal-phone">
                  <span>Telefon</span>
                  <small>Adresse fehlt</small>
                </div>
                <div class="premium-home-signal premium-home-signal-chat">
                  <span>WhatsApp</span>
                  <small>2 Fotos, kein Kontext</small>
                </div>
              </div>
            </div>

            <div class="premium-home-output-board">
              <span class="premium-home-panel-label">Bearbeitbarer Output</span>
              <div class="premium-home-output-rows">
                <div class="premium-home-output-row">
                  <span>Vollständigkeit</span>
                  <strong>Adresse, Fotos, Kontakt</strong>
                </div>
                <div class="premium-home-output-row">
                  <span>Zuständigkeit</span>
                  <strong>Service-Team oder Sachbearbeitung</strong>
                </div>
                <div class="premium-home-output-row">
                  <span>Nächster Schritt</span>
                  <strong>Rückruf, Ticket oder Statusmail</strong>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section premium-home-signature">
    <div class="container premium-home-shell">
      <div class="premium-home-section-head premium-home-section-head-center" data-reveal>
        <span class="section-label">Signature Transformation</span>
        <h2>Vom täglichen Durcheinander zum klaren Ablauf</h2>
        <p>
          Was heute per Telefon, Mail, WhatsApp und Rückfragen auseinanderläuft,
          wird in einen sauberen operativen Flow überführt.
        </p>
      </div>

      <div class="premium-home-transformation-stage" data-reveal>
        <div class="premium-home-before-side">
          <div class="premium-home-stage-head">
            <span class="premium-home-stage-label">Before</span>
            <h3>Fragmente statt Vorgang</h3>
          </div>
          <div class="premium-home-fragment-stack">
            {inboundFragments.map((fragment, index) => (
              <article class:list={['premium-home-fragment', index === 1 && 'premium-home-fragment-glass', index === 3 && 'premium-home-fragment-glass']}>
                <span class="premium-home-fragment-channel">{fragment.channel}</span>
                <p>{fragment.text}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="premium-home-transformation-spine">
          <span class="premium-home-spine-label">Contentfluss Workflow</span>
          <span class="premium-home-spine-line"></span>
          <p>liest, ergänzt und routet den Eingang, bevor operative Zeit verloren geht.</p>
        </div>

        <div class="premium-home-after-side">
          <div class="premium-home-stage-head">
            <span class="premium-home-stage-label">After</span>
            <h3>Strukturierter operativer Flow</h3>
          </div>
          <div class="premium-home-after-board">
            {structuredOutputs.map((item) => (
              <div class="premium-home-after-row">
                <span>{item.label}</span>
                <strong>{item.detail}</strong>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section premium-home-industries">
    <div class="container premium-home-shell">
      <div class="premium-home-section-head" data-reveal>
        <span class="section-label">Zwei Branchen, zwei operative Druckbilder</span>
        <h2>Handwerk und Hausverwaltung brauchen dieselbe Präzision. Aber nicht dieselbe Inszenierung.</h2>
        <p>
          Beide Welten profitieren von saubereren Eingängen und klareren Übergaben.
          Die operative Sprache und der Rhythmus dahinter sind trotzdem unterschiedlich.
        </p>
      </div>

      <div class="premium-home-industry-stage">
        <article class="premium-home-industry premium-home-industry-handwerk" data-reveal>
          <div class="premium-home-industry-top">
            <span class="premium-home-industry-chip">Handwerk</span>
            <span class="premium-home-industry-kicker">Viele Eingänge, wenig Puffer</span>
          </div>
          <h3>Wenn Frontoffice, Angebot und Terminstatus an einem Tag gleichzeitig Druck machen.</h3>
          <p>
            Für Betriebe, bei denen Anfragen sauber reinkommen müssen, damit Rückruf,
            Angebot und Dispo nicht im Tagesgeschäft zerrieben werden.
          </p>
          <ul class="premium-home-industry-list">
            <li>Anfragen kommen ohne Adresse, Foto oder klaren Umfang rein.</li>
            <li>Angebote bleiben offen, weil Follow-up keinen festen Takt hat.</li>
            <li>Statusfragen gehen direkt ins Büro statt in einen sauberen Ablauf.</li>
          </ul>
          <div class="premium-home-industry-tags">
            <span>Frontoffice</span>
            <span>Angebot</span>
            <span>Terminstatus</span>
          </div>
          <a href="/handwerk" class="btn btn-secondary" data-track="home_industry_handwerk">Mehr für Handwerk</a>
        </article>

        <article class="premium-home-industry premium-home-industry-immo" data-reveal>
          <div class="premium-home-industry-top">
            <span class="premium-home-industry-chip">Hausverwaltung</span>
            <span class="premium-home-industry-kicker">Koordination statt Kanalchaos</span>
          </div>
          <h3>Wenn Meldung, Rückfrage und Dienstleister-Status in derselben Spur landen sollen.</h3>
          <p>
            Für Verwaltungen, bei denen Fälle erst dann schneller werden, wenn Eingang,
            Zuständigkeit und Kommunikation denselben Informationsstand haben.
          </p>
          <div class="premium-home-immo-board">
            <div class="premium-home-immo-row">
              <span>Schadenmeldung</span>
              <strong>Einheit, Fotos und Dringlichkeit ergänzt</strong>
            </div>
            <div class="premium-home-immo-row">
              <span>Zuständigkeit</span>
              <strong>Sachbearbeitung oder Dienstleister direkt erkannt</strong>
            </div>
            <div class="premium-home-immo-row">
              <span>Status</span>
              <strong>Rückfrage und Update laufen dokumentiert mit</strong>
            </div>
          </div>
          <a href="/immobilienverwaltung" class="btn btn-secondary" data-track="home_industry_immo">
            Mehr für Hausverwaltung
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="section premium-home-workflows">
    <div class="container premium-home-shell">
      <div class="premium-home-section-head" data-reveal>
        <span class="section-label">Kuratiert statt katalogisiert</span>
        <h2>Drei Workflows, die im Alltag wirklich etwas verändern</h2>
        <p>
          Ein klarer Schwerpunkt, zwei ergänzende Muster. Weniger Kartenflut, mehr Hierarchie
          und bessere Lesbarkeit für das Wesentliche.
        </p>
      </div>

      <div class="premium-home-workflow-stage">
        <article class="premium-home-workflow-feature" data-reveal>
          <div class="premium-home-workflow-feature-top">
            <span class="premium-home-workflow-chip">Featured Workflow</span>
            <span class="mono-tag">Handwerk</span>
          </div>
          <div class="premium-home-workflow-feature-copy">
            <h3>{featuredWorkflow.name}</h3>
            <p class="premium-home-workflow-lead">{featuredWorkflow.short}</p>
          </div>
          <div class="premium-home-workflow-feature-grid">
            <div class="premium-home-workflow-problem-box">
              <span class="workflow-col-label">Problem</span>
              <p>{featuredWorkflow.problem}</p>
            </div>
            <div class="premium-home-workflow-problem-box">
              <span class="workflow-col-label">Was Contentfluss daraus macht</span>
              <p>{featuredWorkflow.solution}</p>
            </div>
          </div>
          <div class="premium-home-workflow-feature-foot">
            <div>
              <span class="workflow-col-label">Im Alltag spürbar</span>
              <ul class="workflow-benefits">
                {featuredWorkflow.benefits.map((benefit) => <li>{benefit}</li>)}
              </ul>
            </div>
            <div class="premium-home-workflow-proof">
              <span class="workflow-col-label">Geeignet für</span>
              <p>{featuredWorkflow.who}</p>
              <p class="premium-home-workflow-effect">{featuredWorkflow.effect}</p>
            </div>
          </div>
        </article>

        <div class="premium-home-workflow-support" data-stagger>
          {supportingWorkflows.map((workflow, index) => (
            <article class={`premium-home-workflow-support-card premium-home-workflow-support-card-${index + 1}`}>
              <div class="premium-home-workflow-support-head">
                <h3>{workflow.name}</h3>
                <span class="mono-tag">{index === 0 ? 'Handwerk' : 'Immo'}</span>
              </div>
              <p class="premium-home-workflow-lead">{workflow.short}</p>
              <p class="premium-home-workflow-support-problem">{workflow.problem}</p>
              <ul class="workflow-benefits">
                {workflow.benefits.map((benefit) => <li>{benefit}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>

      <div class="premium-home-workflow-cta" data-reveal>
        <a href="/workflows" class="btn btn-secondary" data-track="home_workflows_all">Alle Workflows ansehen</a>
      </div>
    </div>
  </section>

  <section class="section-sm premium-home-process">
    <div class="container premium-home-shell">
      <div class="premium-home-section-head premium-home-section-head-center" data-reveal>
        <span class="section-label">Zusammenarbeit</span>
        <h2>So läuft die Zusammenarbeit ab</h2>
      </div>

      <div class="premium-home-process-rail" data-stagger>
        {processSteps.map((step) => (
          <article class="premium-home-process-step">
            <span class="premium-home-process-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section premium-home-final">
    <div class="container premium-home-shell premium-home-final-shell">
      <div class="premium-home-final-card" data-reveal>
        <span class="section-label">Fit-Call</span>
        <h2>Wenn täglich zu viel hängen bleibt, ist es Zeit für einen besseren Ablauf.</h2>
        <p class="page-intro">
          Im Fit-Call schauen wir auf euren Engpass und prüfen, ob ein Workflow in eurem Alltag
          wirklich Sinn ergibt.
        </p>
        <a href="/kontakt" class="btn btn-primary btn-lg premium-home-primary" data-track="home_final_cta">
          Fit-Call buchen
        </a>
      </div>
    </div>
  </section>
</Layout>
