---
import Layout from '../layouts/Layout.astro';
import { breadcrumbSchema } from '../lib/seo';

const schemas = [
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Impressum', path: '/impressum' },
  ]),
];
---

<Layout title="Impressum" description="Impressum von Contentfluss gemäß § 5 TMG." canonicalPath="/impressum" schemas={schemas}>
  <section class="section">
    <div class="container legal-shell" data-reveal>
      <p class="eyebrow">Rechtliches</p>
      <h1>Impressum</h1>

      <article class="card" style="margin-top: 1.2rem;">
        <h2>Angaben gemäß § 5 TMG</h2>
        <p>
          Rene Maikel Blay Hannen-Oware<br />
          Hesemannstraße 17a<br />
          41460 Neuss
        </p>

        <h2 style="margin-top: 1.2rem;">Kontakt</h2>
        <p>
          Telefon: <a href="tel:+4915125273382" style="text-decoration: underline;">015125273382</a><br />
          E-Mail: <a href="mailto:maikel.hannen@gmail.com" style="text-decoration: underline;">maikel.hannen@gmail.com</a>
        </p>

        <h2 style="margin-top: 1.2rem;">Umsatzsteuer</h2>
        <p>Als Kleinunternehmer im Sinne von § 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.</p>

        <h2 style="margin-top: 1.2rem;">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
        <p>
          Rene Maikel Blay Hannen-Oware<br />
          Hesemannstraße 17a<br />
          41460 Neuss
        </p>

        <h2 style="margin-top: 1.2rem;">Streitschlichtung</h2>
        <p>
          Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung bereit:
          <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer" style="text-decoration: underline;">
            https://ec.europa.eu/consumers/odr/
          </a>.
        </p>
        <p style="margin-top: 0.6rem;">
          Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.
        </p>
      </article>
    </div>
  </section>
</Layout>
