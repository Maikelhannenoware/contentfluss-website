---
import Layout from '../layouts/Layout.astro';
import { handwerkOffers } from '../lib/offers';
import { breadcrumbSchema, professionalServiceSchema } from '../lib/seo';

const description =
  'Contentfluss baut AI-Operations für Handwerksbetriebe: Anfrageannahme, Angebots-Follow-up, Service-Recall, Mahnkommunikation und Terminprozesse.';

const painpoints = [
  'Anfragen kommen unvollständig über mehrere Kanäle rein.',
  'Angebote werden nicht systematisch nachverfolgt.',
  'Wartungs- und Service-Recall passiert unregelmäßig.',
  'Zahlungserinnerungen und Mahnkommunikation binden zu viel Bürozeit.',
  'Dispo- und Terminabstimmung erzeugt Rückrufschleifen.',
];

const processSteps = [
  {
    title: 'Workflow-Audit',
    text: 'Ist-Prozess aufnehmen, größten operativen Hebel identifizieren und Zielmetriken festlegen.',
  },
  {
    title: 'Build / Umsetzung',
    text: 'Priorisierten Workflow implementieren, mit realen Fällen testen und sauber in bestehende Prozesse einbetten.',
  },
  {
    title: 'Betrieb / Optimierung',
    text: 'Monitoring, Tuning und Weiterentwicklung im laufenden Betrieb mit klaren Verantwortlichkeiten.',
  },
];

const structuredData = [
  professionalServiceSchema('/handwerk', description),
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Handwerk', path: '/handwerk' },
  ]),
];
---

<Layout
  title="AI-Operations für Handwerk | Contentfluss"
  description={description}
  canonicalPath="/handwerk"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">AI-Operations für Handwerksbetriebe</p>
        <h1>Weniger Bürochaos. Mehr Abschlüsse. Klare Prozesse vom Erstkontakt bis zum Folgeauftrag.</h1>
        <p class="lead">
          Contentfluss legt einen AI-Layer über eure bestehenden Abläufe. Kein Software-Ersatz,
          sondern produktisierte Workflows für Intake, Follow-up, Recall und operative
          Kommunikation.
        </p>
        <p class="trustline">Struktur: Workflow-Audit -> Build -> Betrieb.</p>
        <div class="button-row">
          <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="handwerk_hero_cta">
            Erstgespräch buchen
          </a>
          <a href="#offers" class="btn btn-secondary" data-track="cta_clicked" data-track-label="handwerk_hero_offers">
            5 Handwerk-Offers ansehen
          </a>
        </div>
      </div>

      <aside class="workflow-visual" data-reveal>
        <header>
          <strong>Typische Hebel im Handwerk</strong>
          <span>Intake, Follow-up, Recall</span>
        </header>
        <ul class="metric-list">
          <li>Vollständigere Anfragen statt Rückfrageketten</li>
          <li>Mehr Angebotsrücklauf durch strukturierte Sequenzen</li>
          <li>Planbarere Auslastung durch Service-Recall</li>
          <li>Weniger manuelle Abstimmung im Tagesgeschäft</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Typische Painpoints in Handwerksbetrieben</h2>
      </div>
      <div class="card surface" data-reveal style="padding: 1.3rem;">
        <ul class="list">
          {painpoints.map((painpoint) => (
            <li>{painpoint}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section id="offers" class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Die 5 Offers für Handwerk</h2>
        <p>Jedes Offer ist als wiederholbarer Workflow mit klarer Preis- und Delivery-Logik produktisiert.</p>
      </div>

      <div class="card-grid two">
        {handwerkOffers.map((offer) => (
          <article class="card" data-reveal>
            <span class="chip">{offer.code}</span>
            <h3 style="margin-top: 0.65rem;">{offer.name}</h3>
            <p>{offer.shortDescription}</p>
            <p style="margin-top: 0.75rem;"><strong>Setup:</strong> {offer.setupPrice}</p>
            <p style="margin-top: 0.35rem;"><strong>Betrieb:</strong> {offer.retainerPrice}</p>
            <ul class="list list-check" style="margin-top: 0.85rem;">
              {offer.deliverables.slice(0, 3).map((deliverable) => (
                <li>{deliverable}</li>
              ))}
            </ul>
            <div class="button-row">
              <a
                href={`/handwerk/${offer.slug}`}
                class="btn btn-secondary"
                data-track="cta_clicked"
                data-track-label={`handwerk_offer_detail_${offer.slug}`}
              >
                Details ansehen
              </a>
              <a
                href={`/kontakt?workflow=${offer.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`handwerk_offer_contact_${offer.slug}`}
              >
                Offer besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Prozessmodell für jedes Projekt</h2>
      </div>

      <div class="card-grid three">
        {processSteps.map((step, index) => (
          <article class="card" data-reveal>
            <span class="kicker-number">{index + 1}</span>
            <h3 style="margin-top: 0.8rem;">{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container surface" style="padding: clamp(1.4rem, 4vw, 2.1rem);" data-reveal>
      <h2>Handwerk-Pivot jetzt im Betrieb umsetzen</h2>
      <p class="lead">
        Startpunkt sind die drei priorisierten Kernoffers HW-02, HW-01 und HW-03. Danach wird die
        Offer-Bibliothek schrittweise ausgebaut.
      </p>
      <div class="button-row">
        <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="handwerk_final_cta">
          Erstes Offer priorisieren
        </a>
      </div>
    </div>
  </section>
</Layout>
