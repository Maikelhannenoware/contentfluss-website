---
import Layout from '../layouts/Layout.astro';
import { pageMeta, breadcrumbSchema, professionalServiceSchema } from '../lib/seo';
import { handwerkWorkflows } from '../lib/workflows';

const meta = pageMeta.handwerk;
const schemas = [
  breadcrumbSchema([{name:'Startseite',path:'/'},{name:'Handwerk',path:'/handwerk'}]),
  professionalServiceSchema('/handwerk', meta.description),
];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <section class="hero-sub">
    <div class="container content-narrow">
      <span class="eyebrow">Für Handwerksbetriebe</span>
      <h1 style="margin-top:1rem">Weniger Rückfragen. Weniger Nachfassen. Mehr Klarheit im Ablauf.</h1>
      <p class="page-intro" style="margin-top:1rem">Wenn Anfragen unvollständig reinkommen, Angebote offen liegen bleiben und Rückfragen den Tag zerhacken, hilft kein neues Buzzword — sondern ein besserer Ablauf.</p>
      <div class="flex-row" style="margin-top:2rem">
        <a href="/kontakt" class="btn btn-primary btn-lg" data-track="handwerk_hero_cta">Fit-Call buchen</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Typische Engpässe</span>
        <h2>Was täglich Zeit frisst</h2>
      </div>
      <div class="grid-2" data-stagger>
        {[
          { title: 'Anfragen ohne alle Infos', body: 'Kunde ruft an oder schreibt — aber ohne Adresse, Beschreibung oder Fotos. Bevor es losgehen kann, muss erst nachgehakt werden.' },
          { title: 'Angebote, die im Nichts verschwinden', body: 'Angebot raus, kein Rücklauf. Nachfassen kommt nie dran. Irgendwann fragt ein Mitbewerber nach — und bekommt den Auftrag.' },
          { title: 'Rückfragen zu offenen Terminen', body: 'Wann kommt ihr? Ist Montag noch frei? Statusfragen landen direkt beim falschen Ansprechpartner.' },
          { title: 'Verwaltung neben der Baustelle', body: 'Dokumentation, Materialbestellungen, Abschlussberichte — alles manuell, alles neben dem eigentlichen Job.' },
        ].map(p => (
          <div class="card">
            <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.5rem">{p.title}</h3>
            <p style="font-size:0.875rem;max-width:none">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Workflows</span>
        <h2>Was automatisiert werden kann</h2>
        <p>Konkrete Abläufe für wiederkehrende Aufgaben im Handwerksbetrieb.</p>
      </div>
      <div class="grid-2" data-stagger>
        {handwerkWorkflows.map(wf => (
          <div class="workflow-card">
            <div class="workflow-card-meta">
              <h3 class="workflow-card-title">{wf.name}</h3>
            </div>
            <div>
              <p class="workflow-col-label">Problem</p>
              <p class="workflow-problem-block">{wf.problem}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was automatisiert wird</p>
              <p style="font-size:0.875rem;color:var(--color-text-secondary)">{wf.solution}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was dadurch besser läuft</p>
              <ul class="workflow-benefits">
                {wf.benefits.map(b => <li>{b}</li>)}
              </ul>
            </div>
            <div class="card-footer">
              <a href={`/kontakt?workflow=${wf.slug}`} class="btn btn-secondary btn-sm" data-track={`handwerk_wf_${wf.slug}`}>Anfragen</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Zusammenarbeit</span>
        <h2>Wie es abläuft</h2>
      </div>
      <div class="grid-3" data-stagger>
        {[
          { n:'01', title:'Engpass benennen', body:'Im Fit-Call sprechen wir über eure Situation. Keine Vorbereitung nötig.' },
          { n:'02', title:'Workflow entwickeln', body:'Wir bauen den Ablauf auf eure Systeme, Formulierungen und typischen Fälle zu.' },
          { n:'03', title:'Einsetzen und nachschärfen', body:'Live-Gang, Begleitung im Start, Anpassung was nicht stimmt.' },
        ].map(s => (
          <div class="process-step">
            <span class="process-step-num">{s.n}</span>
            <p class="process-step-title">{s.title}</p>
            <p class="process-step-body">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container content-center">
      <h2>Welcher Ablauf kostet euch am meisten Zeit?</h2>
      <p style="margin-top:0.75rem;margin-bottom:2rem;margin-inline:auto">Im Fit-Call klären wir, ob ein Workflow das lösen kann — und was das kosten würde.</p>
      <a href="/kontakt" class="btn btn-primary btn-lg" data-track="handwerk_final_cta">Fit-Call buchen</a>
    </div>
  </section>

</Layout>
