---
import Layout from '../layouts/Layout.astro';
import { breadcrumbSchema, professionalServiceSchema } from '../lib/seo';

const description =
  'AI Operations Agentur für Prozessautomatisierung: Contentfluss arbeitet strukturiert über Workflow-Audit, Umsetzung und laufende Optimierung.';

const structuredData = [
  professionalServiceSchema('/leistungen', description),
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Leistungen', path: '/leistungen' },
  ]),
];
---

<Layout
  title="Leistungen | KI Workflow Umsetzung für Unternehmen"
  description={description}
  canonicalPath="/leistungen"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container" data-reveal>
      <p class="eyebrow">Leistungen</p>
      <h1>So arbeiten wir an euren Workflows</h1>
      <p class="lead">
        Kein Bauchladen. Kein blindes Tool-Setup. Sondern ein strukturierter Weg von der
        Prozessanalyse bis zur stabilen Umsetzung.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container card-grid three">
      <article class="card card-accent" data-reveal>
        <h2 style="font-size: 1.45rem;">1. Workflow-Audit</h2>
        <p class="price-badge">ab 590 € einmalig</p>
        <p style="margin-top: 0.6rem;"><strong>Was enthalten ist:</strong> Prozessaufnahme, Engpassanalyse, Hebel-Priorisierung, klare Empfehlung.</p>
        <p style="margin-top: 0.5rem;"><strong>Wann sinnvoll:</strong> Wenn unklar ist, welcher Workflow zuerst wirtschaftlich wirkt.</p>
        <p style="margin-top: 0.5rem;"><strong>Ergebnis:</strong> Priorisierter Umsetzungsplan mit realistischem Aufwand.</p>
      </article>

      <article class="card card-accent" data-reveal>
        <h2 style="font-size: 1.45rem;">2. Build / Umsetzung</h2>
        <p class="price-badge">ab 2.900 € bis 7.900 €+</p>
        <p style="margin-top: 0.6rem;"><strong>Was enthalten ist:</strong> Workflow-Design, technische Umsetzung, Testphase, Livegang, Übergabe.</p>
        <p style="margin-top: 0.5rem;"><strong>Wann sinnvoll:</strong> Wenn ein klarer Engpass definiert ist und operativ gelöst werden soll.</p>
        <p style="margin-top: 0.5rem;"><strong>Ergebnis:</strong> Produktiver Workflow, der im Team nutzbar und dokumentiert ist.</p>
      </article>

      <article class="card card-accent" data-reveal>
        <h2 style="font-size: 1.45rem;">3. Betrieb / Optimierung</h2>
        <p class="price-badge">ab 490 € bis 1.490 €+/Monat</p>
        <p style="margin-top: 0.6rem;"><strong>Was enthalten ist:</strong> Monitoring, Fehlerbehebung, KPI-Review, gezielte Weiterentwicklung.</p>
        <p style="margin-top: 0.5rem;"><strong>Wann sinnvoll:</strong> Wenn der Workflow dauerhaft stabil laufen und mitwachsen soll.</p>
        <p style="margin-top: 0.5rem;"><strong>Ergebnis:</strong> Kontinuierlich belastbare Automatisierung statt Einmal-Projekt.</p>
      </article>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <article class="card" data-reveal>
        <h2>Technische Integration</h2>
        <p class="lead" style="margin-top: 0.6rem;">
          Wir binden eure bestehende Infrastruktur an, damit Workflows nicht isoliert neben dem Alltag laufen.
        </p>
        <div class="chip-list" style="margin-top: 1rem;">
          <span class="chip">Bestehende Tools anbinden</span>
          <span class="chip">Formulare</span>
          <span class="chip">E-Mail</span>
          <span class="chip">WhatsApp</span>
          <span class="chip">Telefon</span>
          <span class="chip">Interne Freigaben</span>
          <span class="chip">Einfache Dashboards</span>
        </div>
      </article>
    </div>
  </section>

  <section class="section-tight">
    <div class="container" data-reveal>
      <article class="card">
        <h2>Transparente Angebotslogik</h2>
        <p class="lead" style="margin-top: 0.6rem;">
          Wir verkaufen keine überladenen Paketboxen. Der Umfang richtet sich nach Prozesskomplexität,
          Teamgröße und Integrationsgrad.
        </p>
        <ul class="list list-check" style="margin-top: 1rem;">
          <li>Klare Leistungsabgrenzung vor Start</li>
          <li>Sauber dokumentierte Übergabe</li>
          <li>Keine Lock-in-Architektur ohne Not</li>
        </ul>
        <p style="margin-top: 1rem; color: var(--color-muted);">
          Content-Marketing kann auf Anfrage ergänzend unterstützt werden, steht aber nicht im Zentrum unseres Angebots.
        </p>
      </article>
    </div>
  </section>

  <section class="section-tight">
    <div class="container surface" style="padding: clamp(1.45rem, 4vw, 2.1rem);" data-reveal>
      <h2>Lasst uns den passenden Einstieg definieren</h2>
      <p class="lead">
        Im Erstgespräch klären wir, ob ein Audit direkt sinnvoll ist oder ob bereits eine konkrete Umsetzung starten kann.
      </p>
      <div class="button-row">
        <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="leistungen_erstgespraech">
          Erstgespräch buchen
        </a>
        <a href="/kontakt?audit=1" class="btn btn-secondary" data-track="cta_clicked" data-track-label="leistungen_audit">
          Audit anfragen
        </a>
      </div>
    </div>
  </section>
</Layout>
