---
import Layout from '../layouts/Layout.astro';
import { pageMeta, breadcrumbSchema, professionalServiceSchema } from '../lib/seo';

const meta = pageMeta.leistungen;
const schemas = [
  breadcrumbSchema([{name:'Startseite',path:'/'},{name:'Leistungen',path:'/leistungen'}]),
  professionalServiceSchema('/leistungen', meta.description),
];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <section class="hero-sub hero-sub-leistungen">
    <div class="container content-narrow">
      <span class="eyebrow">Leistungen</span>
      <h1 style="margin-top:1rem">Operative KI-Workflows, die im Alltag Arbeit abnehmen.</h1>
      <p class="page-intro" style="margin-top:1rem">Contentfluss liefert keine Strategiefolien und keine Tool-Empfehlungen. Wir analysieren operative Engpässe, bauen den passenden Workflow und setzen ihn um.</p>
    </div>
  </section>

  <!-- What gets delivered -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Was bei der Zusammenarbeit entsteht</span>
        <h2>Vier Umsetzungsblöcke</h2>
      </div>
      <div class="grid-4" data-stagger>
        {[
          { n:'01', title:'Prozessanalyse', body:'Wir schauen auf eure bestehenden Abläufe und identifizieren, wo täglich Zeit verloren geht — konkret, nicht abstrakt.' },
          { n:'02', title:'Workflow-Design', body:'Wir entwerfen den Ablauf: welche Schritte automatisiert werden, welche Systeme angebunden sind, wie die Übergaben funktionieren.' },
          { n:'03', title:'Umsetzung', body:'Wir bauen und implementieren den Workflow — auf euren Stack, eure Sprache und eure typischen Fälle zugeschnitten.' },
          { n:'04', title:'Rollout & Nachschärfen', body:'Der Workflow geht live. Wir begleiten den Start und passen an, was im echten Betrieb nicht stimmt.' },
        ].map(item => (
          <div class="process-step">
            <span class="process-step-num">{item.n}</span>
            <p class="process-step-title">{item.title}</p>
            <p class="process-step-body">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What you get -->
  <section class="section">
    <div class="container content-narrow">
      <div class="section-head">
        <span class="section-label">Was ihr bekommt</span>
        <h2>Abläufe, die ab Tag 1 laufen</h2>
      </div>
      <p style="margin-bottom:1.25rem">Am Ende einer Zusammenarbeit steht kein PDF mit Empfehlungen, sondern ein Workflow, der in eurem Betrieb läuft. Die Automatisierung ist eingebaut, die Systeme sind verbunden, und euer Team weiß, was sich verändert hat.</p>
      <p style="margin-bottom:1.25rem">Ihr braucht dafür keine interne IT-Abteilung, kein neues Tool als Voraussetzung und keine lange Einarbeitung. Der Workflow setzt auf das auf, was schon da ist — und ersetzt die manuellen Schritte, die heute am meisten Zeit kosten.</p>
      <p>Wenn nach dem Start etwas hakt, schärfen wir nach. Das ist Teil der Arbeit, nicht ein Extrawunsch.</p>
    </div>
  </section>

  <!-- Typical workflow types -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Typische Workflows</span>
        <h2>Was wir häufig umsetzen</h2>
      </div>
      <div class="grid-3" data-stagger>
        {[
          { title:'Anfragequalifizierung', body:'Eingänge automatisch prüfen, kategorisieren und als bearbeitungsfertigen Vorgang weiterleiten.' },
          { title:'Angebots-Follow-up', body:'Offene Angebote zeitbasiert nachfassen, priorisieren und mit dem richtigen Ton wiedervorlegen.' },
          { title:'Schadenmeldungen', body:'Meldungen auf Vollständigkeit prüfen, nachfordern und strukturiert als Vorgang anlegen.' },
          { title:'Inbox-Triage', body:'E-Mails und Tickets automatisch priorisieren, zuordnen und zur Bearbeitung vorbereiten.' },
          { title:'Übergaben & Status', body:'Interne Übergaben und externe Statusupdates standardisieren, damit nichts durchrutscht.' },
          { title:'Serienkommunikation', body:'Wiederkehrende Anschreiben, Erinnerungen und Nachforderungen fristenbasiert und dokumentiert auslösen.' },
        ].map(item => (
          <div class="card">
            <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.5rem">{item.title}</h3>
            <p style="font-size:0.875rem;max-width:none">{item.body}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:2rem;text-align:center">
        <a href="/workflows" class="btn btn-secondary" data-track="leistungen_workflows">Alle Workflows ansehen</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container content-center">
      <h2>Welcher Ablauf kostet euch am meisten Zeit?</h2>
      <p style="margin-top:0.75rem;margin-bottom:2rem;margin-inline:auto">Im Fit-Call klären wir, wo der größte Hebel liegt — und ob ein Workflow dafür Sinn ergibt.</p>
      <a href="/kontakt" class="btn btn-primary btn-lg" data-track="leistungen_final_cta">Fit-Call buchen</a>
    </div>
  </section>

</Layout>
