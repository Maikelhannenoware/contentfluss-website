---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Leistungen" description="Content-Marketing und KI-Automatisierung für lokale Unternehmen in Neuss und Düsseldorf.">

  <section class="max-w-5xl mx-auto px-6 pt-16 pb-8">
    <h1 class="text-4xl font-bold mb-4">Leistungen</h1>
    <p class="text-xl text-gray-600 max-w-2xl">Was ich für euch übernehme – damit ihr euch ums Handwerk kümmern könnt.</p>
  </section>

  <!-- Pakete -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold mb-8">Content-Marketing Pakete</h2>

    <div class="space-y-6">

      <div class="p-8 border border-gray-200 rounded-xl">
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="text-xl font-bold">Content-Starter</h3>
            <p class="text-gray-500 text-sm mt-1">Ideal für den Einstieg</p>
          </div>
          <p class="text-2xl font-bold">299 €<span class="text-gray-400 font-normal text-base">/Monat</span></p>
        </div>
        <ul class="space-y-2 text-gray-600 text-sm">
          <li class="flex gap-2"><span>✓</span> 8 fertige Posts pro Monat (Instagram & Facebook)</li>
          <li class="flex gap-2"><span>✓</span> Bildvorschläge für jedes Posting</li>
          <li class="flex gap-2"><span>✓</span> Lokale Hashtags & Keyword-Optimierung</li>
          <li class="flex gap-2"><span>✓</span> Monatliches Abstimmungsgespräch (30 Min.)</li>
        </ul>
      </div>

      <div class="p-8 border-2 border-gray-900 rounded-xl relative">
        <span class="absolute -top-3 left-6 bg-gray-900 text-white text-xs font-medium px-3 py-1 rounded-full">Meist gebucht</span>
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="text-xl font-bold">Content-Pro</h3>
            <p class="text-gray-500 text-sm mt-1">Für Betriebe, die richtig sichtbar werden wollen</p>
          </div>
          <p class="text-2xl font-bold">499 €<span class="text-gray-400 font-normal text-base">/Monat</span></p>
        </div>
        <ul class="space-y-2 text-gray-600 text-sm">
          <li class="flex gap-2"><span>✓</span> 16 fertige Posts pro Monat</li>
          <li class="flex gap-2"><span>✓</span> Google Business Beiträge (4x/Monat)</li>
          <li class="flex gap-2"><span>✓</span> Monatlicher Newsletter (fertig zum Versenden)</li>
          <li class="flex gap-2"><span>✓</span> Bildvorschläge & Hashtags</li>
          <li class="flex gap-2"><span>✓</span> Monatliches Strategie-Call (45 Min.)</li>
        </ul>
      </div>

      <div class="p-8 border border-gray-200 rounded-xl">
        <div class="flex justify-between items-start mb-4">
          <div>
            <h3 class="text-xl font-bold">KI-Automation</h3>
            <p class="text-gray-500 text-sm mt-1">Einmalige Einrichtung – dauerhafter Nutzen</p>
          </div>
          <p class="text-2xl font-bold">ab 800 €<span class="text-gray-400 font-normal text-base"> einmalig</span></p>
        </div>
        <ul class="space-y-2 text-gray-600 text-sm">
          <li class="flex gap-2"><span>✓</span> Analyse eurer aktuellen Prozesse</li>
          <li class="flex gap-2"><span>✓</span> Einrichtung eines KI-Workflows (z.B. Angebotserstellung, Kundenkommunikation)</li>
          <li class="flex gap-2"><span>✓</span> Schulung & Dokumentation</li>
          <li class="flex gap-2"><span>✓</span> 30 Tage Support nach Übergabe</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-50 py-16 mt-8">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold mb-4">Nicht sicher, was passt?</h2>
      <p class="text-gray-600 mb-8">Erzählt mir kurz von eurem Betrieb – ich empfehle euch das richtige Paket.</p>
      <a href="/kontakt" class="bg-gray-900 text-white font-medium px-8 py-3 rounded-lg hover:bg-gray-700 transition-colors">
        Kostenloses Erstgespräch buchen
      </a>
    </div>
  </section>

</Layout>
