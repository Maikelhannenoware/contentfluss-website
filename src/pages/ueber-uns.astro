---
import Layout from '../layouts/Layout.astro';
import { pageMeta, breadcrumbSchema } from '../lib/seo';

const meta = pageMeta.ueberUns;
const schemas = [
  breadcrumbSchema([{name:'Startseite',path:'/'},{name:'Über uns',path:'/ueber-uns'}]),
];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <section class="hero-sub">
    <div class="container content-narrow">
      <span class="eyebrow">Über uns</span>
      <h1 style="margin-top:1rem">Operative Entlastung statt KI-Show.</h1>
      <p class="page-intro" style="margin-top:1rem">Contentfluss baut KI-Workflows für operative Prozesse in Handwerk und Hausverwaltung. Kein Pitch-Deck, keine Tool-Demo. Umsetzung.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="content-aside">
        <div>
          <p style="margin-bottom:1.25rem">Contentfluss ist aus der Beobachtung entstanden, dass in vielen kleineren Betrieben jeden Tag Zeit verloren geht — in unvollständige Anfragen, manuelle Übergaben, offene Angebote, die niemand nachverfolgt.</p>
          <p style="margin-bottom:1.25rem">Das ist kein KI-Problem und kein Software-Problem. Es ist ein Ablauf-Problem. Und Abläufe lassen sich mit den richtigen Werkzeugen lösen — ohne IT-Großprojekt und ohne Systemwechsel.</p>
          <p>Contentfluss spezialisiert sich auf Handwerk und Hausverwaltung, weil hier die Probleme konkret, wiederkehrend und gut lösbar sind.</p>
        </div>

        <div class="card card-elevated" data-reveal>
          <p class="workflow-col-label">Gründer</p>
          <p style="font-family:var(--font-display);font-size:1.1rem;font-weight:600;margin-top:0.5rem">Maikel Hannen</p>
          <p style="font-size:0.875rem;color:var(--color-text-muted);margin-top:0.25rem">Founder, Contentfluss</p>
          <hr class="divider" style="margin-block:1rem" />
          <p style="font-size:0.875rem;max-width:none">Hintergrund in Prozessautomatisierung und KI-Integration. Fokus auf operative Workflows, die im Tagesgeschäft spürbar Arbeit abnehmen — nicht auf Berater-Deliverables.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Prinzipien</span>
        <h2>Woran sich die Arbeit orientiert</h2>
      </div>
      <div class="grid-2" data-stagger>
        {[
          { title: 'Alltag vor KI-Show', body: 'Wir starten mit dem Tagesgeschäft, nicht mit der Technologie. Was zählt: Welcher Ablauf kostet heute Zeit? Nicht: Welches AI-Feature ist gerade populär.' },
          { title: 'Spezialisierung', body: 'Handwerk und Hausverwaltung. Nicht alles für alle. Die Engpässe in diesen Branchen kennen wir, die Abläufe verstehen wir — deshalb geht die Umsetzung schneller.' },
          { title: 'Umsetzungsnähe', body: 'Was wir liefern, läuft. Kein Audit-Report als Endprodukt, keine Empfehlungsliste zum Selbstumsetzen. Der Workflow ist implementiert und im Einsatz.' },
          { title: 'Pragmatischer Werkzeugeinsatz', body: 'Wir nutzen, was passt — Make, Claude, Resend, bestehende CRM-Systeme. Kein eigenes Produkt, das als Voraussetzung dient. Der Stack richtet sich nach dem Betrieb.' },
        ].map(item => (
          <div class="card">
            <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.5rem">{item.title}</h3>
            <p style="font-size:0.875rem;max-width:none">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container content-center">
      <h2>Kein Pitch. Kein Slide-Deck. Nur ein Gespräch über eure Abläufe.</h2>
      <p style="margin-top:0.75rem;margin-bottom:2rem;margin-inline:auto">Im Fit-Call klären wir, wo euer größter Engpass liegt — und ob ein Workflow dafür Sinn ergibt.</p>
      <a href="/kontakt" class="btn btn-primary btn-lg" data-track="ueberuns_final_cta">Fit-Call buchen</a>
    </div>
  </section>

</Layout>
