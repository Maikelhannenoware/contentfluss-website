---
import Layout from '../layouts/Layout.astro';
import { handwerkWorkflows, immobilienverwaltungWorkflows } from '../lib/workflows';
import { breadcrumbSchema, professionalServiceSchema } from '../lib/seo';

const description =
  'Ausgewählte AI-Workflows für operative Teams in Handwerk und Immobilienverwaltung: konkret, branchenspezifisch und auf reale Engpässe ausgerichtet.';

const structuredData = [
  professionalServiceSchema('/workflows', description),
  breadcrumbSchema([
    { name: 'Startseite', path: '/' },
    { name: 'Workflows', path: '/workflows' },
  ]),
];
---

<Layout
  title="AI-Workflows für Handwerk & Immobilien – Contentfluss"
  description={description}
  canonicalPath="/workflows"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container" data-reveal>
      <p class="eyebrow">Kuratiert statt generisch</p>
      <h1>Ausgewählte AI-Workflows für operative Teams</h1>
      <p class="lead">
        Wir bauen keine generischen Demos, sondern Workflows für reale Engpässe in Handwerk und Immobilienverwaltung.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Für Handwerk</h2>
      </div>

      <div class="card-grid two">
        {handwerkWorkflows.map((workflow) => (
          <article class="card" data-reveal>
            <h3>{workflow.name}</h3>
            <p><strong>Problem:</strong> {workflow.problem}</p>
            <p style="margin-top: 0.55rem;"><strong>Lösung:</strong> {workflow.solution}</p>
            <ul class="list list-check" style="margin-top: 0.85rem;">
              {workflow.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>
            <div class="button-row">
              <a
                href={`/kontakt?workflow=${workflow.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`wf_handwerk_${workflow.slug}`}
              >
                Workflow besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="section-head" data-reveal>
        <h2>Für Immobilienverwaltung</h2>
      </div>

      <div class="card-grid two">
        {immobilienverwaltungWorkflows.map((workflow) => (
          <article class="card" data-reveal>
            <h3>{workflow.name}</h3>
            <p><strong>Problem:</strong> {workflow.problem}</p>
            <p style="margin-top: 0.55rem;"><strong>Lösung:</strong> {workflow.solution}</p>
            <ul class="list list-check" style="margin-top: 0.85rem;">
              {workflow.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>
            <div class="button-row">
              <a
                href={`/kontakt?workflow=${workflow.slug}`}
                class="btn btn-ghost"
                data-track="workflow_cta_clicked"
                data-track-label={`wf_immo_${workflow.slug}`}
              >
                Workflow besprechen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container surface" style="padding: clamp(1.4rem, 4vw, 2.1rem);" data-reveal>
      <h2>Noch kein passender Workflow dabei?</h2>
      <p class="lead">
        Im Erstgespräch klären wir, welcher Engpass in eurem operativen Ablauf den größten Hebel hat.
      </p>
      <div class="button-row">
        <a href="/kontakt" class="btn btn-primary" data-track="cta_clicked" data-track-label="workflows_final_cta">
          Erstgespräch buchen
        </a>
      </div>
    </div>
  </section>
</Layout>
