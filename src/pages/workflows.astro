---
import Layout from '../layouts/Layout.astro';
import { pageMeta, breadcrumbSchema, professionalServiceSchema } from '../lib/seo';
import { handwerkWorkflows, immobilienverwaltungWorkflows } from '../lib/workflows';

const meta = pageMeta.workflows;
const schemas = [
  breadcrumbSchema([{name:'Startseite',path:'/'},{name:'Workflows',path:'/workflows'}]),
  professionalServiceSchema('/workflows', meta.description),
];
---
<Layout title={meta.title} description={meta.description} schemas={schemas}>

  <section class="hero-sub">
    <div class="container content-narrow">
      <span class="eyebrow">Workflows</span>
      <h1 style="margin-top:1rem">Operative Abläufe, die manuelle Arbeit ersetzen.</h1>
      <p class="page-intro" style="margin-top:1rem">Jeder Workflow unten löst ein konkretes Problem in Handwerk oder Hausverwaltung. Keine abstrakten KI-Anwendungen, sondern Abläufe, die im Tagesgeschäft Arbeit abnehmen.</p>
    </div>
  </section>

  <!-- Handwerk Workflows -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Handwerk</span>
        <h2>Workflows für Handwerksbetriebe</h2>
        <p>Für SHK-, Elektro-, Dach- und Servicebetriebe mit 3–30 Mitarbeitern.</p>
      </div>
      <div class="grid-2" data-stagger>
        {handwerkWorkflows.map(wf => (
          <div class="workflow-card">
            <div class="workflow-card-meta">
              <h3 class="workflow-card-title">{wf.name}</h3>
              <span class="mono-tag">HW</span>
            </div>
            <div>
              <p class="workflow-col-label">Problem</p>
              <p class="workflow-problem-block">{wf.problem}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was automatisiert wird</p>
              <p style="font-size:0.875rem;color:var(--color-text-secondary)">{wf.solution}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was dadurch besser läuft</p>
              <ul class="workflow-benefits">
                {wf.benefits.map(b => <li>{b}</li>)}
              </ul>
            </div>
            <div class="card-footer">
              <a href={`/kontakt?workflow=${wf.slug}`} class="btn btn-secondary btn-sm" data-track={`wf_hw_${wf.slug}`}>Anfragen</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Immobilienverwaltung Workflows -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">Immobilienverwaltung</span>
        <h2>Workflows für Hausverwaltungen</h2>
        <p>Für Haus-, WEG- und Immobilienverwaltungen mit hohem Vorgangsaufkommen.</p>
      </div>
      <div class="grid-2" data-stagger>
        {immobilienverwaltungWorkflows.map(wf => (
          <div class="workflow-card">
            <div class="workflow-card-meta">
              <h3 class="workflow-card-title">{wf.name}</h3>
              <span class="mono-tag">IM</span>
            </div>
            <div>
              <p class="workflow-col-label">Problem</p>
              <p class="workflow-problem-block">{wf.problem}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was automatisiert wird</p>
              <p style="font-size:0.875rem;color:var(--color-text-secondary)">{wf.solution}</p>
            </div>
            <div>
              <p class="workflow-col-label">Was dadurch besser läuft</p>
              <ul class="workflow-benefits">
                {wf.benefits.map(b => <li>{b}</li>)}
              </ul>
            </div>
            <div class="card-footer">
              <a href={`/kontakt?workflow=${wf.slug}`} class="btn btn-secondary btn-sm" data-track={`wf_im_${wf.slug}`}>Anfragen</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-feature">
    <div class="container content-center">
      <h2>Welcher Workflow passt zu eurem Engpass?</h2>
      <p style="margin-top:0.75rem;margin-bottom:2rem;margin-inline:auto">Im Fit-Call besprechen wir, welcher Ablauf zuerst Sinn ergibt — und was die Umsetzung kosten würde.</p>
      <a href="/kontakt" class="btn btn-primary btn-lg" data-track="workflows_final_cta">Fit-Call buchen</a>
    </div>
  </section>

</Layout>
