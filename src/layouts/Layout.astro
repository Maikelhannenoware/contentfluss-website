---
import '../styles/global.css';
import { organizationSchema, websiteSchema, absoluteUrl } from '../lib/seo';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  structuredData,
  noindex = false,
} = Astro.props;

const computedTitle = title.includes('Contentfluss') ? title : `${title} | Contentfluss`;
const pathname = Astro.url.pathname;
const canonicalUrl = absoluteUrl(canonicalPath ?? pathname);
const ogImageUrl = absoluteUrl('/og-image.svg');

const navItems = [
  { href: '/leistungen', label: 'Leistungen' },
  { href: '/handwerk', label: 'Handwerk' },
  { href: '/immobilienverwaltung', label: 'Immobilien' },
  { href: '/workflows', label: 'Workflows' },
  { href: '/ueber-uns', label: 'Über uns' },
];

const extraSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const allSchemas = [organizationSchema(), websiteSchema(), ...extraSchemas];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{computedTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Contentfluss" />
    <meta property="og:title" content={computedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={computedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#101e2d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    {allSchemas.map((schema) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>
    ))}
    <slot name="head" />
  </head>

  <body>
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>

    <header class="site-header">
      <div class="container header-shell">
        <a href="/" class="brand" aria-label="Contentfluss Startseite">
          <Logo size="md" />
        </a>

        <nav class="site-nav" aria-label="Hauptnavigation">
          {navItems.map((item) => (
            <a href={item.href} class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}>{item.label}</a>
          ))}
        </nav>

        <div class="header-actions">
          <a
            href="/kontakt"
            class="btn btn-primary header-cta"
            data-track="cta_clicked"
            data-track-label="header_erstgespraech"
          >
            Erstgespräch buchen
          </a>

          <button
            id="menu-toggle"
            class="menu-button"
            aria-label="Menü öffnen"
            aria-controls="mobile-nav"
            aria-expanded="false"
          >
            <svg id="menu-open-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <svg id="menu-close-icon" class="hidden" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6 6l12 12M18 6l-12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </div>

      <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile Navigation">
        <div class="container mobile-nav-inner">
          {navItems.map((item) => (
            <a href={item.href} class={`mobile-link ${isActive(item.href) ? 'is-active' : ''}`}>{item.label}</a>
          ))}
          <a
            href="/kontakt"
            class="btn btn-primary mobile-nav-cta"
            data-track="cta_clicked"
            data-track-label="mobile_erstgespraech"
          >
            Erstgespräch buchen
          </a>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <a href="/" aria-label="Contentfluss Startseite" style="display:inline-block; margin-bottom: 0.75rem;">
            <Logo size="sm" showSub={false} />
          </a>
          <p class="footer-text">AI-Operations für Handwerk und Immobilienverwaltung.</p>
          <p class="footer-meta">Deutschlandweit, remote oder vor Ort.</p>
        </div>

        <div>
          <p class="footer-heading">Lösungen</p>
          <ul class="footer-links">
            <li><a href="/handwerk">Handwerk</a></li>
            <li><a href="/immobilienverwaltung">Immobilienverwaltung</a></li>
            <li><a href="/leistungen">Leistungen</a></li>
            <li><a href="/workflows">Workflows</a></li>
          </ul>
        </div>

        <div>
          <p class="footer-heading">Unternehmen</p>
          <ul class="footer-links">
            <li><a href="/ueber-uns">Über uns</a></li>
            <li><a href="/kontakt">Kontakt</a></li>
            <li><a href="/fallbeispiele">Fallbeispiele</a></li>
          </ul>
        </div>

        <div>
          <p class="footer-heading">Rechtliches</p>
          <ul class="footer-links">
            <li><a href="/impressum">Impressum</a></li>
            <li><a href="/datenschutz">Datenschutz</a></li>
          </ul>
          <a
            href="mailto:hallo@contentfluss.de"
            class="footer-mail"
            data-track="cta_clicked"
            data-track-label="footer_mail"
          >
            hallo@contentfluss.de
          </a>
        </div>
      </div>

      <div class="container footer-bottom">
        <p>© 2026 Contentfluss · Maikel Hannen</p>
        <a href="/kontakt" data-track="cta_clicked" data-track-label="footer_cta">Audit anfragen</a>
      </div>
    </footer>

    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const mobileNav = document.getElementById('mobile-nav');
      const iconOpen = document.getElementById('menu-open-icon');
      const iconClose = document.getElementById('menu-close-icon');

      function setMenuState(open: boolean) {
        if (!mobileNav || !menuToggle || !iconOpen || !iconClose) return;
        mobileNav.classList.toggle('open', open);
        menuToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        menuToggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
        iconOpen.classList.toggle('hidden', open);
        iconClose.classList.toggle('hidden', !open);
      }

      menuToggle?.addEventListener('click', () => {
        const isOpen = mobileNav?.classList.contains('open') ?? false;
        setMenuState(!isOpen);
      });

      document.querySelectorAll('#mobile-nav a').forEach((link) => {
        link.addEventListener('click', () => setMenuState(false));
      });

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setMenuState(false);
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth >= 960) setMenuState(false);
      });
    </script>

    <script>
      type TrackPayload = {
        event: string;
        path: string;
        sessionId: string;
        data: Record<string, string>;
      };

      if (!window.__contentflussTrackingInit) {
        window.__contentflussTrackingInit = true;

        const TRACK_ENDPOINT = '/api/event';
        const TRACK_SESSION_KEY = 'contentfluss_session_id';

        function getSessionId() {
          try {
            const existing = window.localStorage.getItem(TRACK_SESSION_KEY);
            if (existing) return existing;
            const generated = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
            window.localStorage.setItem(TRACK_SESSION_KEY, generated);
            return generated;
          } catch {
            return 'anonymous';
          }
        }

        function sendTrack(payload: TrackPayload) {
          const body = JSON.stringify(payload);
          if (navigator.sendBeacon) {
            const blob = new Blob([body], { type: 'application/json' });
            navigator.sendBeacon(TRACK_ENDPOINT, blob);
            return;
          }

          fetch(TRACK_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
            keepalive: true,
          }).catch(() => {
            // ignore transport errors
          });
        }

        window.contentflussTrack = (eventName: string, data: Record<string, string> = {}) => {
          if (typeof eventName !== 'string' || !eventName.trim()) return;
          sendTrack({
            event: eventName,
            path: window.location.pathname,
            sessionId: getSessionId(),
            data,
          });
        };

        document.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;
          const trackTarget = event.target.closest('[data-track]');
          if (!trackTarget) return;

          const eventName = trackTarget.getAttribute('data-track');
          if (!eventName) return;

          const label = trackTarget.getAttribute('data-track-label') || '';
          window.contentflussTrack?.(eventName, label ? { label } : {});
        });

        const depthMarks = [25, 50, 75, 100];
        const sentDepths = new Set<number>();

        function trackScrollDepth() {
          const scrollHeight = document.documentElement.scrollHeight;
          const viewportHeight = window.innerHeight;
          const scrolled = window.scrollY + viewportHeight;
          const depth = Math.min(100, Math.round((scrolled / Math.max(scrollHeight, 1)) * 100));

          depthMarks.forEach((mark) => {
            if (depth >= mark && !sentDepths.has(mark)) {
              sentDepths.add(mark);
              window.contentflussTrack?.('scroll_depth_reached', { depth: String(mark) });
            }
          });
        }

        window.addEventListener('scroll', trackScrollDepth, { passive: true });
        window.addEventListener('load', trackScrollDepth);
      }

      const revealItems = document.querySelectorAll('[data-reveal]');
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.14 }
        );

        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
