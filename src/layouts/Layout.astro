---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Contentfluss – KI-gestütztes Content-Marketing für lokale Unternehmen in Neuss und Düsseldorf.' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | Contentfluss</title>
    <slot name="head" />
  </head>
  <body class="bg-white text-gray-900 font-sans">

    <!-- Navigation -->
    <header class="border-b border-gray-100">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight">Contentfluss</a>
        <nav class="hidden md:flex gap-8 text-sm font-medium text-gray-600">
          <a href="/leistungen" class="relative hover:text-gray-900 transition-colors after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-blue-600 after:transition-all after:duration-200 hover:after:w-full">Leistungen</a>
          <a href="/ueber-mich" class="relative hover:text-gray-900 transition-colors after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-blue-600 after:transition-all after:duration-200 hover:after:w-full">Über mich</a>
          <a href="/kontakt" class="relative hover:text-gray-900 transition-colors after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-blue-600 after:transition-all after:duration-200 hover:after:w-full">Kontakt</a>
        </nav>
        <a href="/kontakt" data-track="nav_cta_clicked" data-track-label="header-desktop" class="hidden md:inline-block bg-blue-600 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors btn-primary">
          Kostenloses Erstgespräch (15 Min)
        </a>
        <button id="menu-toggle" class="md:hidden p-2 text-gray-600" aria-label="Menü öffnen">
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <!-- Mobile menu -->
      <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-100 px-6 py-4 flex flex-col gap-4 text-sm font-medium text-gray-600">
        <a href="/leistungen" class="hover:text-gray-900 transition-colors">Leistungen</a>
        <a href="/ueber-mich" class="hover:text-gray-900 transition-colors">Über mich</a>
        <a href="/kontakt" class="hover:text-gray-900 transition-colors">Kontakt</a>
        <a href="/kontakt" data-track="nav_cta_clicked" data-track-label="header-mobile" class="inline-block bg-blue-600 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors text-center">
          Kostenloses Erstgespräch (15 Min)
        </a>
      </nav>
    </header>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');
      toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
      });
    </script>

    <!-- Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 mt-24">
      <div class="max-w-5xl mx-auto px-6 py-12">
        <div class="grid md:grid-cols-2 gap-8 mb-8">
          <div>
            <a href="/" class="text-xl font-bold tracking-tight">Contentfluss</a>
            <p class="text-sm text-gray-500 mt-2">KI-Content und Automatisierung<br>für lokale Unternehmen.</p>
          </div>
          <div class="grid grid-cols-2 gap-8 text-sm">
            <div>
              <p class="font-medium text-gray-900 mb-3">Seiten</p>
              <nav class="flex flex-col gap-2 text-gray-500">
                <a href="/leistungen" class="hover:text-gray-900 transition-colors">Leistungen</a>
                <a href="/ueber-mich" class="hover:text-gray-900 transition-colors">Über mich</a>
                <a href="/kontakt" class="hover:text-gray-900 transition-colors">Kontakt</a>
              </nav>
            </div>
            <div>
              <p class="font-medium text-gray-900 mb-3">Rechtliches</p>
              <nav class="flex flex-col gap-2 text-gray-500">
                <a href="/impressum" class="hover:text-gray-900 transition-colors">Impressum</a>
                <a href="/datenschutz" class="hover:text-gray-900 transition-colors">Datenschutz</a>
              </nav>
            </div>
          </div>
        </div>
        <div class="border-t border-gray-100 pt-6 flex flex-col md:flex-row justify-between items-center gap-2 text-sm text-gray-400">
          <p>© 2026 Contentfluss – Maikel Hannen</p>
          <p>Gemacht in Neuss 🇩🇪</p>
        </div>
      </div>
    </footer>

    <script>
      if (!window['__contentflussTrackingInit']) {
        window['__contentflussTrackingInit'] = true;

        const TRACK_ENDPOINT = '/api/event';
        const TRACK_SESSION_KEY = 'contentfluss_session_id';

        function getSessionId() {
          try {
            const existing = window.localStorage.getItem(TRACK_SESSION_KEY);
            if (existing) return existing;
            const generated = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
            window.localStorage.setItem(TRACK_SESSION_KEY, generated);
            return generated;
          } catch {
            return 'anonymous';
          }
        }

        function sendTrack(payload) {
          const body = JSON.stringify(payload);
          if (navigator.sendBeacon) {
            const blob = new Blob([body], { type: 'application/json' });
            navigator.sendBeacon(TRACK_ENDPOINT, blob);
            return;
          }

          fetch(TRACK_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
            keepalive: true,
          }).catch(() => {
            // silently ignore tracking transport errors
          });
        }

        window.contentflussTrack = (eventName, data = {}) => {
          if (typeof eventName !== 'string' || !eventName.trim()) return;
          sendTrack({
            event: eventName,
            path: window.location.pathname,
            sessionId: getSessionId(),
            data,
          });
        };

        document.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;
          const trackTarget = event.target.closest('[data-track]');
          if (!trackTarget) return;

          const eventName = trackTarget.getAttribute('data-track');
          if (!eventName) return;

          const label = trackTarget.getAttribute('data-track-label') || '';
          window.contentflussTrack?.(eventName, label ? { label } : {});
        });
      }

      // Scroll animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>

    <ChatWidget />

  </body>
</html>
