---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Contentfluss – KI-gestütztes Content-Marketing für lokale Unternehmen in Neuss und Düsseldorf.' } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Contentfluss</title>
  </head>
  <body class="bg-white text-gray-900 font-sans">

    <!-- Navigation -->
    <header class="border-b border-gray-100">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-tight">Contentfluss</a>
        <nav class="hidden md:flex gap-8 text-sm font-medium text-gray-600">
          <a href="/leistungen" class="hover:text-gray-900 transition-colors">Leistungen</a>
          <a href="/ueber-mich" class="hover:text-gray-900 transition-colors">Über mich</a>
          <a href="/kontakt" class="hover:text-gray-900 transition-colors">Kontakt</a>
        </nav>
        <a href="/kontakt" class="bg-gray-900 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors">
          Gespräch buchen
        </a>
      </div>
    </header>

    <!-- Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 mt-24">
      <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
        <p>© 2026 Contentfluss – Maikel Hannen</p>
        <nav class="flex gap-6">
          <a href="/impressum" class="hover:text-gray-900 transition-colors">Impressum</a>
          <a href="/datenschutz" class="hover:text-gray-900 transition-colors">Datenschutz</a>
        </nav>
      </div>
    </footer>

  </body>
</html>
