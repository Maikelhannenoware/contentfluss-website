---
import '../styles/global.css';
import { absoluteUrl } from '../lib/seo';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  schemas?: Array<Record<string, unknown>> | Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  schemas,
  noindex = false,
} = Astro.props;

const computedTitle = title.includes('Contentfluss') ? title : `${title} | Contentfluss`;
const pathname = Astro.url.pathname;
const canonicalUrl = absoluteUrl(canonicalPath ?? pathname);
const ogImageUrl = absoluteUrl('/og-image.svg');

const allSchemas = schemas
  ? (Array.isArray(schemas) ? schemas : [schemas])
  : [];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{computedTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Contentfluss" />
    <meta property="og:title" content={computedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={computedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#060B18" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>document.documentElement.classList.add('motion-ready');</script>
    {allSchemas.map((schema) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}></script>
    ))}
    <slot name="head" />
  </head>

  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" aria-label="Contentfluss – Startseite"><Logo size="md" /></a>
        <nav class="desktop-nav" aria-label="Hauptnavigation">
          <a href="/leistungen" class="nav-link">Leistungen</a>
          <a href="/handwerk" class="nav-link">Handwerk</a>
          <a href="/immobilienverwaltung" class="nav-link">Hausverwaltung</a>
          <a href="/workflows" class="nav-link">Workflows</a>
          <a href="/ueber-uns" class="nav-link">Über uns</a>
        </nav>
        <div style="display:flex;align-items:center;gap:0.75rem">
          <a href="/kontakt" class="btn btn-primary btn-sm header-cta" data-track="header_cta">Fit-Call buchen</a>
          <button class="nav-toggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-nav-panel">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <rect y="3" width="20" height="1.75" rx="1"/>
              <rect y="9.125" width="20" height="1.75" rx="1"/>
              <rect y="15.25" width="20" height="1.75" rx="1"/>
            </svg>
          </button>
        </div>
      </div>
      <div id="mobile-nav-panel" class="mobile-nav" aria-hidden="true">
        <ul class="mobile-nav-links">
          <li><a href="/leistungen" class="mobile-nav-link">Leistungen</a></li>
          <li><a href="/handwerk" class="mobile-nav-link">Handwerk</a></li>
          <li><a href="/immobilienverwaltung" class="mobile-nav-link">Hausverwaltung</a></li>
          <li><a href="/workflows" class="mobile-nav-link">Workflows</a></li>
          <li><a href="/ueber-uns" class="mobile-nav-link">Über uns</a></li>
        </ul>
        <a href="/kontakt" class="btn btn-primary btn-full" data-track="mobile_nav_cta">Fit-Call buchen</a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <Logo size="sm" />
            <p class="footer-brand-desc">KI-Workflows für operative Prozesse in Handwerk und Hausverwaltung.</p>
            <a href="mailto:hallo@contentfluss.de" class="footer-email">hallo@contentfluss.de</a>
          </div>
          <div>
            <p class="footer-col-label">Lösungen</p>
            <ul class="footer-links">
              <li><a href="/handwerk">Handwerk</a></li>
              <li><a href="/immobilienverwaltung">Hausverwaltung</a></li>
              <li><a href="/workflows">Workflows</a></li>
              <li><a href="/leistungen">Leistungen</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-label">Unternehmen</p>
            <ul class="footer-links">
              <li><a href="/ueber-uns">Über uns</a></li>
              <li><a href="/fallbeispiele">Fallbeispiele</a></li>
              <li><a href="/kontakt">Kontakt</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-col-label">Rechtliches</p>
            <ul class="footer-links">
              <li><a href="/impressum">Impressum</a></li>
              <li><a href="/datenschutz">Datenschutz</a></li>
            </ul>
          </div>
        </div>
        <hr class="divider" style="margin-block:2rem" />
        <p class="footer-copy">© {new Date().getFullYear()} Contentfluss. Alle Rechte vorbehalten.</p>
      </div>
    </footer>

    <!-- JS Block 1: Mobile menu toggle -->
    <script>
      const header = document.querySelector('.site-header');
      const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
      const panel = document.getElementById('mobile-nav-panel');
      const syncHeaderState = () => {
        header?.classList.toggle('scrolled', window.scrollY > 50);
      };

      syncHeaderState();
      window.addEventListener('scroll', syncHeaderState, { passive: true });

      if (toggle && panel) {
        toggle.addEventListener('click', () => {
          const open = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!open));
          panel.classList.toggle('is-open', !open);
          panel.setAttribute('aria-hidden', String(open));
        });
        panel.querySelectorAll('a').forEach(a => {
          a.addEventListener('click', () => {
            toggle.setAttribute('aria-expanded', 'false');
            panel.classList.remove('is-open');
            panel.setAttribute('aria-hidden', 'true');
          });
        });
        document.addEventListener('keydown', e => {
          if (e.key === 'Escape' && panel.classList.contains('is-open')) {
            toggle.setAttribute('aria-expanded', 'false');
            panel.classList.remove('is-open');
            panel.setAttribute('aria-hidden', 'true');
            (toggle as HTMLElement).focus();
          }
        });
        window.addEventListener('resize', () => {
          if (window.innerWidth >= 960) {
            toggle.setAttribute('aria-expanded', 'false');
            panel.classList.remove('is-open');
            panel.setAttribute('aria-hidden', 'true');
          }
        });
      }
    </script>

    <!-- JS Block 2: Tracking system -->
    <script>
      declare global {
        interface Window {
          contentflussTrack?: (eventName: string, data?: Record<string, string>) => void;
          __contentflussTrackingInit?: boolean;
        }
      }

      type TrackPayload = {
        event: string;
        path: string;
        sessionId: string;
        data: Record<string, string>;
      };

      if (!window.__contentflussTrackingInit) {
        window.__contentflussTrackingInit = true;

        const TRACK_ENDPOINT = '/api/event';
        const TRACK_SESSION_KEY = 'contentfluss_session_id';

        function getSessionId() {
          try {
            const existing = window.localStorage.getItem(TRACK_SESSION_KEY);
            if (existing) return existing;
            const generated = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
            window.localStorage.setItem(TRACK_SESSION_KEY, generated);
            return generated;
          } catch {
            return 'anonymous';
          }
        }

        function sendTrack(payload: TrackPayload) {
          const body = JSON.stringify(payload);
          if (navigator.sendBeacon) {
            const blob = new Blob([body], { type: 'application/json' });
            navigator.sendBeacon(TRACK_ENDPOINT, blob);
            return;
          }

          fetch(TRACK_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
            keepalive: true,
          }).catch(() => {
            // ignore transport errors
          });
        }

        window.contentflussTrack = (eventName: string, data: Record<string, string> = {}) => {
          if (typeof eventName !== 'string' || !eventName.trim()) return;
          sendTrack({
            event: eventName,
            path: window.location.pathname,
            sessionId: getSessionId(),
            data,
          });
        };

        document.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;
          const trackTarget = event.target.closest('[data-track]');
          if (!trackTarget) return;

          const eventName = trackTarget.getAttribute('data-track');
          if (!eventName) return;

          const label = trackTarget.getAttribute('data-track-label') || '';
          window.contentflussTrack?.(eventName, label ? { label } : {});
        });

        const depthMarks = [25, 50, 75, 100];
        const sentDepths = new Set<number>();

        function trackScrollDepth() {
          const scrollHeight = document.documentElement.scrollHeight;
          const viewportHeight = window.innerHeight;
          const scrolled = window.scrollY + viewportHeight;
          const depth = Math.min(100, Math.round((scrolled / Math.max(scrollHeight, 1)) * 100));

          depthMarks.forEach((mark) => {
            if (depth >= mark && !sentDepths.has(mark)) {
              sentDepths.add(mark);
              window.contentflussTrack?.('scroll_depth_reached', { depth: String(mark) });
            }
          });
        }

        window.addEventListener('scroll', trackScrollDepth, { passive: true });
        window.addEventListener('load', trackScrollDepth);
      }
    </script>

    <!-- JS Block 3: Reveal + Stagger (NO counter) -->
    <script>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealItems = document.querySelectorAll('[data-reveal]');
      const staggerItems = document.querySelectorAll('[data-stagger]');

      if (prefersReducedMotion) {
        revealItems.forEach((item) => item.classList.add('is-visible'));
        staggerItems.forEach((item) => item.classList.add('is-visible'));
      } else if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.14 }
        );
        revealItems.forEach((item) => observer.observe(item));

        const staggerObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                staggerObs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        staggerItems.forEach((item) => staggerObs.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add('is-visible'));
        staggerItems.forEach((item) => item.classList.add('is-visible'));
      }
    </script>

    <!-- JS Block 4: Hero parallax -->
    <script>
      if (
        document.documentElement.classList.contains('motion-ready') &&
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
        window.innerWidth >= 769
      ) {
        const parallaxEls = document.querySelectorAll<HTMLElement>('[data-hero-parallax]');
        const scrollOutEls = document.querySelectorAll<HTMLElement>('[data-hero-scroll-out]');
        const supportsScrollTimeline = typeof CSS !== 'undefined' && CSS.supports('animation-timeline: scroll()');

        if (parallaxEls.length || scrollOutEls.length) {
          let ticking = false;

          const syncHeroScrollEffects = () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(() => {
                const y = window.scrollY;
                if (parallaxEls.length) {
                  parallaxEls.forEach((el) => {
                    const factor = parseFloat(el.dataset.heroParallax || '0');
                    el.style.transform = `translateY(${y * factor}px)`;
                  });
                }

                if (!supportsScrollTimeline && scrollOutEls.length) {
                  const heroProgress = Math.min(1, Math.max(0, y / (window.innerHeight * 0.55)));
                  scrollOutEls.forEach((el) => {
                    el.style.setProperty('--hero-scroll-shift', `${heroProgress * -30}px`);
                    el.style.setProperty('--hero-scroll-fade', String(1 - heroProgress * 0.7));
                    el.style.setProperty('--hero-scroll-blur', `${heroProgress * 4}px`);
                  });
                }

                ticking = false;
              });
            }
          };

          window.addEventListener('scroll', syncHeroScrollEffects, { passive: true });
          syncHeroScrollEffects();
        }
      }
    </script>

    <!-- JS Block 5: Hero cursor glow -->
    <script>
      (() => {
        if (!document.documentElement.classList.contains('motion-ready')) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        if (window.innerWidth < 769 || !window.matchMedia('(pointer: fine)').matches) return;

        const hero = document.querySelector<HTMLElement>('.home-hero');
        const glow = document.querySelector<HTMLElement>('.home-hero-cursor-glow');
        if (!hero || !glow) return;

        let targetX = 0;
        let targetY = 0;
        let currentX = 0;
        let currentY = 0;
        let ticking = false;

        const updateGlow = () => {
          currentX += (targetX - currentX) * 0.15;
          currentY += (targetY - currentY) * 0.15;
          glow.style.transform = `translate(${currentX - 200}px, ${currentY - 200}px)`;

          if (Math.abs(targetX - currentX) > 0.5 || Math.abs(targetY - currentY) > 0.5) {
            requestAnimationFrame(updateGlow);
          } else {
            ticking = false;
          }
        };

        hero.addEventListener('mousemove', (event) => {
          const rect = hero.getBoundingClientRect();
          targetX = event.clientX - rect.left;
          targetY = event.clientY - rect.top;

          if (!ticking) {
            ticking = true;
            requestAnimationFrame(updateGlow);
          }
        });

        hero.addEventListener('mouseenter', () => {
          glow.style.opacity = '1';
        });

        hero.addEventListener('mouseleave', () => {
          glow.style.opacity = '0';
        });
      })();
    </script>
  </body>
</html>
