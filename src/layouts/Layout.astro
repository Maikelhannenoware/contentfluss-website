---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title: string;
  description?: string;
}

const defaultDescription = 'Wir automatisieren Geschäftsprozesse mit KI - pragmatisch, messbar und DSGVO-konform.';
const { title, description = defaultDescription } = Astro.props;
const computedTitle = title.includes('Contentfluss') ? title : `${title} | Contentfluss`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{computedTitle}</title>
    <slot name="head" />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans">
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-xl font-extrabold tracking-tight text-slate-900">Contentfluss</a>

        <nav class="hidden gap-8 text-sm font-medium text-slate-600 md:flex">
          <a href="/leistungen" class="nav-link">Leistungen</a>
          <a href="/ueber-mich" class="nav-link">Über uns</a>
          <a href="/kontakt" class="nav-link">Kontakt</a>
        </nav>

        <a
          href="/kontakt"
          data-track="nav_cta_clicked"
          data-track-label="header-desktop"
          class="btn-primary hidden rounded-lg px-4 py-2 text-sm font-semibold text-white md:inline-block"
        >
          Erstgespräch buchen
        </a>

        <button id="menu-toggle" class="p-2 text-slate-700 md:hidden" aria-label="Menü öffnen">
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <nav id="mobile-menu" class="hidden border-t border-slate-200 bg-white px-6 py-4 md:hidden">
        <div class="flex flex-col gap-4 text-sm font-medium text-slate-700">
          <a href="/leistungen" class="hover:text-slate-900 transition-colors">Leistungen</a>
          <a href="/ueber-mich" class="hover:text-slate-900 transition-colors">Über uns</a>
          <a href="/kontakt" class="hover:text-slate-900 transition-colors">Kontakt</a>
          <a
            href="/kontakt"
            data-track="nav_cta_clicked"
            data-track-label="header-mobile"
            class="btn-primary inline-block rounded-lg px-4 py-2 text-center text-sm font-semibold text-white"
          >
            Erstgespräch buchen
          </a>
        </div>
      </nav>
    </header>

    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const iconOpen = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-slate-200 bg-white">
      <div class="mx-auto w-full max-w-6xl px-6 py-12">
        <div class="mb-8 grid gap-8 md:grid-cols-2">
          <div>
            <a href="/" class="text-xl font-extrabold tracking-tight text-slate-900">Contentfluss</a>
            <p class="mt-2 text-sm text-slate-500">KI-Automatisierung und Workflows für KMU in Deutschland.</p>
          </div>

          <div class="grid grid-cols-2 gap-8 text-sm">
            <div>
              <p class="mb-3 font-semibold text-slate-900">Seiten</p>
              <nav class="flex flex-col gap-2 text-slate-500">
                <a href="/leistungen" class="hover:text-slate-900 transition-colors">Leistungen</a>
                <a href="/ueber-mich" class="hover:text-slate-900 transition-colors">Über uns</a>
                <a href="/kontakt" class="hover:text-slate-900 transition-colors">Kontakt</a>
              </nav>
            </div>

            <div>
              <p class="mb-3 font-semibold text-slate-900">Rechtliches</p>
              <nav class="flex flex-col gap-2 text-slate-500">
                <a href="/impressum" class="hover:text-slate-900 transition-colors">Impressum</a>
                <a href="/datenschutz" class="hover:text-slate-900 transition-colors">Datenschutz</a>
              </nav>
            </div>
          </div>
        </div>

        <div class="flex flex-col items-center justify-between gap-2 border-t border-slate-200 pt-6 text-sm text-slate-400 md:flex-row">
          <p>© 2026 Contentfluss - Maikel Hannen</p>
          <p>Deutschlandweit erreichbar (remote oder vor Ort)</p>
        </div>
      </div>
    </footer>

    <script>
      if (!window['__contentflussTrackingInit']) {
        window['__contentflussTrackingInit'] = true;

        const TRACK_ENDPOINT = '/api/event';
        const TRACK_SESSION_KEY = 'contentfluss_session_id';

        function getSessionId() {
          try {
            const existing = window.localStorage.getItem(TRACK_SESSION_KEY);
            if (existing) return existing;
            const generated = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
            window.localStorage.setItem(TRACK_SESSION_KEY, generated);
            return generated;
          } catch {
            return 'anonymous';
          }
        }

        function sendTrack(payload) {
          const body = JSON.stringify(payload);
          if (navigator.sendBeacon) {
            const blob = new Blob([body], { type: 'application/json' });
            navigator.sendBeacon(TRACK_ENDPOINT, blob);
            return;
          }

          fetch(TRACK_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
            keepalive: true,
          }).catch(() => {
            // silently ignore tracking transport errors
          });
        }

        window.contentflussTrack = (eventName, data = {}) => {
          if (typeof eventName !== 'string' || !eventName.trim()) return;
          sendTrack({
            event: eventName,
            path: window.location.pathname,
            sessionId: getSessionId(),
            data,
          });
        };

        document.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;
          const trackTarget = event.target.closest('[data-track]');
          if (!trackTarget) return;

          const eventName = trackTarget.getAttribute('data-track');
          if (!eventName) return;

          const label = trackTarget.getAttribute('data-track-label') || '';
          window.contentflussTrack?.(eventName, label ? { label } : {});
        });
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>

    <ChatWidget />
  </body>
</html>
