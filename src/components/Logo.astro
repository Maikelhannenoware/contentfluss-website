---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}
const { size = 'md', class: cls } = Astro.props;
const iconSize = { sm: 22, md: 26, lg: 34 }[size];
const titleSize = { sm: '0.9375rem', md: '1rem', lg: '1.25rem' }[size];
---
<span class:list={['logo', cls]} style={`--icon:${iconSize}px;--title:${titleSize}`}>
  <svg width={iconSize} height={iconSize} viewBox="0 0 28 28" fill="none" aria-hidden="true">
    <rect width="28" height="28" rx="7" fill="#1558FF"/>
    <path d="M7 10h8M7 14h14M7 18h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
  </svg>
  <span class="logo-name">Contentfluss</span>
</span>
<style>
  .logo { display: inline-flex; align-items: center; gap: 0.55rem; }
  .logo-name {
    font-family: var(--font-display);
    font-size: var(--title);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1;
  }
</style>
