---
// ChatWidget – Flo, der Contentfluss Assistent
---

<div id="chat-container" class="chat-container">
  <div
    id="chat-window"
    role="dialog"
    aria-modal="true"
    aria-label="Chat mit Flo"
    aria-hidden="true"
    class="chat-window"
    hidden
  >
    <div class="chat-header">
      <div class="chat-header-meta">
        <div class="chat-brand-avatar">F</div>
        <div>
          <p class="chat-title">Flo</p>
          <p class="chat-subtitle">Contentfluss Assistent</p>
        </div>
      </div>
      <button id="chat-close" class="chat-icon-btn" aria-label="Chat schließen">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div id="chat-messages" aria-live="polite" aria-label="Chatverlauf" class="chat-messages"></div>

    <div class="chat-input-area">
      <div class="chat-form-wrap">
        <form id="chat-form" class="chat-form">
          <input
            id="chat-input"
            type="text"
            placeholder="Nachricht schreiben..."
            maxlength="500"
            autocomplete="off"
            class="chat-input"
          />
          <button id="chat-submit" type="submit" aria-label="Senden" class="chat-submit">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
        </form>
      </div>

      <div class="chat-booking">
        <a href="/kontakt" data-track="chat_booking_bar_clicked" class="chat-booking-link">
          Kostenloses Erstgespräch (15 Min)
        </a>
      </div>
    </div>
  </div>

  <div class="chat-toggle-wrap">
    <button
      id="chat-toggle"
      aria-label="Chat öffnen"
      aria-expanded="false"
      aria-controls="chat-window"
      class="chat-toggle"
    >
      <svg id="chat-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
      </svg>
      <svg id="chat-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <span id="chat-badge" aria-label="Ungelesene Nachricht" class="chat-badge" hidden>1</span>
  </div>
</div>

<style is:global>
  .chat-container {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .chat-window {
    width: 360px;
    max-width: calc(100vw - 2rem);
    height: min(560px, calc(100svh - 110px));
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #ffffff;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2), 0 10px 25px rgba(0, 0, 0, 0.12);
  }

  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    flex-shrink: 0;
  }

  .chat-header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .chat-brand-avatar {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    color: #ffffff;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.4);
  }

  .chat-title {
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .chat-subtitle {
    color: #94a3b8;
    font-size: 0.75rem;
  }

  .chat-icon-btn {
    border: 0;
    background: transparent;
    color: #94a3b8;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 0.375rem;
    transition: color 0.15s ease;
  }

  .chat-icon-btn:hover,
  .chat-icon-btn:focus-visible {
    color: #ffffff;
    outline: none;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: #f8fafc;
  }

  .chat-input-area {
    border-top: 1px solid #e2e8f0;
    background: #ffffff;
    flex-shrink: 0;
  }

  .chat-form-wrap {
    padding: 0.75rem 1rem 0.5rem;
  }

  .chat-form {
    display: flex;
    gap: 0.5rem;
  }

  .chat-input {
    flex: 1;
    font-size: 0.875rem;
    padding: 0.56rem 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.625rem;
    outline: none;
    background: #f8fafc;
    color: #1e293b;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .chat-input:focus {
    border-color: #3b82f6;
    background: #ffffff;
  }

  .chat-submit {
    border: 0;
    border-radius: 0.625rem;
    padding: 0.56rem 0.81rem;
    color: #ffffff;
    cursor: pointer;
    flex-shrink: 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    transition: opacity 0.15s ease;
  }

  .chat-submit:hover,
  .chat-submit:focus-visible {
    opacity: 0.85;
    outline: none;
  }

  .chat-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .chat-booking {
    text-align: center;
    padding: 0 1rem 0.75rem;
  }

  .chat-booking-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 9999px;
    padding: 0.375rem 0.875rem;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .chat-booking-link:hover,
  .chat-booking-link:focus-visible {
    background: #dbeafe;
    border-color: #93c5fd;
    outline: none;
  }

  .chat-toggle-wrap {
    position: relative;
  }

  .chat-toggle {
    width: 56px;
    height: 56px;
    border: 0;
    border-radius: 9999px;
    color: #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.4), 0 3px 8px rgba(0, 0, 0, 0.2);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .chat-toggle:hover,
  .chat-toggle:focus-visible {
    opacity: 0.9;
    transform: scale(1.05);
    outline: none;
  }

  .chat-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: #ffffff;
    background: #ef4444;
    border-radius: 9999px;
    box-shadow: 0 2px 6px rgba(239, 68, 68, 0.5);
  }

  .chat-message {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .chat-message-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .chat-message-user {
    flex-direction: row-reverse;
  }

  .chat-avatar {
    width: 28px;
    height: 28px;
    border-radius: 9999px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  .chat-avatar-user {
    font-size: 9px;
    color: #64748b;
    background: #e2e8f0;
  }

  .chat-avatar-assistant {
    font-size: 12px;
    color: #ffffff;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    box-shadow: 0 2px 6px rgba(59, 130, 246, 0.35);
  }

  .chat-bubble {
    max-width: 78%;
    font-size: 14px;
    line-height: 1.55;
    padding: 0.625rem 0.875rem;
    border-radius: 1rem;
    word-break: break-word;
  }

  .chat-bubble-user {
    color: #ffffff;
    border-bottom-right-radius: 4px;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.25);
  }

  .chat-bubble-assistant {
    color: #1e293b;
    border: 1px solid #e2e8f0;
    border-bottom-left-radius: 4px;
    background: #ffffff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .chat-inline-link {
    color: #2563eb;
    text-decoration: underline;
    font-weight: 600;
  }

  .chat-quick-replies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.5rem 0 0.125rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .chat-quick-replies-visible {
    opacity: 1;
  }

  .chat-chip {
    font-size: 12px;
    padding: 0.4375rem 0.8125rem;
    border-radius: 9999px;
    border: 1.5px solid #cbd5e1;
    color: #475569;
    background: #ffffff;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
    font-weight: 500;
  }

  .chat-chip:hover,
  .chat-chip:focus-visible {
    background: #eff6ff;
    border-color: #3b82f6;
    color: #2563eb;
    outline: none;
  }

  .chat-typing {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .chat-typing-bubble {
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    border-bottom-left-radius: 4px;
    background: #ffffff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    padding: 0.75rem 0.875rem;
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .chat-typing-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: #94a3b8;
    display: inline-block;
    animation: typingDot 1.2s infinite;
  }

  .chat-typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .chat-typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @media (max-width: 640px) {
    .chat-container {
      right: 1rem;
      bottom: 1rem;
    }

    .chat-window {
      max-width: calc(100vw - 1rem);
    }
  }

  @keyframes typingDot {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }
</style>

<script>
  type TrackFn = (eventName: string, data?: Record<string, string>) => void;
  type TrackWindow = Window & typeof globalThis & { contentflussTrack?: TrackFn };
  type Message = { role: 'user' | 'assistant'; content: string };

  const chatWindow = document.getElementById('chat-window') as HTMLDivElement | null;
  const chatToggle = document.getElementById('chat-toggle') as HTMLButtonElement | null;
  const chatClose = document.getElementById('chat-close') as HTMLButtonElement | null;
  const chatMessages = document.getElementById('chat-messages') as HTMLDivElement | null;
  const chatForm = document.getElementById('chat-form') as HTMLFormElement | null;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement | null;
  const chatSubmit = document.getElementById('chat-submit') as HTMLButtonElement | null;
  const iconOpen = document.getElementById('chat-icon-open') as SVGElement | null;
  const iconClose = document.getElementById('chat-icon-close') as SVGElement | null;
  const chatBadge = document.getElementById('chat-badge') as HTMLSpanElement | null;

  if (chatWindow && chatToggle && chatClose && chatMessages && chatForm && chatInput && chatSubmit && iconOpen && iconClose && chatBadge) {
    let messages: Message[] = [];
    let isOpen = false;
    let greeted = false;
    let unreadCount = 0;
    let isSending = false;
    let userMessageCount = 0;
    let bookingPromptShown = false;
    let previousFocus: HTMLElement | null = null;

    function track(eventName: string, data?: Record<string, string>) {
      (window as TrackWindow).contentflussTrack?.(eventName, data);
    }

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function parseLinks(text: string): string {
      const escaped = escapeHtml(text);
      return escaped.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_, label, url) => {
        const isRelative = url.startsWith('/');
        const isHttps = url.startsWith('https://');
        const safeUrl = isRelative || isHttps ? url : '#';
        const target = isRelative ? '_self' : '_blank';
        const rel = target === '_blank' ? ' rel="noopener noreferrer"' : '';
        return `<a href="${escapeHtml(safeUrl)}" class="chat-inline-link" target="${target}"${rel}>${escapeHtml(label)}</a>`;
      });
    }

    function updateBadge() {
      if (unreadCount > 0 && !isOpen) {
        chatBadge.textContent = String(unreadCount);
        chatBadge.hidden = false;
      } else {
        chatBadge.hidden = true;
      }
    }

    function scrollToBottom() {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function addMessage(role: 'user' | 'assistant', content: string) {
      const wrapper = document.createElement('div');
      wrapper.className = `chat-message ${role === 'user' ? 'chat-message-user' : ''}`.trim();

      const avatar = document.createElement('div');
      avatar.className = `chat-avatar ${role === 'user' ? 'chat-avatar-user' : 'chat-avatar-assistant'}`;
      avatar.textContent = role === 'user' ? 'Du' : 'F';

      const bubble = document.createElement('div');
      bubble.className = `chat-bubble ${role === 'user' ? 'chat-bubble-user' : 'chat-bubble-assistant'}`;

      if (role === 'user') {
        bubble.textContent = content;
      } else {
        bubble.innerHTML = parseLinks(content);
      }

      wrapper.appendChild(avatar);
      wrapper.appendChild(bubble);
      chatMessages.appendChild(wrapper);

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          wrapper.classList.add('chat-message-visible');
          scrollToBottom();
        });
      });

      if (role === 'assistant' && !isOpen) {
        unreadCount += 1;
        updateBadge();
      }
    }

    function addQuickReplies() {
      const chips = [
        { label: 'Preise ansehen', text: 'Was kostet das?' },
        { label: 'Termin buchen', text: 'Ich möchte einen Termin buchen.' },
        { label: 'Was macht ihr?', text: 'Was macht ihr genau?' },
      ];

      const wrapper = document.createElement('div');
      wrapper.id = 'quick-replies';
      wrapper.className = 'chat-quick-replies';

      chips.forEach(({ label, text }) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'chat-chip';
        btn.textContent = label;
        btn.addEventListener('click', async () => {
          wrapper.remove();
          await sendMessage(text, 'quick_reply');
        });
        wrapper.appendChild(btn);
      });

      chatMessages.appendChild(wrapper);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          wrapper.classList.add('chat-quick-replies-visible');
          scrollToBottom();
        });
      });
    }

    function showTyping() {
      const wrapper = document.createElement('div');
      wrapper.id = 'typing-indicator';
      wrapper.className = 'chat-typing';

      const avatar = document.createElement('div');
      avatar.className = 'chat-avatar chat-avatar-assistant';
      avatar.textContent = 'F';

      const bubble = document.createElement('div');
      bubble.className = 'chat-typing-bubble';

      for (let i = 0; i < 3; i += 1) {
        const dot = document.createElement('span');
        dot.className = 'chat-typing-dot';
        bubble.appendChild(dot);
      }

      wrapper.appendChild(avatar);
      wrapper.appendChild(bubble);
      chatMessages.appendChild(wrapper);
      scrollToBottom();
    }

    function removeTyping() {
      document.getElementById('typing-indicator')?.remove();
    }

    function setLoading(loading: boolean) {
      isSending = loading;
      chatInput.disabled = loading;
      chatSubmit.disabled = loading;
    }

    function maybeAddBookingPrompt() {
      if (bookingPromptShown || userMessageCount < 2) return;
      bookingPromptShown = true;
      const ctaMessage = 'Wenn du magst, kannst du direkt ein [Kostenloses Erstgespräch (15 Min)](/kontakt) buchen.';
      messages.push({ role: 'assistant', content: ctaMessage });
      addMessage('assistant', ctaMessage);
    }

    async function sendMessage(content: string, source: 'manual' | 'quick_reply' = 'manual') {
      if (isSending) return;

      setLoading(true);
      chatInput.value = '';
      messages.push({ role: 'user', content });
      userMessageCount += 1;
      addMessage('user', content);
      showTyping();
      track('chat_message_sent', { source });

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages }),
        });

        const data = (await res.json().catch(() => ({}))) as {
          success?: boolean;
          reply?: string;
          code?: string;
        };

        removeTyping();
        if (res.ok && data.success && typeof data.reply === 'string' && data.reply.trim()) {
          const reply = data.reply.trim();
          messages.push({ role: 'assistant', content: reply });
          addMessage('assistant', reply);
        } else {
          const code = typeof data.code === 'string' ? data.code : `HTTP_${res.status}`;
          addMessage('assistant', 'Der Chat ist gerade kurz überlastet. Nutze bitte die [Kontaktseite](/kontakt), dann melden wir uns schnell bei dir.');
          track('chat_error_fallback_shown', { code });
        }
      } catch {
        removeTyping();
        addMessage('assistant', 'Entschuldigung, da ist etwas schiefgelaufen. Bitte nutze die [Kontaktseite](/kontakt).');
        track('chat_error_fallback_shown', { code: 'NETWORK_ERROR' });
      } finally {
        maybeAddBookingPrompt();
        setLoading(false);
        if (isOpen) chatInput.focus();
      }
    }

    function openChat() {
      isOpen = true;
      previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      chatWindow.hidden = false;
      chatWindow.setAttribute('aria-hidden', 'false');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      chatToggle.setAttribute('aria-label', 'Chat schließen');
      chatToggle.setAttribute('aria-expanded', 'true');
      unreadCount = 0;
      updateBadge();
      track('chat_opened');

      if (!greeted) {
        greeted = true;
        const greeting = 'Hallo! Ich bin Flo, der Assistent von Contentfluss. Womit kann ich euch helfen?';
        messages.push({ role: 'assistant', content: greeting });
        addMessage('assistant', greeting);
        addQuickReplies();
      }

      requestAnimationFrame(() => chatInput.focus());
    }

    function closeChat() {
      isOpen = false;
      chatWindow.hidden = true;
      chatWindow.setAttribute('aria-hidden', 'true');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      chatToggle.setAttribute('aria-label', 'Chat öffnen');
      chatToggle.setAttribute('aria-expanded', 'false');

      const focusTarget = previousFocus && document.contains(previousFocus) ? previousFocus : chatToggle;
      focusTarget.focus();
      previousFocus = null;
    }

    function handleDocumentKeydown(event: KeyboardEvent) {
      if (event.key === 'Escape' && isOpen) {
        closeChat();
        return;
      }

      if (event.key !== 'Tab' || !isOpen) return;

      const focusable = Array.from(
        chatWindow.querySelectorAll<HTMLElement>(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        )
      ).filter((element) => !element.hasAttribute('disabled'));

      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    }

    chatToggle.addEventListener('click', () => (isOpen ? closeChat() : openChat()));
    chatClose.addEventListener('click', closeChat);
    chatForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const content = chatInput.value.trim();
      if (!content || isSending) return;
      document.getElementById('quick-replies')?.remove();
      await sendMessage(content, 'manual');
    });

    document.addEventListener('keydown', handleDocumentKeydown);
    document.addEventListener('astro:before-swap', () => {
      document.removeEventListener('keydown', handleDocumentKeydown);
    }, { once: true });
  }
</script>
